---
import SEOHead from '../components/seo/SEOHead.astro';
import LandingNav from '../components/nav/LandingNav.astro';
import LandingFooter from '../components/footer/LandingFooter.astro';
import CookieConsentBanner from '../components/legal/CookieConsentBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
  nofollow?: boolean;
}

const props = Astro.props;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://www.shortselect.com/#organization",
  name: "ShortSelect",
  url: "https://www.shortselect.com",
  logo: { "@type": "ImageObject", url: "https://www.shortselect.com/logo.svg" },
  description: "KI-gestützte Recruiting Software und ATS für moderne Teams",
  contactPoint: {
    "@type": "ContactPoint",
    email: "hello@shortselect.com",
    contactType: "Customer Service",
    availableLanguage: ["German", "English"],
  },
  sameAs: [
    "https://linkedin.com/company/shortselect",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://www.shortselect.com/#website",
  url: "https://www.shortselect.com/",
  name: "ShortSelect",
  inLanguage: "de-DE",
  publisher: { "@id": "https://www.shortselect.com/#organization" },
};
---

<!doctype html>
<html lang="de" class="no-js">
  <head>
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>
    <SEOHead {...props} jsonLd={props.jsonLd
      ? [orgSchema, websiteSchema, ...(Array.isArray(props.jsonLd) ? props.jsonLd : [props.jsonLd])]
      : [orgSchema, websiteSchema]} />
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <LandingNav />
    <main>
      <slot />
    </main>
    <LandingFooter />
    <CookieConsentBanner />

    <!-- Landing sections handle their own IntersectionObserver reveal animations -->
    <!-- Global data-reveal observer for non-landing pages (blog, produkt, etc.) -->
    <script is:inline>
      (function() {
        var selector = 'main [data-reveal], main .reveal-item, main .opacity-0.translate-y-8, main .opacity-0.translate-y-12';
        function reveal(el) {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
          el.classList.add('revealed');
        }
        var observer = new IntersectionObserver(
          function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                var delay = entry.target.getAttribute('data-reveal-delay');
                if (delay) {
                  entry.target.style.transitionDelay = delay + 'ms';
                }
                reveal(entry.target);
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px' }
        );
        function init() {
          var elements = document.querySelectorAll(selector);
          elements.forEach(function(el) { observer.observe(el); });
          window.setTimeout(function() {
            elements.forEach(function(el) {
              if (!el.classList.contains('revealed')) reveal(el);
            });
          }, 1800);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
