---
// HeroSection - Main hero with animated gradient background and mount animations
---

<section class="relative overflow-hidden py-20 md:py-32">
  <!-- Animated Gradient Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-accent/5 to-background"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,hsl(var(--primary)/0.15),transparent_50%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_80%,hsl(var(--accent)/0.1),transparent_50%)]"></div>

  <!-- Floating Shapes -->
  <div class="absolute top-20 left-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl animate-float-slow"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent/10 rounded-full blur-3xl animate-float-slow" style="animation-delay: -3s;"></div>
  <div class="absolute top-1/2 left-1/4 w-48 h-48 bg-primary/5 rounded-full blur-2xl animate-float" style="animation-delay: -1.5s;"></div>

  <!-- Decorative Grid -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]"></div>

  <div class="container relative mx-auto px-4">
    <div class="hero-container mx-auto max-w-4xl text-center space-y-8">
      <!-- Animated Badge -->
      <div class="hero-animate hero-badge inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20">
        <svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
          <path d="M20 3v4"/>
          <path d="M22 5h-4"/>
          <path d="M4 17v2"/>
          <path d="M5 18H3"/>
        </svg>
        <span class="text-sm font-medium">Für Recruiting-Agenturen & Personalvermittler</span>
      </div>

      <!-- Animated Headline -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold tracking-tight">
        <span class="hero-animate hero-headline hero-delay-100 inline-block">
          Stellen besetzen.
        </span>{" "}
        <span class="hero-animate hero-headline hero-delay-200 inline-block text-primary relative">
          Schneller. Mit halb so viel Aufwand.
          <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 280 8" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path id="hero-underline-path" d="M2 6C70 2 210 2 278 6" stroke="currentColor" stroke-width="3" stroke-linecap="round" style="stroke-dasharray: 280; stroke-dashoffset: 280; transition: stroke-dashoffset 1s ease-out;" />
          </svg>
        </span>
      </h1>

      <!-- Subline -->
      <p class="hero-animate hero-headline hero-delay-300 text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
        ShortSelect ist das ATS mit KI-Agenten, die Screening, Matching und Nurturing für Sie erledigen. Sie konzentrieren sich auf Gespräche, nicht auf Verwaltung.
      </p>

      <!-- Animated CTAs -->
      <div class="hero-animate hero-headline hero-delay-500 flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <a href="https://app.shortselect.com/signup" class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-primary-foreground font-semibold rounded-lg text-base group relative overflow-hidden hover:shadow-lg transition-shadow">
          <span class="relative z-10 flex items-center gap-2">
            Demo buchen
            <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </span>
          <div class="absolute inset-0 bg-gradient-to-r from-primary via-accent to-primary bg-[length:200%_100%] opacity-0 group-hover:opacity-100 transition-opacity animate-gradient-shift"></div>
        </a>
        <a href="#features" class="inline-flex items-center px-8 py-3 border-2 border-border font-semibold rounded-lg text-base group hover:border-primary/50 transition-colors">
          <span class="group-hover:text-primary transition-colors">So funktioniert's</span>
        </a>
      </div>

      <!-- Social Proof -->
      <div class="hero-animate hero-social hero-delay-600 text-sm text-muted-foreground pt-8">
        <span class="inline-flex items-center gap-2">
          <span class="flex -space-x-2">
            <img src="/testimonials/yasar-sentuerk.webp" alt="Yasar Sentürk, Geschäftsführer searched GmbH" width="24" height="24" decoding="async" class="w-6 h-6 rounded-full object-cover object-top border-2 border-background" style="animation-delay: 0ms;" />
            <img src="/testimonials/bahadir-battal.webp" alt="Bahadir Battal, Gründer VeraPartners" width="24" height="24" decoding="async" class="w-6 h-6 rounded-full object-cover object-top border-2 border-background" style="animation-delay: 100ms;" />
            <img src="/testimonials/alireza-nikjou.webp" alt="Alireza Nikjou, Geschäftsführer Experiton" width="24" height="24" decoding="async" class="w-6 h-6 rounded-full object-cover object-top border-2 border-background" style="animation-delay: 200ms;" />
            <img src="/testimonials/nordin-begdouri.webp" alt="Nordin Begdouri, Geschäftsführer SalesWorx" width="24" height="24" decoding="async" class="w-6 h-6 rounded-full object-cover object-top border-2 border-background" style="animation-delay: 300ms;" />
          </span>
          Vertraut von 43+ Recruiting-Teams weltweit
        </span>
      </div>
    </div>
  </div>

  <!-- Bottom Fade -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent"></div>
</section>

<style>
  /* Badge: opacity + translateY(-16px) matching React's -translate-y-4 */
  .hero-container .hero-badge {
    opacity: 0;
    transform: translateY(-16px);
    transition: all 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hero-container.mounted .hero-badge {
    opacity: 1;
    transform: translateY(0);
  }

  /* Headlines & subline & CTAs: opacity + translateY(32px) matching React's translate-y-8 */
  .hero-container .hero-headline {
    opacity: 0;
    transform: translateY(32px);
    transition: all 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hero-container.mounted .hero-headline {
    opacity: 1;
    transform: translateY(0);
  }

  /* Social proof: only opacity, no translateY — matching React which only uses opacity-100/opacity-0 */
  .hero-container .hero-social {
    opacity: 0;
    transition: all 700ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hero-container.mounted .hero-social {
    opacity: 1;
  }

  /* Delays matching React's delay-100 through delay-600 */
  .hero-container.mounted .hero-delay-100 { transition-delay: 100ms; }
  .hero-container.mounted .hero-delay-200 { transition-delay: 200ms; }
  .hero-container.mounted .hero-delay-300 { transition-delay: 300ms; }
  .hero-container.mounted .hero-delay-400 { transition-delay: 400ms; }
  .hero-container.mounted .hero-delay-500 { transition-delay: 500ms; }
  .hero-container.mounted .hero-delay-600 { transition-delay: 600ms; }
</style>

<script is:inline>
  requestAnimationFrame(function() {
    document.querySelector('.hero-container')?.classList.add('mounted');
    var ul = document.getElementById('hero-underline-path');
    if (ul) { setTimeout(function() { ul.style.strokeDashoffset = '0'; }, 800); }
  });
</script>
