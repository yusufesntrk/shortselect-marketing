---
// CTASection - Final CTA banner with gradient background
---

<section
  class="py-20 md:py-32 text-white relative overflow-hidden"
  style="background: linear-gradient(to bottom right, hsl(0 72% 50%), hsl(0 72% 52%), hsl(12 76% 61%));"
>
  <!-- Animated background shapes -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-white/5 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-white/5 rounded-full blur-3xl animate-float-slow" style="animation-delay: -3s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-white/[0.03] rounded-full blur-3xl animate-pulse"></div>
  </div>

  <!-- Decorative particles -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 10%; top: 20%; animation-delay: 0.5s; animation-duration: 4s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 25%; top: 60%; animation-delay: 1.2s; animation-duration: 5s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 40%; top: 30%; animation-delay: 2.1s; animation-duration: 3.5s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 55%; top: 70%; animation-delay: 0.8s; animation-duration: 6s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 70%; top: 15%; animation-delay: 3.5s; animation-duration: 4.5s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 85%; top: 50%; animation-delay: 1.8s; animation-duration: 5.5s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 15%; top: 80%; animation-delay: 4.2s; animation-duration: 3.8s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 50%; top: 10%; animation-delay: 2.5s; animation-duration: 4.2s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 90%; top: 40%; animation-delay: 0.3s; animation-duration: 6.5s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 35%; top: 90%; animation-delay: 3.1s; animation-duration: 4.8s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 60%; top: 45%; animation-delay: 1.5s; animation-duration: 5.2s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 5%; top: 55%; animation-delay: 4.8s; animation-duration: 3.3s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 78%; top: 85%; animation-delay: 2.8s; animation-duration: 5.8s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 45%; top: 5%; animation-delay: 0.1s; animation-duration: 4.6s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 20%; top: 35%; animation-delay: 3.8s; animation-duration: 6.2s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 65%; top: 25%; animation-delay: 1.0s; animation-duration: 3.6s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 80%; top: 65%; animation-delay: 4.5s; animation-duration: 5.4s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 30%; top: 75%; animation-delay: 2.3s; animation-duration: 4.1s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 95%; top: 8%; animation-delay: 0.7s; animation-duration: 5.7s;"></div>
    <div class="absolute w-1 h-1 bg-white/30 rounded-full animate-float" style="left: 12%; top: 42%; animation-delay: 1.6s; animation-duration: 4.4s;"></div>
  </div>

  <!-- Grid pattern -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.08)_1px,transparent_1px)] bg-[size:32px_32px] opacity-40"></div>

  <div class="container relative mx-auto px-4">
    <div data-reveal class="max-w-3xl mx-auto text-center space-y-8">
      <!-- Headline -->
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-display font-bold leading-tight">
        Bereit, Ihr Recruiting zu{" "}
        <span class="relative inline-block">
          revolutionieren
          <svg
            class="absolute -bottom-2 left-0 w-full"
            viewBox="0 0 300 12"
            fill="none"
          >
            <path
              d="M2 10C60 4 240 4 298 10"
              stroke="rgba(255,255,255,0.5)"
              stroke-width="4"
              stroke-linecap="round"
              class="cta-underline"
              style="stroke-dasharray: 300; stroke-dashoffset: 300;"
            />
          </svg>
        </span>
        ?
      </h2>

      <!-- Subtext -->
      <p data-reveal data-reveal-delay="200" class="text-lg md:text-xl text-white/90">
        Starten Sie noch heute Ihre kostenlose 14-Tage-Testversion.
        <br class="hidden sm:block" />
        Keine Kreditkarte erforderlich.
      </p>

      <!-- CTA Buttons -->
      <div data-reveal data-reveal-delay="400" class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <!-- Primary CTA with shimmer effect -->
        <a href="https://app.shortselect.com/signup" class="inline-flex items-center gap-2 px-8 py-3 bg-white text-primary font-semibold rounded-lg text-base group relative overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-105">
          <!-- Shimmer overlay -->
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
          <span class="relative z-10 flex items-center gap-2">
            <svg class="h-5 w-5 animate-pulse" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>
              <path d="M20 3v4"/>
              <path d="M22 5h-4"/>
              <path d="M4 17v2"/>
              <path d="M5 18H3"/>
            </svg>
            Jetzt kostenlos testen
            <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </span>
        </a>

        <!-- Secondary CTA -->
        <a href="https://app.shortselect.com/signup" class="inline-flex items-center px-8 py-3 bg-transparent text-white border-2 border-white/50 font-semibold rounded-lg text-base transition-all duration-300 hover:bg-white/10 hover:border-white hover:scale-105">
          Demo vereinbaren
        </a>
      </div>

      <!-- Trust indicators -->
      <div data-reveal data-reveal-delay="600" class="flex flex-wrap items-center justify-center gap-6 pt-8 text-sm text-white/70">
        <span class="flex items-center gap-2">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          14 Tage kostenlos
        </span>
        <span class="flex items-center gap-2">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Keine Kreditkarte
        </span>
        <span class="flex items-center gap-2">
          <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          Jederzeit kündbar
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-underline {
    transition: stroke-dashoffset 1s ease-out 0.5s;
  }
  :global([data-reveal].revealed) .cta-underline {
    stroke-dashoffset: 0;
  }
</style>
