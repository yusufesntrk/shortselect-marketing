---
// AgentsVsFeaturesSection - Two-column comparison: KI-Features vs. KI-Agenten
---

<section id="agents-vs-features" class="py-20 md:py-32 bg-muted/30">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div id="avf-header" class="text-center space-y-4 mb-16 opacity-0 translate-y-8 transition-all duration-700">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20">
        <span class="text-sm font-medium">Der Unterschied</span>
      </div>
      <h2 class="text-3xl md:text-5xl font-display font-bold">
        KI-Features vs.{" "}
        <span class="text-primary relative inline-block">
          KI-Agenten
          <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 8" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path id="avf-underline-path" d="M2 6C50 2 150 2 198 6" stroke="currentColor" stroke-width="3" stroke-linecap="round" style="stroke-dasharray: 200; stroke-dashoffset: 200; transition: stroke-dashoffset 1s ease-out;" />
          </svg>
        </span>
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Andere Tools warten auf Ihren Klick. ShortSelect arbeitet, während Sie schlafen.
      </p>
    </div>

    <!-- Comparison Grid -->
    <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
      <!-- Left Card: Competitors -->
      <div id="avf-card-left" class="rounded-xl border border-border bg-card p-8 opacity-0 translate-y-12 transition-all duration-700" style="transition-delay: 150ms;">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-12 w-12 rounded-lg bg-muted flex items-center justify-center">
            <svg class="h-6 w-6 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold">KI-Features</h3>
            <p class="text-sm text-muted-foreground">Wettbewerber</p>
          </div>
        </div>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-muted-foreground mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
            </svg>
            <span class="text-muted-foreground">Manuell auslösen: Recruiter klickt "Matching starten"</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-muted-foreground mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
            </svg>
            <span class="text-muted-foreground">Nur reaktiv: Läuft erst nach Benutzeraktion</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-muted-foreground mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
            </svg>
            <span class="text-muted-foreground">Isoliert: Jedes Feature arbeitet für sich</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-muted-foreground mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
            </svg>
            <span class="text-muted-foreground">Keine Lernkurve: Statische Regeln und Filter</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-muted-foreground mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
            </svg>
            <span class="text-muted-foreground">Tageszeit-abhängig: Nur aktiv wenn jemand arbeitet</span>
          </li>
        </ul>
      </div>

      <!-- Right Card: ShortSelect AgentBurst -->
      <div id="avf-card-right" class="rounded-xl border-2 border-primary/20 bg-primary/5 p-8 opacity-0 translate-y-12 transition-all duration-700" style="transition-delay: 300ms;">
        <div class="flex items-center gap-3 mb-6">
          <div class="h-12 w-12 rounded-lg bg-primary/10 flex items-center justify-center">
            <svg class="h-6 w-6 text-primary" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 8V4H8"/>
              <rect width="16" height="12" x="4" y="8" rx="2"/>
              <path d="M2 14h2"/>
              <path d="M20 14h2"/>
              <path d="M15 13v2"/>
              <path d="M9 13v2"/>
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold">KI-Agenten</h3>
            <p class="text-sm text-primary">ShortSelect AgentBurst</p>
          </div>
        </div>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-primary mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            <span>Sie kommen morgens und die Shortlist steht</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-primary mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            <span>Über Nacht werden neue Bewerber gescreent und gerankt</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-primary mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            <span>Matching, Screening und Follow-up greifen nahtlos ineinander</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-primary mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            <span>Je mehr Sie besetzen, desto präziser werden die Vorschläge</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="h-5 w-5 text-primary mt-0.5 shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            <span>Auch am Wochenende werden Kandidaten nicht vertröstet</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var section = document.getElementById('agents-vs-features');
  if (!section) return;

  var header = document.getElementById('avf-header');
  var underline = document.getElementById('avf-underline-path');
  var cardLeft = document.getElementById('avf-card-left');
  var cardRight = document.getElementById('avf-card-right');

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        // Reveal header
        if (header) {
          header.style.opacity = '1';
          header.style.transform = 'translateY(0)';
        }
        // Draw underline
        if (underline) {
          setTimeout(function() { underline.style.strokeDashoffset = '0'; }, 300);
        }
        // Reveal cards with stagger
        if (cardLeft) {
          cardLeft.style.opacity = '1';
          cardLeft.style.transform = 'translateY(0)';
        }
        if (cardRight) {
          cardRight.style.opacity = '1';
          cardRight.style.transform = 'translateY(0)';
        }
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  observer.observe(section);
})();
</script>
