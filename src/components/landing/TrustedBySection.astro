---
// TrustedBySection - Infinite marquee of partner logos
const partners = [
  "searched GmbH",
  "AMONOVA GmbH",
  "tw.con. GmbH",
  "VeraPartners",
  "Experiton UG",
  "SalesWorx",
];

// Duplicate for seamless infinite scroll
const allPartners = [...partners, ...partners];
---

<section class="py-12 border-y bg-muted/30 overflow-hidden">
  <div class="container mx-auto px-4 mb-8">
    <p class="text-center text-sm text-muted-foreground">
      Vertrauenspartner von führenden Recruiting-Agenturen
    </p>
  </div>

  <!-- Infinite Marquee Container -->
  <div class="relative">
    <!-- Left Fade -->
    <div class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-muted/30 to-transparent z-10 pointer-events-none"></div>

    <!-- Marquee Track -->
    <div class="flex animate-marquee hover:[animation-play-state:paused]">
      {allPartners.map((partner) => (
        <div class="flex-shrink-0 flex items-center justify-center px-12 py-4 group cursor-default">
          <span class="text-xl font-semibold text-muted-foreground/50 transition-all duration-300 group-hover:text-primary group-hover:scale-110">
            {partner}
          </span>
        </div>
      ))}
    </div>

    <!-- Right Fade -->
    <div class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-muted/30 to-transparent z-10 pointer-events-none"></div>
  </div>
</section>
