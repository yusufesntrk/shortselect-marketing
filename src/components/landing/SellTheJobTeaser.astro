---
// SellTheJobTeaser - Homepage teaser for /job-selling landing page
---

<section id="sell-the-job-teaser" class="py-16 md:py-24 bg-gray-950 text-white relative overflow-hidden">
  <!-- Glow effects -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_50%,hsl(0_72%_50%/0.15),transparent_60%)]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_70%_50%,hsl(12_76%_61%/0.1),transparent_60%)]"></div>

  <!-- Fine grid pattern -->
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:24px_24px]"></div>

  <div class="container relative mx-auto px-4">
    <div id="stj-teaser-content" class="max-w-3xl mx-auto text-center space-y-6 opacity-0 translate-y-8 transition-all duration-700">
      <!-- Badge -->
      <div>
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 border border-white/20 text-sm font-medium">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          NEU
        </span>
      </div>

      <!-- Headline -->
      <h2 class="text-3xl md:text-5xl font-display font-extrabold tracking-tight">
        Die neue Ära des Recruitings hat <span class="text-primary">begonnen</span>.
      </h2>

      <!-- Subline -->
      <p class="text-lg text-white/60 max-w-xl mx-auto">
        Post & Pray ist tot. Entdecken Sie Sell the Job — die Methode, mit der Sie A-Player aktiv gewinnen statt passiv zu warten.
      </p>

      <!-- CTA -->
      <div class="pt-4">
        <a href="/job-selling" class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-white font-semibold rounded-lg text-base group relative overflow-hidden hover:shadow-lg hover:shadow-primary/25 transition-all duration-300">
          <span class="relative z-10 flex items-center gap-2">
            Sell the Job entdecken
            <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/>
              <path d="m12 5 7 7-7 7"/>
            </svg>
          </span>
          <div class="absolute inset-0 bg-gradient-to-r from-primary via-accent to-primary bg-[length:200%_100%] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </a>
      </div>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var section = document.getElementById('sell-the-job-teaser');
  if (!section) return;
  var content = document.getElementById('stj-teaser-content');
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        if (content) { content.style.opacity = '1'; content.style.transform = 'translateY(0)'; }
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.2 });
  observer.observe(section);
})();
</script>
