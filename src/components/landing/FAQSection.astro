---
// FAQSection - FAQ accordion with details/summary and JSON-LD schema
import { faqs } from '@/data/faq';

// FAQPage Schema for Google Rich Snippets
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};
---

<!-- Structured Data for FAQPage -->
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section id="faq" class="py-20 md:py-32">
  <div class="container mx-auto px-4">
    <div id="faq-header" class="text-center space-y-4 mb-16 opacity-0 translate-y-8 transition-all duration-700">
      <h2 class="text-3xl md:text-5xl font-display font-bold">
        Häufig gestellte{" "}
        <span class="text-primary">Fragen</span>
      </h2>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        Hier finden Sie Antworten auf die wichtigsten Fragen zu ShortSelect.
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-4">
      {faqs.map((faq, i) => (
        <details
          class="faq-item group border rounded-lg px-6 transition-all duration-200 hover:border-primary/30 opacity-0"
          style={`transition-delay: ${i * 50}ms;`}
        >
          <summary class="flex items-center justify-between py-4 cursor-pointer text-left font-semibold list-none [&::-webkit-details-marker]:hidden">
            <span>{faq.question}</span>
            <svg
              class="h-5 w-5 text-muted-foreground shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180"
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <div class="pb-4 text-muted-foreground">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>

    <div id="faq-footer" class="text-center mt-12 opacity-0 transition-opacity duration-700" style="transition-delay: 500ms;">
      <p class="text-muted-foreground">
        Weitere Fragen?{" "}
        <a href="mailto:hello@shortselect.com" class="text-primary hover:underline">
          Kontaktieren Sie uns
        </a>
      </p>
    </div>
  </div>
</section>

<script is:inline>
(function() {
  var section = document.getElementById('faq');
  if (!section) return;

  var header = document.getElementById('faq-header');
  var items = section.querySelectorAll('.faq-item');
  var footer = document.getElementById('faq-footer');

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        // Reveal header
        if (header) {
          header.style.opacity = '1';
          header.style.transform = 'translateY(0)';
        }

        // Reveal FAQ items with stagger (50ms each, via CSS transition-delay)
        items.forEach(function(item) {
          item.style.opacity = '1';
        });

        // Reveal footer
        if (footer) {
          footer.style.opacity = '1';
        }

        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });

  observer.observe(section);
})();
</script>
