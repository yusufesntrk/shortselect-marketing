---
const produktLinks = [
  { href: '/produkt/ats-crm', label: 'ATS & CRM' },
  { href: '/produkt/karriereseite', label: 'Karriereseite' },
  { href: '/produkt/ki-features', label: 'KI-Features' },
  { href: '/produkt/automatisierung', label: 'Automatisierung' },
  { href: '/produkt/multiposting', label: 'Multiposting' },
  { href: '/produkt/compliance', label: 'DSGVO & Compliance' },
  { href: '/preise', label: 'Preise' },
];

const loesungenLinks = [
  { href: '/fuer/personalvermittlung', label: 'Personalvermittlung' },
  { href: '/fuer/startups', label: 'Startups' },
  { href: '/fuer/enterprise', label: 'Enterprise' },
  { href: '/branchen/it-recruiting', label: 'IT-Recruiting' },
  { href: '/branchen/finance', label: 'Finance & Banking' },
  { href: '/branchen/healthcare', label: 'Healthcare' },
  { href: '/branchen/handwerk', label: 'Handwerk' },
];

const ressourcenLinks = [
  { href: '/blog', label: 'Blog' },
  { href: '/ressourcen', label: 'Ressourcen' },
  { href: '/glossar', label: 'Glossar' },
  { href: '/methode/smart-recruiting', label: 'Smart Recruiting' },
  { href: '/vergleich/beste-ats-software', label: 'ATS Vergleich' },
  { href: '/integrationen', label: 'Integrationen' },
  { href: '/demo', label: 'Demo buchen' },
];

const unternehmenLinks = [
  { href: '/ueber-uns', label: 'Über uns' },
  { href: '/kunden', label: 'Kunden' },
  { href: '/kontakt', label: 'Kontakt' },
  { href: '/sicherheit', label: 'Sicherheit' },
  { href: '/datenschutz', label: 'Datenschutz' },
  { href: '/impressum', label: 'Impressum' },
  { href: '/agb', label: 'AGB' },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-950 text-gray-300 pt-16 pb-8">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 mb-12">
      <!-- Logo Column -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="inline-block mb-4">
          <img src="/logo.svg" alt="ShortSelect" class="h-8 brightness-0 invert" />
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          KI-gestuetztes Bewerbermanagement fuer moderne Recruiting-Teams.
        </p>
        <div class="flex gap-3 mt-4">
          <a href="https://linkedin.com/company/shortselect" target="_blank" rel="noopener noreferrer" class="text-gray-400 hover:text-white transition-colors" aria-label="LinkedIn">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" /></svg>
          </a>
          <a href="mailto:hello@shortselect.com" class="text-gray-400 hover:text-white transition-colors" aria-label="E-Mail">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </a>
        </div>
      </div>

      <!-- Produkt -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Produkt</h3>
        <ul class="space-y-2.5">
          {produktLinks.map((link) => <li><a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Loesungen -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Loesungen</h3>
        <ul class="space-y-2.5">
          {loesungenLinks.map((link) => <li><a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Ressourcen -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Ressourcen</h3>
        <ul class="space-y-2.5">
          {ressourcenLinks.map((link) => <li><a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">{link.label}</a></li>)}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div>
        <h3 class="text-sm font-semibold text-white mb-4">Unternehmen</h3>
        <ul class="space-y-2.5">
          {unternehmenLinks.map((link) => <li><a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors">{link.label}</a></li>)}
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-gray-800 pt-6 text-center">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} ShortSelect. Alle Rechte vorbehalten.
      </p>
    </div>
  </div>
</footer>
