---
// Cookie-Consent-Banner fuer Marketing-Site
// DSGVO-konform: gleichberechtigte Buttons, granulare Auswahl, Re-Open ueber Footer.
// ENV-Gate: PUBLIC_COOKIE_BANNER_ENABLED muss "true" sein.
const enabled = import.meta.env.PUBLIC_COOKIE_BANNER_ENABLED === "true";
---

{enabled && (
  <div id="cookie-consent-root" hidden>
    <div
      role="dialog"
      aria-modal="false"
      aria-label="Cookie-Einstellungen"
      class="fixed inset-x-3 bottom-3 z-[60] sm:inset-x-auto sm:right-4 sm:bottom-4 sm:max-w-md"
      data-cookie-banner
    >
      <div class="rounded-lg border border-border bg-background shadow-2xl p-4 sm:p-5">
        <div class="flex items-start gap-3">
          <div class="rounded-full bg-primary/10 p-2 mt-0.5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-primary"
            >
              <path d="M12 2a10 10 0 1 0 10 10 4 4 0 0 1-5-5 4 4 0 0 1-5-5"></path>
              <path d="M8.5 8.5v.01"></path>
              <path d="M16 15.5v.01"></path>
              <path d="M12 12v.01"></path>
              <path d="M11 17v.01"></path>
              <path d="M7 14v.01"></path>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <h2 class="text-sm font-semibold">Cookie-Einstellungen</h2>
            <p class="text-xs text-muted-foreground mt-1 leading-relaxed">
              Wir nutzen ausschliesslich technisch notwendige Cookies fuer Sicherheit und Bot-Schutz.
              Optionale Kategorien aktivieren wir nur mit Ihrer Einwilligung (&sect; 25 Abs. 1 TDDDG).
            </p>
          </div>
          <button
            type="button"
            data-cookie-close
            aria-label="Schliessen"
            hidden
            class="text-muted-foreground hover:text-foreground"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
          </button>
        </div>

        <button
          type="button"
          data-cookie-toggle-details
          class="mt-3 flex items-center gap-1 text-xs font-medium text-primary hover:underline"
        >
          <span data-cookie-toggle-label>Details anpassen</span>
        </button>

        <div data-cookie-details hidden class="mt-3 border-t border-border pt-2 space-y-2">
          <label class="flex items-start justify-between gap-3 py-2 cursor-not-allowed">
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium">Notwendig</span>
                <span class="text-[10px] uppercase tracking-wide text-muted-foreground">Erforderlich</span>
              </div>
              <p class="text-xs text-muted-foreground mt-0.5">Login-Session, CSRF-Schutz, Bot-Mitigation. Ohne diese funktioniert die Plattform nicht.</p>
            </div>
            <input type="checkbox" checked disabled class="mt-1 h-4 w-4" />
          </label>
          <label class="flex items-start justify-between gap-3 py-2">
            <div class="flex-1">
              <span class="text-sm font-medium">Funktional</span>
              <p class="text-xs text-muted-foreground mt-0.5">Erinnert sich an Sprache, Timezone und Layout-Einstellungen.</p>
            </div>
            <input type="checkbox" data-cookie-toggle="functional" class="mt-1 h-4 w-4" />
          </label>
          <label class="flex items-start justify-between gap-3 py-2">
            <div class="flex-1">
              <span class="text-sm font-medium">Statistik</span>
              <p class="text-xs text-muted-foreground mt-0.5">Anonymisierte Nutzungsstatistiken zur Produktverbesserung.</p>
            </div>
            <input type="checkbox" data-cookie-toggle="analytics" class="mt-1 h-4 w-4" />
          </label>
          <label class="flex items-start justify-between gap-3 py-2">
            <div class="flex-1">
              <span class="text-sm font-medium">Marketing</span>
              <p class="text-xs text-muted-foreground mt-0.5">Personalisierte Inhalte und Conversion-Tracking auf externen Plattformen.</p>
            </div>
            <input type="checkbox" data-cookie-toggle="marketing" class="mt-1 h-4 w-4" />
          </label>
        </div>

        <div class="mt-4 flex flex-col-reverse sm:flex-row sm:items-center gap-2">
          <button
            type="button"
            data-cookie-reject
            class="flex-1 inline-flex items-center justify-center rounded-md border border-input bg-background px-3 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground"
          >
            Alle ablehnen
          </button>
          <button
            type="button"
            data-cookie-accept
            class="flex-1 inline-flex items-center justify-center rounded-md bg-primary px-3 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90"
          >
            <span data-cookie-accept-label>Alle akzeptieren</span>
          </button>
        </div>

        <p class="mt-3 text-[10px] text-muted-foreground/80 text-center">
          <a href="/datenschutz" class="hover:underline">Datenschutz</a>
          {' '}&middot;{' '}
          <a href="/impressum" class="hover:underline">Impressum</a>
        </p>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      var STORAGE_KEY = "shortselect_cookie_consent";
      var CONSENT_VERSION = "v2026-05-07";
      var root = document.getElementById("cookie-consent-root");
      if (!root) return;
      var banner = root.querySelector("[data-cookie-banner]");
      var details = root.querySelector("[data-cookie-details]");
      var toggleBtn = root.querySelector("[data-cookie-toggle-details]");
      var toggleLabel = root.querySelector("[data-cookie-toggle-label]");
      var closeBtn = root.querySelector("[data-cookie-close]");
      var acceptBtn = root.querySelector("[data-cookie-accept]");
      var acceptLabel = root.querySelector("[data-cookie-accept-label]");
      var rejectBtn = root.querySelector("[data-cookie-reject]");
      var togglesByKey = {
        functional: root.querySelector('[data-cookie-toggle="functional"]'),
        analytics: root.querySelector('[data-cookie-toggle="analytics"]'),
        marketing: root.querySelector('[data-cookie-toggle="marketing"]')
      };
      var detailsExpanded = false;
      var forcedOpen = false;

      function readConsent() {
        try {
          var raw = window.localStorage.getItem(STORAGE_KEY);
          if (!raw) return null;
          var parsed = JSON.parse(raw);
          if (parsed.version !== CONSENT_VERSION) return null;
          if (parsed.necessary !== true) return null;
          return parsed;
        } catch (e) {
          return null;
        }
      }

      function writeConsent(state) {
        var full = {
          necessary: true,
          functional: !!state.functional,
          analytics: !!state.analytics,
          marketing: !!state.marketing,
          timestamp: new Date().toISOString(),
          version: CONSENT_VERSION
        };
        window.localStorage.setItem(STORAGE_KEY, JSON.stringify(full));
        window.dispatchEvent(new CustomEvent("cookie-consent-changed", { detail: full }));
      }

      function showBanner() {
        root.hidden = false;
      }

      function hideBanner() {
        root.hidden = true;
        forcedOpen = false;
        if (closeBtn) closeBtn.hidden = true;
      }

      function setDetails(open) {
        detailsExpanded = open;
        if (details) details.hidden = !open;
        if (toggleLabel) toggleLabel.textContent = open ? "Details ausblenden" : "Details anpassen";
        if (acceptLabel) acceptLabel.textContent = open ? "Auswahl speichern" : "Alle akzeptieren";
      }

      function getDraftFromToggles() {
        return {
          functional: !!(togglesByKey.functional && togglesByKey.functional.checked),
          analytics: !!(togglesByKey.analytics && togglesByKey.analytics.checked),
          marketing: !!(togglesByKey.marketing && togglesByKey.marketing.checked)
        };
      }

      if (toggleBtn) toggleBtn.addEventListener("click", function () { setDetails(!detailsExpanded); });
      if (closeBtn) closeBtn.addEventListener("click", hideBanner);
      if (acceptBtn) {
        acceptBtn.addEventListener("click", function () {
          if (detailsExpanded) {
            writeConsent(getDraftFromToggles());
          } else {
            writeConsent({ functional: true, analytics: true, marketing: true });
          }
          hideBanner();
        });
      }
      if (rejectBtn) {
        rejectBtn.addEventListener("click", function () {
          writeConsent({ functional: false, analytics: false, marketing: false });
          hideBanner();
        });
      }

      window.addEventListener("cookie-consent-reopen", function () {
        forcedOpen = true;
        if (closeBtn) closeBtn.hidden = false;
        setDetails(true);
        showBanner();
      });

      // Initialer Render: nur zeigen wenn noch keine Wahl getroffen wurde
      var existing = readConsent();
      if (!existing) {
        showBanner();
      }
    })();
  </script>
)}
