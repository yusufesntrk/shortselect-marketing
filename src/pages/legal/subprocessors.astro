---
import MarketingLayout from '../../layouts/MarketingLayout.astro';

// Unterauftragsverarbeiter (Sub-Prozessoren) von ShortSelect.
// Diese Liste spiegelt die in der Datenschutzerklärung (Abschnitt 6) genannten
// Auftragsverarbeiter wider. Keine erfundenen Anbieter, nur real eingesetzte Dienste.
const subprocessors = [
  { name: "Supabase Inc.", purpose: "Datenbank, Authentifizierung, Storage, Edge Functions", region: "EU (Frankfurt)", privacy: "https://supabase.com/privacy" },
  { name: "Hetzner Online GmbH", purpose: "Server für PDF-Generierung, Workflow-Automation, WebRTC, Bot-Orchestrierung", region: "Deutschland (Falkenstein)", privacy: "https://www.hetzner.com/rechtliches/datenschutz" },
  { name: "Cloudflare Inc.", purpose: "Hosting Marketing-Site und App-Frontend, CDN, Bot-Schutz", region: "USA / global (DPF + SCC)", privacy: "https://www.cloudflare.com/privacypolicy/" },
  { name: "Resend (Ra Resende Inc.)", purpose: "Transaktionale E-Mails (Login-Bestätigung, Einladungen, Rechnungen)", region: "USA (DPF + SCC)", privacy: "https://resend.com/legal/privacy-policy" },
  { name: "Stripe Payments Europe Ltd. / Stripe Inc.", purpose: "Zahlungsabwicklung, Subscription-Management, Rechnungsstellung, Steuer-Berechnung, Customer Portal", region: "Irland / USA (DPF + SCC)", privacy: "https://stripe.com/privacy" },
  { name: "Anthropic PBC", purpose: "KI-Verarbeitung: Lebenslauf-Analyse, Matching, Screening, AI-Interview", region: "USA (DPF + SCC)", privacy: "https://www.anthropic.com/legal/privacy" },
  { name: "OpenAI", purpose: "KI-Sprachmodelle", region: "USA (DPF + SCC)", privacy: "https://openai.com/policies/privacy-policy/" },
  { name: "Deepgram Inc.", purpose: "Speech-to-Text beim AI-Interview", region: "USA (SCC + TIA)", privacy: "https://deepgram.com/privacy" },
  { name: "ElevenLabs Inc.", purpose: "Text-to-Speech beim AI-Interview", region: "USA (DPF + SCC)", privacy: "https://elevenlabs.io/privacy-policy" },
  { name: "Google LLC", purpose: "Calendar- und Gmail-OAuth-Integration auf Wunsch des Kunden", region: "USA / Irland (DPF + SCC)", privacy: "https://policies.google.com/privacy" },
  { name: "Microsoft Corp.", purpose: "Outlook-OAuth-Integration auf Wunsch des Kunden", region: "USA / Irland (DPF + SCC)", privacy: "https://privacy.microsoft.com/privacystatement" },
  { name: "Zoom Video Communications", purpose: "Video-Termin-Integration auf Wunsch des Kunden", region: "USA (DPF + SCC)", privacy: "https://www.zoom.com/en/trust/privacy/" },
  { name: "LinkedIn Corp.", purpose: "Provider-API für Sourcing-Funktionen", region: "USA / Irland (DPF über Microsoft + SCC)", privacy: "https://www.linkedin.com/legal/privacy-policy" },
  { name: "Meta Platforms Ireland Ltd.", purpose: "Lead-Ads, Marketing-API auf Wunsch des Kunden", region: "Irland / USA (DPF + SCC)", privacy: "https://www.facebook.com/privacy/policy/" },
  { name: "Indeed", purpose: "Apply-Integration auf Wunsch des Kunden", region: "USA (SCC + TIA)", privacy: "https://www.indeed.com/legal/privacy" },
  { name: "Stepstone", purpose: "Push und Quality-Signals", region: "Deutschland", privacy: "https://www.stepstone.de/ueber-stepstone/datenschutz/" },
  { name: "Whapi (WhatsApp-Provider)", purpose: "WhatsApp-Chat-Integration auf Wunsch des Kunden", region: "Israel / USA (SCC)", privacy: "https://whapi.cloud/" },
];
---

<MarketingLayout
  title="Unterauftragsverarbeiter | ShortSelect"
  description="Liste der Unterauftragsverarbeiter (Sub-Prozessoren), die ShortSelect zur Bereitstellung der Plattform einsetzt, mit Zweck, Verarbeitungsregion und Datenschutz-Link."
  noindex={true}
>
  <section class="pt-32 pb-20 md:pb-28">
    <div class="container mx-auto px-4 max-w-4xl">
      <nav class="flex items-center gap-1.5 text-sm text-muted-foreground mb-6">
        <a href="/datenschutz/" class="hover:text-foreground transition-colors">Datenschutz</a>
        <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-[hsl(var(--primary))]">Unterauftragsverarbeiter</span>
      </nav>

      <h1 class="text-3xl font-display font-bold mb-2">Unterauftragsverarbeiter</h1>
      <p class="text-sm text-muted-foreground mb-8">Stand: 12. Juli 2026</p>

      <div class="prose-legal space-y-6">
        <p>
          Für den Betrieb von ShortSelect setzen wir sorgfältig ausgewählte Dienstleister als Unterauftragsverarbeiter (Sub-Prozessoren) im Sinne von Art. 28 DSGVO ein. Mit allen hier genannten Anbietern bestehen Verträge zur Auftragsverarbeitung. Bei Übermittlungen in Drittländer stützen wir uns auf das EU-US Data Privacy Framework (DPF), auf EU-Standardvertragsklauseln (SCC) sowie, wo erforderlich, auf ein Transfer Impact Assessment (TIA).
        </p>
        <p>
          Diese Übersicht ergänzt Abschnitt 6 unserer <a href="/datenschutz/" class="text-[hsl(var(--primary))] hover:underline">Datenschutzerklärung</a>. Nicht jeder Dienst wird für jeden Kunden aktiv; Integrationen wie Kalender, E-Mail, Video oder WhatsApp werden nur auf ausdrücklichen Wunsch des jeweiligen Kunden verbunden.
        </p>

        <div class="overflow-x-auto">
          <table class="w-full text-sm border border-muted-foreground/20">
            <thead class="bg-muted/40">
              <tr>
                <th class="text-left p-2 border-b border-muted-foreground/20">Anbieter</th>
                <th class="text-left p-2 border-b border-muted-foreground/20">Zweck</th>
                <th class="text-left p-2 border-b border-muted-foreground/20">Ort/Region der Verarbeitung</th>
                <th class="text-left p-2 border-b border-muted-foreground/20">Datenschutz</th>
              </tr>
            </thead>
            <tbody>
              {subprocessors.map((sub) => (
                <tr>
                  <td class="p-2 border-b border-muted-foreground/10 align-top font-medium">{sub.name}</td>
                  <td class="p-2 border-b border-muted-foreground/10 align-top">{sub.purpose}</td>
                  <td class="p-2 border-b border-muted-foreground/10 align-top">{sub.region}</td>
                  <td class="p-2 border-b border-muted-foreground/10 align-top">
                    <a href={sub.privacy} target="_blank" rel="noopener" class="text-[hsl(var(--primary))] hover:underline">Datenschutz</a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p>
          Wir aktualisieren diese Liste, wenn wir einen neuen Unterauftragsverarbeiter hinzufügen oder einen bestehenden ersetzen. Bei wesentlichen Änderungen informieren wir betroffene Kunden im Rahmen des Auftragsverarbeitungsvertrags. Fragen zur Auftragsverarbeitung richten Sie bitte an <a href="mailto:hello@shortselect.com" class="text-[hsl(var(--primary))] hover:underline">hello@shortselect.com</a>.
        </p>
      </div>
    </div>
  </section>
</MarketingLayout>
