---
import LoesungLayout from '../../layouts/LoesungLayout.astro';

const painPoints = [
  { title: "Mandanten-Chaos", description: "Verschiedene Excel-Tabellen pro Kunde. Kein einheitliches System, keine Struktur. Sie verlieren den Überblick, bevor der Tag richtig anfängt.", iconPath: '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>' },
  { title: "Keine Übersicht", description: "Wer hat welchen Kandidaten wo platziert? Ohne zentrale Datenbank müssen Sie sich durch E-Mails, Tabellen und Notizen kämpfen.", iconPath: '<path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/>' },
  { title: "Zeitfresser", description: "Manuelle Reports für jeden Kunden. Stundenlange Zusammenfassung am Monatsende statt produktives Recruiting.", iconPath: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
];

const solutions = [
  { title: "Multi-Tenancy", subtitle: "Ein System. Alle Mandanten. Klare Trennung.", description: "Verwalten Sie alle Kunden in einem einzigen System mit strikter Datentrennung auf Datenbankebene. Jeder Mandant sieht nur seine eigenen Daten.", iconPath: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m6.08 9.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/><path d="m6.08 14.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/>' },
  { title: "Client Portal", subtitle: "Ihre Kunden sehen Shortlists in Echtzeit.", description: "Geben Sie Ihren Kunden ein eigenes Portal, in dem sie Kandidatenprofile einsehen, Feedback geben und den Recruiting-Fortschritt live verfolgen können.", iconPath: '<rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/>' },
  { title: "Pipeline pro Job", subtitle: "Individuelle Recruiting-Pipelines für jeden Auftrag.", description: "Erstellen Sie maßgeschneiderte Pipelines mit Drag & Drop. Von der Erstansprache bis zum Placement - alles in einem übersichtlichen Kanban-Board.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { title: "Automatische Reports", subtitle: "KPIs auf Knopfdruck - pro Mandant.", description: "Time-to-Hire, Cost-per-Hire, Pipeline-Velocity und mehr. Generieren Sie professionelle Reports in Sekunden statt Stunden.", iconPath: '<line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/>' },
  { title: "KI-Matching & Screening", subtitle: "Die KI findet den besten Kandidaten für jeden Auftrag.", description: "Automatisches CV-Parsing, intelligentes Matching und anonymisierte Shortlists -- DSGVO-konform.", iconPath: '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/>' },
];
---

<LoesungLayout
  title="ShortSelect für Personalvermittlung | Multi-Mandanten ATS"
  description="Multi-Mandanten ATS mit KI-Matching für Personalvermittler. Client Portal, Pipeline pro Job, automatische Reports. Jetzt kostenlos testen."
  badgeText="Für Agenturen gebaut"
  badgeIcon='<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/>'
  headline="Die Software, die mit"
  highlightedWord="Ihrer Agentur"
  headlineSuffix="wächst."
  subline="Multi-Mandanten ATS mit KI-gestütztem Matching für Personalvermittler, die mehr erreichen wollen. Verwalten Sie alle Kunden, Kandidaten und Pipelines an einem Ort."
  painTitle="Kommt Ihnen das"
  painHighlight="bekannt"
  painSubline="Als Personalvermittler jonglieren Sie täglich zwischen Mandanten, Kandidaten und Deadlines. Ohne das richtige System wird das schnell zum Albtraum."
  painPoints={painPoints}
  solutionBadge="Die Lösung"
  solutionTitle="Alles, was Ihre Agentur braucht."
  solutionHighlight="In einem System."
  solutions={solutions}
  secondaryCta="Demo vereinbaren"
  secondaryCtaHref="https://app.shortselect.com/signup"
>
  <!-- TESTIMONIAL -->
  <section id="pv-testimonial" class="py-20 md:py-28">
    <div class="container mx-auto px-4">
      <div id="pv-testimonial-content" class="max-w-3xl mx-auto text-center opacity-0 translate-y-8 transition-all duration-700">
        <svg class="h-12 w-12 text-primary/20 mx-auto mb-6" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V21c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c0 2.25.25 4-2.75 4v3c0 1 0 1 1 1z"/></svg>
        <blockquote class="text-2xl md:text-3xl font-display font-bold tracking-tight leading-snug mb-8">
          &ldquo;ShortSelect hat unsere Agentur auf ein neues Level gebracht. Endlich haben wir alle Mandanten, Kandidaten und Pipelines an einem Ort.&rdquo;
        </blockquote>
        <div class="flex items-center justify-center gap-4">
          <div class="w-14 h-14 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="text-primary font-bold text-lg">YS</span>
          </div>
          <div class="text-left">
            <div class="font-semibold">Yasar Sentuerk</div>
            <div class="text-sm text-[hsl(var(--muted-foreground))]">Geschäftsführer, searched GmbH</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING TEASER -->
  <section id="pv-pricing" class="py-20 md:py-28 bg-[hsl(var(--muted)/0.3)]">
    <div class="container mx-auto px-4">
      <div id="pv-pricing-content" class="max-w-2xl mx-auto text-center space-y-6 opacity-0 translate-y-8 transition-all duration-700">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold border border-primary/20 text-primary">Preise</span>
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-display font-bold tracking-tight">
          Ab <span class="text-primary">0 EUR/Monat</span> starten
        </h2>
        <p class="text-lg text-[hsl(var(--muted-foreground))]">
          Keine Kreditkarte erforderlich. Keine versteckten Kosten. Starten Sie kostenlos und upgraden Sie, wenn Sie bereit sind.
        </p>
        <div class="pt-4">
          <a href="/preise" class="inline-flex items-center gap-2 px-8 py-3 border border-[hsl(var(--border))] font-semibold rounded-lg text-base transition-all duration-300 hover:border-primary/50 hover:text-primary group">
            Alle Preise ansehen
            <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
<script is:inline>
(function() {
  var sections = [
    { sectionId: 'pv-testimonial', contentId: 'pv-testimonial-content' },
    { sectionId: 'pv-pricing', contentId: 'pv-pricing-content' }
  ];
  sections.forEach(function(s) {
    var section = document.getElementById(s.sectionId);
    var content = document.getElementById(s.contentId);
    if (!section || !content) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          content.style.opacity = '1';
          content.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    observer.observe(section);
  });
})();
</script>
</LoesungLayout>
