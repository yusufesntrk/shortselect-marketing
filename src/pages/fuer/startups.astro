---
import LoesungLayout from '../../layouts/LoesungLayout.astro';

const painPoints = [
  { title: "Kein Prozess", description: "Erste Stelle ueber LinkedIn posten. Bewerbungen kommen per E-Mail. Schnell herrscht Chaos.", iconPath: '<circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>' },
  { title: "Kandidaten gehen verloren", description: "5 offene Stellen. Wer hat wem geschrieben? Der beste Kandidat geht verloren, weil niemand nachgefasst hat.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" x2="22" y1="11" y2="11"/>' },
  { title: "Keine Struktur", description: "Excel, E-Mail, Notion, alles verteilt. Kein einheitliches System von Anfang an.", iconPath: '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>' },
];

const solutions = [
  { title: "Kostenlos starten", subtitle: "Kein Budget? Kein Problem.", description: "Starten Sie mit dem Free-Plan und zahlen Sie erst, wenn Sie wachsen. Professionelles Recruiting von Tag 1.", iconPath: '<path d="M20 12V8H6a2 2 0 0 1-2-2c0-1.1.9-2 2-2h12v4"/><path d="M4 6v12c0 1.1.9 2 2 2h14v-4"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>' },
  { title: "Karriereseite in 5 Minuten", subtitle: "Professionell aussehen, ohne Designer.", description: "Erstellen Sie eine gebrandete Karriereseite in Minuten. Kein Designer, kein Entwickler nötig.", iconPath: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>' },
  { title: "Drag & Drop Pipeline", subtitle: "So einfach wie Trello, aber für Recruiting.", description: "Verschieben Sie Kandidaten durch Ihre Pipeline mit intuitivem Drag & Drop. Visuell, übersichtlich, effizient.", iconPath: '<circle cx="9" cy="12" r="1"/><circle cx="9" cy="5" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="19" r="1"/>' },
  { title: "Wachsen ohne Limits", subtitle: "Von 1 bis 100 Mitarbeiter.", description: "Upgraden, wenn Sie bereit sind. ShortSelect waechst mit Ihrem Startup, ohne Systemwechsel.", iconPath: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>' },
];
---

<LoesungLayout
  title="ShortSelect für Startups | ATS das mitwaechst"
  description="Das ATS für Startups: Kostenlos starten, Karriereseite in 5 Minuten, Drag & Drop Pipeline. Von der ersten Stelle bis zum 100. Mitarbeiter."
  badgeText="Kostenlos starten"
  badgeIcon='<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>'
  headline="Starten Sie smart."
  highlightedWord="Skalieren"
  headlineSuffix="Sie spaeter."
  subline="Das ATS, das mit Ihrem Startup waechst, von der ersten Stelle bis zum 100. Mitarbeiter. Professionelles Recruiting von Tag 1 an."
  primaryCta="Jetzt kostenlos starten"
  secondaryCta="Features entdecken"
  painTitle="Warum Startups ein"
  painHighlight="ATS"
  painSubline=""
  painPoints={painPoints}
  solutionBadge=""
  solutionTitle="Gebaut für"
  solutionHighlight="Startups"
  solutions={solutions}
/>
