  .stj-spark.s1 { top: 20%; left: 12%; animation: sparkFloat 4s ease-in-out infinite; }
  .stj-spark.s2 { top: 78%; right: 16%; animation: sparkFloat 5s ease-in-out infinite 1s; }
  .stj-spark.s3 { top: 32%; right: 8%; animation: sparkFloat 4.5s ease-in-out infinite 0.5s; }
  .stj-spark.s4 { bottom: 24%; left: 14%; animation: sparkFloat 5.5s ease-in-out infinite 2s; }
  @keyframes sparkFloat {
    0%, 100% { opacity: 0.4; transform: translate(0, 0) scale(1); }
