    margin-left: 8px;
  }
  .fc-footer .bottom a:hover { color: rgba(255,255,255,0.8); }

  /* ============ AGENTBURST SOURCING SHOWCASE ============ */
  .fc-abs { padding: 100px 0; background: white; position: relative; overflow: hidden; }
  .fc-abs::before {
    content: ''; position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 1000px 500px at 50% 0%, rgba(239,68,68,0.05), transparent 60%),
      radial-gradient(ellipse 800px 400px at 50% 100%, rgba(239,68,68,0.04), transparent 60%);
    pointer-events: none;
  }
  .fc-abs > * { position: relative; z-index: 1; }
  .abs-head { max-width: 760px; margin: 0 auto 48px; text-align: center; padding: 0 32px; }
  .abs-head h2 { margin-top: 18px; font-size: 46px; line-height: 1.02; }
  .abs-head h2 .accent { color: #ef4444; position: relative; display: inline-block; }
  .abs-head h2 .accent::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: 4px;
    height: 12px; background: rgba(239,68,68,0.13); z-index: -1; border-radius: 4px;
  }
  .abs-head .lead { margin: 18px auto 0; font-size: 17px; color: #525252; line-height: 1.55; max-width: 620px; }

  .abs-stage { max-width: 1100px; margin: 0 auto; padding: 0 32px; }

  /* Platform bar — z-index above hero card so spawn animation doesn't bleed through */
  .abs-plat-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 28px; position: relative; z-index: 10; }
  .abs-plat {
    background: white; border: 1px solid #e5e5e5; border-radius: 14px; padding: 12px 14px;
    display: flex; align-items: center; gap: 11px;
    box-shadow: 0 10px 24px -16px rgba(0,0,0,0.15);
    position: relative; transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .abs-plat-logo {
    width: 36px; height: 36px; border-radius: 9px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .abs-plat-logo svg { width: 22px; height: 22px; display: block; }
  .abs-plat-logo-stepstone { background: transparent !important; padding: 0; }
  .abs-plat-logo-stepstone svg { width: 36px; height: 36px; border-radius: 9px; }
  .abs-plat-meta { flex: 1; min-width: 0; }
  .abs-plat-name { font-family: 'Poppins'; font-weight: 800; font-size: 12.5px; letter-spacing: -0.01em; }
  .abs-plat-status {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 8.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    display: flex; align-items: center; gap: 4px; margin-top: 2px;
  }
  .abs-plat-status.live { color: #16a34a; }
  .abs-plat-status.soon { color: #d97706; }
  .abs-plat-status .led {
    width: 6px; height: 6px; border-radius: 50%; background: currentColor;
    animation: abs-pulse 1.4s ease-in-out infinite;
  }
  @keyframes abs-pulse { 0%, 100% { opacity: 0.4; transform: scale(0.85); } 50% { opacity: 1; transform: scale(1.15); } }

  .abs-plat.active {
    border-color: #ef4444;
    box-shadow:
      0 0 0 4px rgba(239,68,68,0.1),
      0 20px 50px -10px rgba(239,68,68,0.35),
      inset 0 0 30px rgba(239,68,68,0.04);
    transform: translateY(-4px);
  }
  .abs-plat.active .abs-plat-logo { transform: scale(1.15) rotate(-4deg); }
  .abs-plat.active::after {
    content: 'Profil gefunden';
    position: absolute; top: -10px; right: 12px;
    background: #ef4444; color: white;
    font-size: 9px; font-weight: 800; padding: 4px 8px; border-radius: 100px;
    letter-spacing: 0.04em; text-transform: uppercase;
    box-shadow: 0 6px 16px rgba(239,68,68,0.4);
    animation: abs-toast-pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes abs-toast-pop { 0% { opacity: 0; transform: translateY(8px) scale(0.6); } 100% { opacity: 1; transform: translateY(0) scale(1); } }

  /* Main row */
  .abs-main-row {
    display: grid; grid-template-columns: 1fr 320px; gap: 24px; align-items: stretch;
  }
  .abs-arena { position: relative; min-height: 420px; perspective: 1400px; }

  /* Hero card */
  .abs-hero-card {
    position: absolute; top: 50%; left: 50%;
    width: 340px; margin-top: -190px; margin-left: -170px;
    background: white; border-radius: 16px; padding: 18px;
    box-shadow: 0 24px 56px -16px rgba(0,0,0,0.22), 0 0 0 1px rgba(0,0,0,0.04);
    opacity: 0; z-index: 4; transform-style: preserve-3d;
    --spawn-dx: 0px; --spawn-dy: 0px;
    --file-dx: 300px; --file-dy: 0px;
  }
  .abs-hero-card.spawning { animation: abs-spawn 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
  @keyframes abs-spawn {
    0% { transform: translate(var(--spawn-dx), var(--spawn-dy)) scale(0.4) rotate(-8deg); opacity: 0; }
    30% { opacity: 1; }
    100% { transform: translate(0, 0) scale(1) rotate(0deg); opacity: 1; }
  }
  .abs-hero-card.idle { opacity: 1; transform: translate(0, 0) scale(1); }
  .abs-hero-card.filing { animation: abs-file-away 0.9s cubic-bezier(0.7, 0.05, 0.35, 1) forwards; }
  @keyframes abs-file-away {
    0% { transform: translate(0, 0) scale(1) rotate(0); opacity: 1; }
    40% { transform: translate(calc(var(--file-dx) * 0.4), calc(var(--file-dy) * 0.4 - 20px)) scale(0.85) rotate(6deg); opacity: 1; }
    100% { transform: translate(var(--file-dx), var(--file-dy)) scale(0.18) rotate(2deg); opacity: 0; }
  }
  .abs-hero-card.rejecting { animation: abs-reject-drop 0.9s cubic-bezier(0.55, 0, 0.85, 0.5) forwards; }
  @keyframes abs-reject-drop {
    0% { transform: translate(0, 0) rotate(0); opacity: 1; }
    100% { transform: translate(20px, 260px) rotate(22deg) scale(0.5); opacity: 0; }
  }

  /* Reject X */
  .abs-reject-x { position: absolute; inset: -8px; pointer-events: none; opacity: 0; z-index: 6; }
  .abs-reject-x svg { width: 100%; height: 100%; overflow: visible; }
  .abs-reject-x line {
    stroke: #ef4444; stroke-width: 5; stroke-linecap: round;
    stroke-dasharray: 400; stroke-dashoffset: 400;
    filter: drop-shadow(0 0 10px rgba(239,68,68,0.6));
  }
  .abs-hero-card.strike .abs-reject-x { opacity: 1; }
  .abs-hero-card.strike .abs-reject-x line { animation: abs-strike 0.45s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
  .abs-hero-card.strike .abs-reject-x line:nth-child(2) { animation-delay: 0.18s; }
  @keyframes abs-strike { to { stroke-dashoffset: 0; } }
  .abs-hero-card.strike .abs-hc-name,
  .abs-hero-card.strike .abs-crit-label {
    text-decoration: line-through; text-decoration-color: #ef4444; text-decoration-thickness: 2px;
  }
  .abs-hero-card.strike { background: rgba(239, 68, 68, 0.03); }

  /* Scan beam */
  .abs-scan-beam {
    position: absolute; left: 8px; right: 8px; height: 3px;
    background: linear-gradient(90deg, transparent, #ef4444 30%, #ef4444 70%, transparent);
    box-shadow: 0 0 24px #ef4444, 0 0 8px #ef4444;
    border-radius: 2px; top: 0; opacity: 0; pointer-events: none;
  }
  .abs-hero-card.scanning .abs-scan-beam { animation: abs-beam 1.8s cubic-bezier(0.5, 0, 0.5, 1) 0.1s; }
  @keyframes abs-beam {
    0% { opacity: 0; top: 0; } 10% { opacity: 1; }
    90% { opacity: 1; top: calc(100% - 3px); } 100% { opacity: 0; top: calc(100% - 3px); }
  }

  /* Identity */
  .abs-hc-id { display: flex; align-items: center; gap: 14px; padding-bottom: 16px; border-bottom: 1px solid #f4f4f5; margin-bottom: 14px; }
  .abs-hc-av {
    width: 52px; height: 52px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: white; font-family: 'Poppins'; font-weight: 800; font-size: 17px;
    flex-shrink: 0; box-shadow: 0 6px 18px rgba(0,0,0,0.18);
  }
  .abs-hc-info { flex: 1; min-width: 0; }
  .abs-hc-name { font-family: 'Poppins'; font-weight: 800; font-size: 18px; line-height: 1.1; }
  .abs-hc-role { font-size: 12px; color: #525252; margin-top: 4px; display: flex; align-items: center; gap: 8px; }
  .abs-hc-src {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 9px; font-weight: 700; padding: 3px 7px; border-radius: 5px;
    color: white; letter-spacing: 0.04em;
  }
  .abs-hc-id-num { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 10px; color: #71717a; }

  /* Criteria */
  .abs-crit-list { display: flex; flex-direction: column; gap: 9px; }
  .abs-crit {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 12px; background: #fafafa; border-radius: 10px;
    border: 1px solid #f4f4f5;
    opacity: 0; transform: translateX(20px) scale(0.92);
  }
  .abs-crit.show { animation: abs-crit-in 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
  @keyframes abs-crit-in {
    0% { opacity: 0; transform: translateX(20px) scale(0.92); }
    60% { transform: translateX(-2px) scale(1.04); }
    100% { opacity: 1; transform: translateX(0) scale(1); }
  }
  .abs-crit-icon {
    width: 22px; height: 22px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: #e5e5e5; color: white; font-size: 11px; font-weight: 800; flex-shrink: 0;
  }
  .abs-crit.pass .abs-crit-icon { background: #16a34a; box-shadow: 0 0 12px rgba(22,163,74,0.4); }
  .abs-crit.fail .abs-crit-icon { background: #ef4444; box-shadow: 0 0 12px rgba(239,68,68,0.4); }
  .abs-crit-label { flex: 1; font-size: 12.5px; font-weight: 700; color: #0a0a0e; }
  .abs-crit-val { font-family: ui-monospace, 'SF Mono', Menlo, monospace; font-size: 11px; font-weight: 700; color: #525252; }
  .abs-crit.pass .abs-crit-val { color: #16a34a; }
  .abs-crit.fail .abs-crit-val { color: #ef4444; }

  /* Score stamp */
  .abs-score-stamp {
    position: absolute; top: -22px; right: -22px;
    width: 86px; height: 86px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center; flex-direction: column;
    color: white; font-family: 'Poppins'; font-weight: 800;
    opacity: 0; z-index: 5;
    box-shadow: 0 14px 40px -8px rgba(0,0,0,0.3);
    transform: scale(3) rotate(25deg);
  }
  .abs-score-stamp.match { background: linear-gradient(135deg, #22c55e, #16a34a); }
  .abs-score-stamp.miss { background: linear-gradient(135deg, #ef4444, #b91c1c); }
  .abs-score-stamp .num { font-size: 28px; line-height: 1; }
  .abs-score-stamp .lbl { font-size: 9px; font-weight: 800; letter-spacing: 0.1em; margin-top: 2px; text-transform: uppercase; }
  .abs-hero-card.scored .abs-score-stamp { animation: abs-stamp 0.6s cubic-bezier(0.5, -0.2, 0.6, 1.5) forwards; }
  @keyframes abs-stamp {
    0% { opacity: 0; transform: scale(3) rotate(25deg); }
    55% { opacity: 1; transform: scale(0.85) rotate(-14deg); }
    75% { transform: scale(1.12) rotate(-6deg); }
    100% { opacity: 1; transform: scale(1) rotate(-9deg); }
  }
  .abs-score-stamp::before {
    content: ''; position: absolute; inset: -8px; border-radius: 50%;
    border: 2px dashed rgba(255,255,255,0.4);
    animation: abs-ring 2s linear infinite;
  }
  @keyframes abs-ring { from { transform: rotate(0); } to { transform: rotate(360deg); } }

  /* Confetti */
  .abs-confetti { position: absolute; top: -10px; right: -10px; width: 120px; height: 120px; pointer-events: none; opacity: 0; }
  .abs-hero-card.scored.match-card .abs-confetti { animation: abs-confetti 0.8s ease-out 0.2s; }
  @keyframes abs-confetti {
    0% { opacity: 0; transform: scale(0.3); } 40% { opacity: 1; } 100% { opacity: 0; transform: scale(1.8); }
  }
  .abs-confetti i { position: absolute; width: 6px; height: 6px; border-radius: 2px; top: 50%; left: 50%; transform-origin: center; }
  .abs-confetti i:nth-child(1) { background: #22c55e; transform: rotate(0) translateY(-20px); }
  .abs-confetti i:nth-child(2) { background: #ef4444; transform: rotate(45deg) translateY(-20px); }
  .abs-confetti i:nth-child(3) { background: #facc15; transform: rotate(90deg) translateY(-20px); }
  .abs-confetti i:nth-child(4) { background: #3b82f6; transform: rotate(135deg) translateY(-20px); }
  .abs-confetti i:nth-child(5) { background: #ec4899; transform: rotate(180deg) translateY(-20px); }
  .abs-confetti i:nth-child(6) { background: #22c55e; transform: rotate(225deg) translateY(-20px); }
  .abs-confetti i:nth-child(7) { background: #f97316; transform: rotate(270deg) translateY(-20px); }
  .abs-confetti i:nth-child(8) { background: #8b5cf6; transform: rotate(315deg) translateY(-20px); }

  /* Pipeline (Sourcing Pool) */
  .abs-pipeline {
    background: white; border: 1px solid #e5e5e5; border-radius: 18px; padding: 18px;
    box-shadow: 0 16px 48px -22px rgba(0,0,0,0.15);
    display: flex; flex-direction: column; gap: 14px; position: relative; z-index: 2;
  }
  .abs-pipe-head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 12px; border-bottom: 1px solid #e5e5e5; }
  .abs-pipe-title { font-family: 'Poppins'; font-weight: 800; font-size: 14px; }
  .abs-pipe-live {
    display: flex; align-items: center; gap: 6px;
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 10px; font-weight: 700; color: #16a34a;
    letter-spacing: 0.08em; text-transform: uppercase;
  }
  .abs-pipe-live .led { width: 7px; height: 7px; border-radius: 50%; background: #16a34a; animation: abs-pulse 1.4s ease-in-out infinite; box-shadow: 0 0 8px #16a34a; }
  .abs-pool-cards { display: flex; flex-direction: column; gap: 10px; flex: 1; padding: 4px 0; }
  .abs-pipe-card {
    background: #fafafa; border: 1px solid #e5e5e5; border-radius: 12px; padding: 11px 12px;
    display: flex; align-items: center; gap: 10px;
    box-shadow: 0 4px 12px -4px rgba(0,0,0,0.06);
  }
  .abs-pipe-card.land { animation: abs-pcard-land 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
  @keyframes abs-pcard-land {
    0% { opacity: 0; transform: scale(0.6) translateY(-6px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
  }
  .abs-pipe-card.exit { animation: abs-pcard-exit 0.55s cubic-bezier(0.55, 0, 0.85, 0.5) forwards; }
  @keyframes abs-pcard-exit {
    0% { opacity: 1; transform: translateX(0) scale(1); }
    100% { opacity: 0; transform: translateX(40px) scale(0.9); }
  }
  .abs-pc-av {
    width: 34px; height: 34px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: white; font-weight: 800; font-size: 12px; flex-shrink: 0;
  }
  .abs-pc-meta { flex: 1; min-width: 0; }
  .abs-pc-name { font-size: 13px; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .abs-pc-foot { display: flex; align-items: center; gap: 5px; margin-top: 2px; }
  .abs-pc-source {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 8.5px; font-weight: 700; padding: 2px 5px; border-radius: 4px;
    color: white; letter-spacing: 0.04em;
  }
  .abs-pc-score { font-family: 'Poppins'; font-weight: 800; font-size: 18px; color: #ef4444; }
  .abs-source-linkedin { background: #0a66c2; }
  .abs-source-xing { background: #006567; }
  .abs-source-indeed { background: #2557a7; }
  .abs-source-stepstone { background: #0073e6; }

  /* === HAMBURGER + MOBILE NAV OVERLAY (base styles, always loaded) === */
  .fc-nav-burger {
    display: none; /* hidden on desktop; shown via @media in later task */
    background: transparent;
    border: 0;
    width: 44px;
    height: 44px;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    cursor: pointer;
    padding: 0;
    margin-left: 4px;
  }
  .fc-nav-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: #0a0a0e;
    border-radius: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .fc-mob-nav[hidden] { display: none; }
  .fc-mob-nav {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(255,255,255,0.98);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 280ms cubic-bezier(0.32, 0.72, 0, 1);
  }
  .fc-mob-nav.is-open { transform: translateX(0); }

  .fc-mob-nav-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    position: sticky;
    top: 0;
    background: rgba(255,255,255,0.98);
    z-index: 2;
  }
  .fc-mob-nav-logo {
    font-family: 'Poppins';
    font-weight: 700;
    font-size: 19px;
    letter-spacing: -0.03em;
    text-decoration: none;
  }
  .fc-mob-nav-close {
    background: transparent;
    border: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #0a0a0e;
  }

  .fc-mob-nav-body {
    flex: 1;
    overflow-y: auto;
    padding: 12px 0;
  }
  .fc-mob-acc-trigger {
    width: 100%;
    background: transparent;
    border: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px;
    font-size: 17px;
    font-weight: 600;
    color: #0a0a0e;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
  }
  .fc-mob-acc-caret {
    transition: transform 200ms ease;
  }
  .fc-mob-acc-trigger[aria-expanded="true"] .fc-mob-acc-caret {
    transform: rotate(180deg);
  }
  .fc-mob-acc-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 240ms ease-out;
  }
  .fc-mob-acc-panel.is-open {
    max-height: 600px;
  }
  .fc-mob-link {
    display: block;
    padding: 14px 40px;
    font-size: 15px;
    color: #525252;
    text-decoration: none;
    border-radius: 8px;
    transition: background 150ms ease;
    min-height: 44px;
  }
  .fc-mob-link:hover, .fc-mob-link:focus-visible {
    background: rgba(239,68,68,0.05);
    color: #ef4444;
  }
  .fc-mob-link.flat {
    padding: 16px 24px;
    font-size: 17px;
    font-weight: 600;
    color: #0a0a0e;
  }
  .fc-mob-link.flat.highlight {
    color: #ef4444;
  }

  .fc-mob-nav-foot {
    display: flex;
    gap: 10px;
    padding: 16px 20px;
    border-top: 1px solid rgba(0,0,0,0.06);
    position: sticky;
    bottom: 0;
    background: rgba(255,255,255,0.98);
  }
  .fc-mob-cta-ghost, .fc-mob-cta-primary {
    flex: 1;
    text-align: center;
    padding: 14px 16px;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 700;
    font-size: 15px;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .fc-mob-cta-ghost {
    border: 2px solid rgba(0,0,0,0.1);
    color: #0a0a0e;
    background: transparent;
  }
  .fc-mob-cta-primary {
    background: #ef4444;
    color: white;
    box-shadow: 0 4px 0 #b91c1c;
  }

  body.no-scroll { overflow: hidden; }

  /* Body-level overflow safety net (alle Viewports) */
  html, body.fc {
    overflow-x: clip;
    max-width: 100vw;
  }
  @supports not (overflow-x: clip) {
    html, body.fc { overflow-x: hidden; }
  }

  /* === TABLET NAV (≤1080px): Desktop-Menü passt nicht mehr in die Pille → Burger === */
  @media (max-width: 1080px) {
    .fc-nav-menu { display: none; }
    .fc-nav-burger { display: flex; }
    .fc-nav-right { gap: 0; flex-shrink: 0; }
    /* CTAs wandern ins Burger-Overlay — in der Top-Bar ausblenden */
    .fc-nav-right .nav-cta-ghost,
    .fc-nav-right .nav-cta-primary { display: none; }
  }

  /* === MOBILE OVERRIDES (≤768px) === */
  @media (max-width: 768px) {
    /* --- Nav --- */
    .fc-nav { padding: 12px 16px 0; }
    .fc-nav-inner {
      width: 100%;
      max-width: 100%;
      padding: 6px 6px 6px 14px;
      gap: 8px;
      box-sizing: border-box;
    }
    .fc-nav-left { gap: 8px; flex: 1; min-width: 0; }

    /* --- Hero --- */
    .fc-hero { padding: 60px 0 40px; overflow-x: hidden; }
    .fc-hero-inner {
      padding: 0 20px;
      align-items: stretch;
      text-align: center;
      width: 100%;
      max-width: 100%;
    }
    .fc-hero-inner > * { max-width: 100%; }
    .fc-hero h1 {
      font-size: 32px;
      line-height: 1.05;
      word-wrap: break-word;
      overflow-wrap: break-word;
      hyphens: auto;
    }
    .fc-hero .lead {
      font-size: 16px;
      max-width: 100%;
      margin-top: 20px;
      margin-left: 0;
      margin-right: 0;
    }
    .fc-hero .actions {
      flex-direction: column;
      gap: 12px;
      margin-top: 28px;
      width: 100%;
      align-items: stretch;
    }
    .fc-hero .actions .fc-btn,
    .fc-hero .actions .fc-btn-ghost {
      width: 100%;
      justify-content: center;
      box-sizing: border-box;
    }
    .fc-hero .trust { justify-content: center; flex-wrap: wrap; }
    .fc-pill { align-self: center; }
    .fc-hero-glow { display: none; }
    .fc-hero::before { width: 100%; height: 600px; }
    .fc-hero-deco-dot { opacity: 0.3; }
    .fc-hero-deco-star { opacity: 0.4; font-size: 16px; }
    .fc-pill { font-size: 12px; padding: 6px 12px; }

    /* --- "So funktioniert's" Cards --- */
    .fc-how-head { padding: 0 20px; max-width: 100%; }
    .fc-how-head h2 { font-size: 32px; }
    .fc-how-cards {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 0 20px;
      margin-top: 40px;
      max-width: 100%;
    }

    /* --- Bento Grid --- */
    .fc-bento-head { padding: 0 20px; max-width: 100%; }
    .fc-bento-head h2 { font-size: 32px; }
    .fc-bento {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 16px;
      padding: 0 20px;
      max-width: 100%;
    }
    .fc-bento > * {
      grid-column: auto !important;
      grid-row: auto !important;
      min-height: 200px;
    }

    /* --- Stats Grid --- */
    .fc-stats-head { padding: 0 20px; max-width: 100%; }
    .fc-stats-head h2 { font-size: 32px; }
    .fc-stats-grid {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 0 20px;
      margin-top: 40px;
      max-width: 100%;
    }

    /* --- Close (dark CTA section) --- */
    .fc-close { padding: 60px 0; }
    .fc-close-inner { padding: 0 20px; max-width: 100%; }
    .fc-close h2 { font-size: 32px; line-height: 1.1; }
    .fc-close .lead { font-size: 15px; margin-top: 14px; }
    .fc-close .actions {
      flex-direction: column;
      gap: 12px;
      margin-top: 28px;
    }
    .fc-close .actions a { width: 100%; justify-content: center; box-sizing: border-box; }

    /* --- Agents-vs-Features --- */
    .fc-avf { padding: 60px 0; }
    .fc-avf-head { padding: 0 20px; margin-bottom: 32px; max-width: 100%; }
    .fc-avf-head h2 { font-size: 32px; }
    .fc-avf-grid {
      grid-template-columns: 1fr;
      padding: 0 20px;
      gap: 20px;
      max-width: 100%;
    }

    /* --- AI-Features --- */
    .fc-ai-head { padding: 0 20px; margin-bottom: 40px; max-width: 100%; }
    .fc-ai-head h2 { font-size: 32px; }
    .fc-ai-grid {
      grid-template-columns: 1fr;
      padding: 0 20px;
      gap: 16px;
      max-width: 100%;
    }

    /* --- Testimonials --- */
    .fc-testi-head { padding: 0 20px; margin-bottom: 40px; max-width: 100%; }
    .fc-testi-head h2 { font-size: 32px; }
    .fc-testi-grid {
      grid-template-columns: 1fr;
      padding: 0 20px;
      gap: 16px;
      max-width: 100%;
    }

    /* --- FAQ --- */
    .fc-faq { padding: 60px 0; }
    .fc-faq-head { padding: 0 20px; margin-bottom: 32px; max-width: 100%; }
    .fc-faq-head h2 { font-size: 32px; }

    /* --- Sell-the-Job teaser (decorative fields) --- */
    .stj-field { display: none; }

    /* --- Trusted-by marquee — keep marquee but ensure parent clips properly --- */
    .fc-trusted { max-width: 100vw; overflow: hidden; }

    /* --- Sourcing score-stamp + other absolute positioned siblings --- */
    .abs-section, .abs-main-row, .abs-pipe-card { max-width: 100%; overflow: hidden; }

  }

  /* === SMALL MOBILE OVERRIDES (≤480px) === */
  @media (max-width: 480px) {
    /* --- Nav --- */
    .fc-nav { padding: 10px 12px 0; }
    .fc-nav-inner { padding: 5px 5px 5px 12px; gap: 6px; }
    .fc-logo { font-size: 17px; gap: 8px; }
    .fc-logo .lg { width: 28px; height: 28px; }

    /* --- Hero --- */
    .fc-hero { padding: 50px 0 30px; }
    .fc-hero-inner { padding: 0 16px; }
    .fc-hero h1 { font-size: 26px; }
    .fc-hero .lead { font-size: 15px; margin-top: 16px; }
    .fc-hero-deco-dot { display: none; }
    .fc-hero-deco-star { display: none; }

    /* --- Headings further reduced --- */
    .fc-how-head h2,
    .fc-bento-head h2,
    .fc-stats-head h2,
    .fc-close h2,
    .fc-avf-head h2,
    .fc-ai-head h2,
    .fc-testi-head h2,
    .fc-faq-head h2 { font-size: 26px; }

    /* --- Sourcing-Showcase scale-down --- */
    .abs-head h2 { font-size: 26px; }
    .abs-pipe-card {
      transform: scale(0.92);
      transform-origin: center top;
    }
    .abs-plat-bar { gap: 8px; }
    .abs-plat {
      padding: 8px 6px;
      font-size: 11px;
    }
  }

  @media (max-width: 880px) {
    .abs-main-row { grid-template-columns: 1fr; }
    .abs-plat-bar { grid-template-columns: repeat(2, 1fr); }
    .abs-head h2 { font-size: 36px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .abs-hero-card, .abs-hero-card *, .abs-plat, .abs-plat *, .abs-pipe-card, .abs-pipe-card *,
