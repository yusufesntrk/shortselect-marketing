  <script is:inline>
(function() {
  // Use window for scroll
  

  // Reveal-on-scroll observer (within scrollable stage)
  function checkReveal() {
    // Use viewport for measurements
    var triggerY = window.innerHeight * 0.85;
    document.querySelectorAll('[data-reveal]').forEach(function(el) {
      if (el.classList.contains('in')) return;
      var rect = el.getBoundingClientRect();
      var elTop = rect.top;
      if (elTop < triggerY && elTop > -rect.height) {
        el.classList.add('in');
      }
    });
    // Stat cards trigger
    document.querySelectorAll('.fc-stat-card').forEach(function(el) {
      if (el.classList.contains('in')) return;
      var rect = el.getBoundingClientRect();
      var elTop = rect.top;
      if (elTop < triggerY && elTop > -rect.height) {
        el.classList.add('in');
        // animate counter
        var counter = el.querySelector('[data-counter]');
        if (counter) {
          var target = parseFloat(counter.dataset.counter);
          var dec = parseInt(counter.dataset.decimals || 0);
          var prefix = counter.dataset.prefix || '';
          var suffix = counter.dataset.suffix || '';
          var dur = 1800;
          var start = performance.now();
          function step(now) {
            var p = Math.min(1, (now - start) / dur);
            var eased = 1 - Math.pow(1 - p, 3);
            var v = target * eased;
            var formatted;
            if (dec > 0) {
              formatted = v.toFixed(dec).replace('.', ',');
            } else {
              formatted = Math.floor(v).toLocaleString('de-DE');
            }
            counter.textContent = prefix + formatted + suffix;
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }
      }
    });
  }
  window.addEventListener("scroll", checkReveal); window.addEventListener("resize", checkReveal);
  setTimeout(checkReveal, 100);
  setTimeout(function() {
    document.querySelectorAll('[data-reveal]').forEach(function(el) {
      if (!el.classList.contains('in')) el.classList.add('in');
    });
  }, 1800);

  // Smart Ranking: shuffle candidates every 4s (FIXED: position rows absolutely)
  var rankingAnim = document.getElementById('rankingAnim');
  if (rankingAnim) {
    var ROW_GAP = 44; // 38px height + 6px gap
    var rows = rankingAnim.querySelectorAll('.rank-row');
    // Set initial positions
    rows.forEach(function(row, idx) {
      row.style.transform = 'translate3d(0,' + (idx * ROW_GAP) + 'px,0)';
    });

    var permutations = [
      [0, 1, 2, 3],
      [1, 0, 2, 3],
      [1, 2, 0, 3],
      [2, 0, 3, 1],
      [0, 2, 1, 3],
      [3, 0, 2, 1],
      [0, 1, 3, 2]
    ];
    var permIdx = 0;
    setInterval(function() {
      permIdx = (permIdx + 1) % permutations.length;
      var perm = permutations[permIdx];
      // perm[i] = which row should be at position i
      perm.forEach(function(rowIdx, posIdx) {
        var row = rows[rowIdx];
        row.style.transform = 'translate3d(0,' + (posIdx * ROW_GAP) + 'px,0)';
        if (posIdx === 0) row.classList.add('top');
        else row.classList.remove('top');
      });
    }, 4000);
  }

  // AVF Win Dashboard: Counter tickt live hoch
  var winCounter = document.getElementById('winCounter');
  if (winCounter) {
    var w = 147;
    setInterval(function() {
      w += 1;
      if (w > 999) w = 147;
      winCounter.textContent = w;
    }, 1100);
  }

  // 3D Tilt on Hover (Framer-Motion-style)
  document.querySelectorAll('[data-tilt]').forEach(function(card) {
    var rafId = null;
    var targetRX = 0, targetRY = 0;
    var currentRX = 0, currentRY = 0;

    function tiltLoop() {
      currentRX += (targetRX - currentRX) * 0.15;
      currentRY += (targetRY - currentRY) * 0.15;
      card.style.transform = 'perspective(1200px) rotateX(' + currentRX + 'deg) rotateY(' + currentRY + 'deg) translateZ(0)';
      if (Math.abs(targetRX - currentRX) > 0.01 || Math.abs(targetRY - currentRY) > 0.01) {
        rafId = requestAnimationFrame(tiltLoop);
      } else {
        rafId = null;
      }
    }

    card.addEventListener('mousemove', function(e) {
      var rect = card.getBoundingClientRect();
      var x = (e.clientX - rect.left) / rect.width;
      var y = (e.clientY - rect.top) / rect.height;
      targetRY = (x - 0.5) * 8;
      targetRX = -(y - 0.5) * 8;
      if (!rafId) rafId = requestAnimationFrame(tiltLoop);
    });

    card.addEventListener('mouseleave', function() {
      targetRX = 0;
      targetRY = 0;
      if (!rafId) rafId = requestAnimationFrame(tiltLoop);
    });
  });

  // STJ live counter (tickt langsam hoch)
  var stjCounter = document.getElementById('stjCounter');
  if (stjCounter) {
    var n = 47;
    setInterval(function() {
      n += Math.random() > 0.5 ? 1 : 0;
      if (n > 89) n = 47; // reset für demo
      stjCounter.textContent = n;
    }, 2400);
  }

  // Pipeline animation (FIXED: cards appear in correct columns sequentially)
  var pipeAnim = document.getElementById('pipeAnim');
  if (pipeAnim) {
    var pipeCards = pipeAnim.querySelectorAll('.pipe-card');
    var pipeStage = 0;
    function tickPipe() {
      pipeCards.forEach(function(c) { c.classList.remove('live'); });
      pipeCards[pipeStage].classList.add('live');
      pipeStage = (pipeStage + 1) % pipeCards.length;
    }
    tickPipe();
    setInterval(tickPipe, 1500);
  }

  // Cookie banner reopen trigger
  document.querySelectorAll('[data-cookie-reopen]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      window.dispatchEvent(new CustomEvent('cookie-consent-reopen'));
    });
  });

  // ============ AGENTBURST SOURCING SHOWCASE ============
  var absCard = document.getElementById('absHeroCard');
  if (absCard) {
    var ABS_PROFILES = [
      { id:'A847-291', av:'JK', name:'Julia Kessler', role:'Senior Sales Manager', source:'linkedin', color:'#0a66c2',
        score:94, match:true, crit:[ ['9/10','pass'],['7 Jahre','pass'],['Berlin','pass'],['DE/EN','pass'],['85k€','pass'] ] },
      { id:'A847-318', av:'MA', name:'Mehmet Aydın', role:'Account Executive', source:'xing', color:'#006567',
        score:91, match:true, crit:[ ['8/10','pass'],['5 Jahre','pass'],['München','pass'],['DE','pass'],['72k€','pass'] ] },
      { id:'A847-344', av:'PR', name:'Patrick Roth', role:'BDR Junior', source:'indeed', color:'#2557a7',
        score:42, match:false, crit:[ ['6/10','pass'],['1 Jahr','fail'],['Wien','pass'],['DE','pass'],['—','fail'] ] },
      { id:'A847-512', av:'TN', name:'Tanja Neumann', role:'Key Account Manager', source:'stepstone', color:'#0073e6',
        score:87, match:true, crit:[ ['8/10','pass'],['4 Jahre','pass'],['Hamburg','pass'],['DE/EN','pass'],['68k€','pass'] ] }
    ];

    var absEls = {
      av: document.getElementById('absHcAv'),
      name: document.getElementById('absHcName'),
      role: document.getElementById('absHcRole'),
      src: document.getElementById('absHcSrc'),
      idNum: document.getElementById('absHcIdNum'),
      crits: document.querySelectorAll('#absCritList .abs-crit'),
      stamp: document.getElementById('absScoreStamp'),
      stampNum: document.getElementById('absScoreNum'),
      stampLbl: document.getElementById('absScoreLbl'),
      colSourced: document.getElementById('absColSourced'),
      plats: {
        linkedin: document.getElementById('abs-plat-linkedin'),
        xing: document.getElementById('abs-plat-xing'),
        indeed: document.getElementById('abs-plat-indeed'),
        stepstone: document.getElementById('abs-plat-stepstone')
      }
    };

    var absIdx = 0;

    function absClearCardClasses() {
      absCard.classList.remove('spawning','idle','scanning','scored','filing','rejecting','strike','match-card','miss-card');
      absCard.style.opacity = '0';
      absCard.style.removeProperty('transform');
    }
    function absResetCrits() {
      absEls.crits.forEach(function(c) {
        c.classList.remove('show','pass','fail');
        c.querySelector('.abs-crit-icon').textContent = '·';
        c.querySelector('.abs-crit-val').textContent = '—';
      });
    }
    function absDeactivatePlats() {
      Object.keys(absEls.plats).forEach(function(k){ absEls.plats[k].classList.remove('active'); });
    }
    function absSetSpawnVector(platformEl) {
      var pRect = platformEl.getBoundingClientRect();
      absCard.style.opacity = '0';
      absCard.classList.remove('spawning');
      var cRect = absCard.getBoundingClientRect();
      // Only horizontal motion from platform — vertical clamped to 0 so card
      // never crosses into the platform bar visually
      var dx = (pRect.left + pRect.width/2) - (cRect.left + cRect.width/2);
      absCard.style.setProperty('--spawn-dx', dx + 'px');
      absCard.style.setProperty('--spawn-dy', '0px');
    }
    function absSetFileVector() {
      var target = absEls.colSourced.getBoundingClientRect();
      var cRect = absCard.getBoundingClientRect();
      var dx = (target.left + 40) - (cRect.left + cRect.width/2);
      var dy = (target.top + 30) - (cRect.top + cRect.height/2);
      absCard.style.setProperty('--file-dx', dx + 'px');
      absCard.style.setProperty('--file-dy', dy + 'px');
    }
    function absAnimateScore(target, ms) {
      var cur = 0;
      var steps = 22;
      var stepDur = ms / steps;
      var step = Math.max(1, Math.round(target / steps));
      var t = setInterval(function() {
        cur = Math.min(target, cur + step);
        absEls.stampNum.textContent = cur;
        if (cur >= target) clearInterval(t);
      }, stepDur);
    }
    function absSetCrit(idx, val, status) {
      var c = absEls.crits[idx];
      c.classList.add('show', status);
      c.querySelector('.abs-crit-icon').textContent = status === 'pass' ? '✓' : '✕';
      c.querySelector('.abs-crit-val').textContent = val;
    }
    function absAddPoolCard(p) {
      var html =
        '<div class="abs-pipe-card land">' +
          '<div class="abs-pc-av" style="background:'+p.color+'">'+p.av+'</div>' +
          '<div class="abs-pc-meta">' +
            '<div class="abs-pc-name">'+p.name+'</div>' +
            '<div class="abs-pc-foot">' +
              '<span class="abs-pc-source abs-source-'+p.source+'">'+p.source+'</span>' +
              '<span class="abs-pc-score">'+p.score+'</span>' +
            '</div>' +
          '</div>' +
        '</div>';
      absEls.colSourced.insertAdjacentHTML('beforeend', html);
    }
    function absClearPool() {
      var cards = Array.prototype.slice.call(absEls.colSourced.children);
      cards.forEach(function(c, i) { setTimeout(function(){ c.classList.add('exit'); }, i * 80); });
      setTimeout(function(){ absEls.colSourced.innerHTML = ''; }, cards.length * 80 + 600);
    }

    function absRunCycle() {
      var p = ABS_PROFILES[absIdx % ABS_PROFILES.length];
      var isFirstOfRound = (absIdx % ABS_PROFILES.length === 0);
      absIdx++;

      if (isFirstOfRound && absEls.colSourced.children.length > 0) {
        absClearPool();
      }

      absClearCardClasses();
      absResetCrits();
      absDeactivatePlats();
      absEls.stamp.classList.remove('match','miss');
      absEls.stampNum.textContent = '0';

      absEls.av.textContent = p.av;
      absEls.av.style.background = p.color;
      absEls.name.textContent = p.name;
      absEls.role.textContent = p.role;
      absEls.src.textContent = p.source;
      absEls.src.className = 'abs-hc-src abs-source-' + p.source;
      absEls.idNum.textContent = '#' + p.id;

      absEls.plats[p.source].classList.add('active');

      setTimeout(function() {
        absSetSpawnVector(absEls.plats[p.source]);
        absCard.classList.add('spawning');
      }, 1000);

      setTimeout(function() {
        absCard.classList.remove('spawning');
        absCard.classList.add('idle');
        absCard.style.opacity = '1';
      }, 1700);

      setTimeout(function() {
        absCard.classList.add('scanning');
        p.crit.forEach(function(cv, i) {
          setTimeout(function() { absSetCrit(i, cv[0], cv[1]); }, 100 + i * 320);
        });
      }, 2200);

      setTimeout(function() {
        absCard.classList.remove('scanning');
        absEls.stamp.classList.add(p.match ? 'match' : 'miss');
        absEls.stampLbl.textContent = p.match ? 'Match' : 'Pass';
        absCard.classList.add('scored', p.match ? 'match-card' : 'miss-card');
        absAnimateScore(p.score, 400);
      }, 4500);

      setTimeout(function() {
        if (p.match) {
          absSetFileVector();
          absCard.classList.remove('idle');
          absCard.classList.add('filing');
          setTimeout(function() { absAddPoolCard(p); }, 780);
        } else {
          absCard.classList.add('strike');
          setTimeout(function() {
            absCard.classList.remove('idle');
            absCard.classList.add('rejecting');
          }, 700);
        }
      }, 5400);
    }

    // Start the loop only when section is scrolled into view (preserves performance)
    var absArenaEl = document.getElementById('absArena');
    var absStarted = false;
    var absInterval = null;
    function absMaybeStart() {
      if (absStarted) return;
      var rect = absArenaEl.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        absStarted = true;
        setTimeout(absRunCycle, 600);
        absInterval = setInterval(absRunCycle, 7000);
      }
    }
    window.addEventListener('scroll', absMaybeStart, { passive: true });
    window.addEventListener('load', absMaybeStart);
    absMaybeStart();
  }
})();

  // === MOBILE NAV OVERLAY ===
  (function initMobileNav() {
    const burger = document.querySelector('.fc-nav-burger');
    const overlay = document.getElementById('mobile-nav-overlay');
    const closeBtn = overlay && overlay.querySelector('.fc-mob-nav-close');
    if (!burger || !overlay || !closeBtn) return;

    const accTriggers = overlay.querySelectorAll('.fc-mob-acc-trigger');

    function openOverlay() {
      overlay.removeAttribute('hidden');
      // Force reflow so transition runs from translateX(100%)
      void overlay.offsetHeight;
      overlay.classList.add('is-open');
      burger.setAttribute('aria-expanded', 'true');
      document.body.classList.add('no-scroll');
      setTimeout(function () { closeBtn.focus(); }, 50);
    }

    function closeOverlay() {
      overlay.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('no-scroll');
      setTimeout(function () {
        overlay.setAttribute('hidden', '');
        accTriggers.forEach(function (t) {
          t.setAttribute('aria-expanded', 'false');
          const panel = t.nextElementSibling;
          if (panel) panel.classList.remove('is-open');
        });
      }, 300);
    }

    burger.addEventListener('click', openOverlay);
    closeBtn.addEventListener('click', closeOverlay);

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && overlay.classList.contains('is-open')) {
        closeOverlay();
      }
    });

    accTriggers.forEach(function (trigger) {
      trigger.addEventListener('click', function () {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        accTriggers.forEach(function (t) {
          t.setAttribute('aria-expanded', 'false');
          const p = t.nextElementSibling;
          if (p) p.classList.remove('is-open');
        });
        if (!isOpen) {
          trigger.setAttribute('aria-expanded', 'true');
          const panel = trigger.nextElementSibling;
          if (panel) panel.classList.add('is-open');
        }
      });
    });

    overlay.querySelectorAll('.fc-mob-link').forEach(function (link) {
      link.addEventListener('click', function () {
        // Don't preventDefault — let navigation happen
        closeOverlay();
      });
    });
  })();
  </script>
</body>
