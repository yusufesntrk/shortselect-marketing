---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import SellTheJobTeaser from '../components/landing/SellTheJobTeaser.astro';
import AgentsVsFeaturesSection from '../components/landing/AgentsVsFeaturesSection.astro';
import TrustedBySection from '../components/landing/TrustedBySection.astro';
import AIFeaturesSection from '../components/landing/AIFeaturesSection.astro';
import PlatformSection from '../components/landing/PlatformSection.astro';
import StatsSection from '../components/landing/StatsSection.astro';
import FAQSection from '../components/landing/FAQSection.astro';
import CTASection from '../components/landing/CTASection.astro';
import TestimonialsSection from '../components/landing/TestimonialsSection.astro';

const SIGNUP_URL_HERO = 'https://app.shortselect.com/signup?utm_source=marketing&utm_medium=cta&utm_campaign=founders_deal&utm_content=hero';

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "ShortSelect",
  applicationCategory: "BusinessApplication",
  applicationSubCategory: "Applicant Tracking System",
  operatingSystem: "Web Browser",
  description: "KI-gestützte Recruiting Software für modernes Bewerbermanagement mit AI Matching, Smart Ranking und Client Portal",
  offers: {
    "@type": "Offer",
    name: "Founders Deal",
    price: "89.00",
    priceCurrency: "EUR",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2099-12-31",
    url: "https://www.shortselect.com/preise",
  },
  featureList: [
    "KI-gestütztes Kandidaten-Matching",
    "Smart Ranking mit AI",
    "Automatische Benachrichtigungen",
    "Client Portal für Kunden",
    "Kanban Board",
    "Interview Scheduling",
    "Talent Pools",
    "Reports & Analytics",
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    ratingCount: "127",
    bestRating: "5",
  },
};
---

<MarketingLayout
  title="ShortSelect, KI-Recruiting Software & ATS | Kostenlos testen"
  description="KI-gestützte Recruiting Software mit AI Matching, Smart Ranking und Client Portal. 30 Tage kostenlos testen, keine Kreditkarte nötig."
  jsonLd={softwareSchema}
>
  <HeroSection />
  <SellTheJobTeaser />
  <AgentsVsFeaturesSection />
  <TrustedBySection />
  <AIFeaturesSection />
  <PlatformSection />
  <StatsSection />
  <TestimonialsSection />

  <!-- Pricing Teaser -->
  <section class="py-20 md:py-32 relative overflow-hidden" id="pricing">
    <div class="container mx-auto px-4">
      <div id="pricing-teaser" class="max-w-2xl mx-auto text-center opacity-0 translate-y-8 transition-all duration-700">
        <span class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-primary/10 text-primary text-sm font-semibold">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          Limitiertes Founders Angebot
        </span>
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight mb-4">
          Founders Deal: <span class="text-primary">alle Funktionen, ein Preis.</span>
        </h2>
        <div class="flex items-baseline justify-center gap-3 mb-4 flex-wrap">
          <span class="text-xl text-muted-foreground line-through font-medium">150 €</span>
          <span class="text-5xl font-display font-bold text-foreground">89 €</span>
          <span class="text-lg text-muted-foreground">/Monat</span>
        </div>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto mb-8">
          Pro Tenant, alle Recruiter-Plätze inklusive. Preis auf Lebenszeit garantiert. Limitiert auf die ersten 100 Recruiting-Agenturen.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href={SIGNUP_URL_HERO}
            class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-primary-foreground font-semibold rounded-lg text-base hover:bg-primary/90 shadow-md hover:shadow-xl transition-all duration-300"
          >
            30 Tage kostenlos starten
          </a>
          <a
            href="/preise"
            class="inline-flex items-center px-8 py-3 border-2 border-border font-semibold rounded-lg text-base hover:border-primary/50 transition-colors"
          >
            Alle Details ansehen
          </a>
        </div>
        <p class="text-xs text-muted-foreground mt-6">
          30 Tage kostenlos. Keine Kreditkarte erforderlich. Jederzeit kündbar.
        </p>
      </div>
    </div>
  </section>

  <FAQSection />
  <CTASection />
</MarketingLayout>

<script is:inline>
(function() {
  var teaser = document.getElementById('pricing-teaser');
  if (!teaser) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  observer.observe(teaser);
})();
</script>
