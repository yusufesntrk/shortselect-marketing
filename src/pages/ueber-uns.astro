---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import CTASection from '../components/landing/CTASection.astro';
---

<MarketingLayout
  title="Ueber uns – Das Team hinter ShortSelect | ShortSelect"
  description="Lernen Sie das Team hinter ShortSelect kennen. Wir glauben, dass Recruiting besser sein kann -- und bauen die Software, die das beweist."
>
  <!-- Hero -->
  <section class="relative overflow-hidden py-28 md:py-40 bg-gradient-to-br from-[hsl(var(--primary))] via-[hsl(var(--primary)/0.95)] to-[hsl(var(--accent))] text-white">
    <div class="absolute top-10 left-[10%] w-72 h-72 bg-white/5 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-10 right-[10%] w-96 h-96 bg-white/5 rounded-full blur-3xl animate-float-slow" style="animation-delay: -3s;"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.08)_1px,transparent_1px)] bg-[size:32px_32px] opacity-40"></div>

    <div class="container relative mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-3xl mx-auto text-center space-y-6">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-display font-bold tracking-tight leading-tight">
          Wir glauben, dass Recruiting besser sein kann.
        </h1>
        <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto">
          ShortSelect entstand aus dem Wunsch, Personalvermittlern das zu geben, was sie verdienen: ein Werkzeug, das mitdenkt.
        </p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-[hsl(var(--background))] to-transparent"></div>
  </section>

  <!-- Origin Story -->
  <section class="py-20 md:py-32 relative overflow-hidden">
    <div class="absolute top-20 right-0 w-80 h-80 bg-[hsl(var(--primary)/0.05)] rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-20 left-0 w-64 h-64 bg-[hsl(var(--accent)/0.05)] rounded-full blur-3xl animate-float-slow" style="animation-delay: -2s;"></div>

    <div class="container relative mx-auto px-4 max-w-4xl space-y-20">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center">
        <span class="text-sm font-medium text-[hsl(var(--primary))] uppercase tracking-widest">Der Anfang</span>
        <h2 class="text-2xl md:text-4xl font-display font-bold tracking-tight mt-4">
          2024: Ein Recruiter. 200 Bewerbungen. Eine Excel-Tabelle.
        </h2>
      </div>

      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-2xl">
        <div class="border-l-4 border-[hsl(var(--primary)/0.3)] pl-6">
          <p class="text-lg md:text-xl text-[hsl(var(--muted-foreground))] leading-relaxed">
            Wir haben gesehen, wie Personalvermittler Stunden mit Copy-Paste verbringen, statt mit Menschen zu sprechen. Wie sie zwischen zehn Tabs jonglieren, nur um einen Kandidaten weiterzuleiten.
          </p>
        </div>
      </div>

      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-2xl ml-auto">
        <div class="border-r-4 border-[hsl(var(--accent)/0.3)] pr-6 text-right">
          <p class="text-lg md:text-xl text-[hsl(var(--muted-foreground))] leading-relaxed">
            Wir haben uns gefragt: Was wäre, wenn die Software die Verwaltung übernimmt -- und der Recruiter sich aufs Wesentliche konzentrieren kann?
          </p>
        </div>
      </div>

      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center">
        <h2 class="text-2xl md:text-4xl font-display font-bold tracking-tight">
          Die Antwort: <span class="text-[hsl(var(--primary))]">ShortSelect</span>.
        </h2>
        <p class="text-lg text-[hsl(var(--muted-foreground))] mt-4 max-w-2xl mx-auto">
          Ein ATS, das von Recruitern für Recruiter gebaut wurde. Mit KI, die echte Probleme löst -- nicht Features, die niemand braucht.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20 md:py-28 bg-[hsl(var(--muted)/0.3)] relative overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center max-w-3xl mx-auto mb-16">
        <span class="text-sm font-medium text-[hsl(var(--primary))] uppercase tracking-widest">Unsere Mission</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight mt-4 mb-4">Recruiting einfach machen.</h2>
        <p class="text-lg text-[hsl(var(--muted-foreground))]">Drei Prinzipien leiten alles, was wir tun.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 rounded-xl border border-[hsl(var(--border))] bg-[hsl(var(--card))] p-8 text-center space-y-4">
          <div class="h-14 w-14 rounded-xl bg-[hsl(var(--primary)/0.1)] flex items-center justify-center mx-auto">
            <svg class="h-7 w-7 text-[hsl(var(--primary))]" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
          </div>
          <h3 class="text-xl font-display font-bold">Einfachheit</h3>
          <p class="text-[hsl(var(--muted-foreground))]">Komplexe Probleme, einfache Lösungen</p>
        </div>

        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border border-[hsl(var(--border))] bg-[hsl(var(--card))] p-8 text-center space-y-4" style="transition-delay: 100ms;">
          <div class="h-14 w-14 rounded-xl bg-[hsl(var(--primary)/0.1)] flex items-center justify-center mx-auto">
            <svg class="h-7 w-7 text-[hsl(var(--primary))]" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></svg>
          </div>
          <h3 class="text-xl font-display font-bold">Innovation</h3>
          <p class="text-[hsl(var(--muted-foreground))]">KI dort, wo sie wirklich hilft</p>
        </div>

        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border border-[hsl(var(--border))] bg-[hsl(var(--card))] p-8 text-center space-y-4" style="transition-delay: 200ms;">
          <div class="h-14 w-14 rounded-xl bg-[hsl(var(--primary)/0.1)] flex items-center justify-center mx-auto">
            <svg class="h-7 w-7 text-[hsl(var(--primary))]" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
          </div>
          <h3 class="text-xl font-display font-bold">Fairness</h3>
          <p class="text-[hsl(var(--muted-foreground))]">Transparente Preise, ehrliche Software</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight mb-4">Unsere Werte</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-3 p-6">
          <div class="h-12 w-12 rounded-xl bg-[hsl(var(--primary)/0.1)] flex items-center justify-center mx-auto">
            <svg class="h-6 w-6 text-[hsl(var(--primary))]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="font-display font-bold">Nutzer zuerst</h3>
          <p class="text-sm text-[hsl(var(--muted-foreground))]">Jede Entscheidung beginnt beim Recruiter.</p>
        </div>

        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-center space-y-3 p-6" style="transition-delay: 100ms;">
          <div class="h-12 w-12 rounded-xl bg-[hsl(var(--primary)/0.1)] flex items-center justify-center mx-auto">
            <svg class="h-6 w-6 text-[hsl(var(--primary))]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
          </div>
          <h3 class="font-display font-bold">Daten-sicher</h3>
          <p class="text-sm text-[hsl(var(--muted-foreground))]">DSGVO-konform, Server in der EU.</p>
        </div>

        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-center space-y-3 p-6" style="transition-delay: 200ms;">
          <div class="h-12 w-12 rounded-xl bg-[hsl(var(--primary)/0.1)] flex items-center justify-center mx-auto">
            <svg class="h-6 w-6 text-[hsl(var(--primary))]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
          </div>
          <h3 class="font-display font-bold">Made in Germany</h3>
          <p class="text-sm text-[hsl(var(--muted-foreground))]">Entwickelt und gehostet in Deutschland.</p>
        </div>

        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-center space-y-3 p-6" style="transition-delay: 300ms;">
          <div class="h-12 w-12 rounded-xl bg-[hsl(var(--primary)/0.1)] flex items-center justify-center mx-auto">
            <svg class="h-6 w-6 text-[hsl(var(--primary))]" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="font-display font-bold">Open API</h3>
          <p class="text-sm text-[hsl(var(--muted-foreground))]">Nahtlose Integration in bestehende Systeme.</p>
        </div>
      </div>
    </div>
  </section>

  <CTASection />

  <script is:inline>
  (function() {
    var items = document.querySelectorAll('.reveal-item');
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>
</MarketingLayout>
