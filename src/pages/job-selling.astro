---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Sell the Job – Die neue Ära des Recruitings",
  description: "Post & Pray ist tot. Entdecken Sie, wie Sie Jobs aktiv vermarkten und A-Player gewinnen.",
  url: "https://shortselect.com/job-selling",
};
---

<MarketingLayout
  title="Sell the Job – Die neue Ära des Recruitings | ShortSelect"
  description="Post & Pray ist tot. Entdecken Sie, wie Sie Jobs aktiv vermarkten und A-Player gewinnen. ShortSelect ist das erste ATS mit Job Selling Engine."
  jsonLd={jsonLd}
>

  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 1: CINEMATIC HERO — Dark, full-screen, provocative
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="js-hero" class="relative min-h-screen flex items-center justify-center bg-gray-950 text-white overflow-hidden">
    <!-- Subtle radial glow -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,hsl(0_72%_50%/0.12),transparent_70%)]"></div>
    <!-- Fine grid pattern -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:32px_32px] opacity-30"></div>
    <!-- Floating glow orbs -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/8 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-accent/6 rounded-full blur-3xl animate-float-slow" style="animation-delay: -3s;"></div>

    <div class="container relative mx-auto px-4 text-center space-y-10">
      <!-- Badge -->
      <div id="js-hero-badge" class="opacity-0 -translate-y-4 transition-all duration-700">
        <span class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-white/10 border border-white/20 text-sm font-medium text-white/90 backdrop-blur-sm">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          Die Ära von Post & Pray ist vorbei
        </span>
      </div>

      <!-- Headline -->
      <h1 class="space-y-2">
        <span id="js-hero-line1" class="block text-4xl md:text-6xl lg:text-7xl font-display font-extrabold tracking-tight leading-[1.1] opacity-0 translate-y-8 transition-all duration-700" style="transition-delay: 150ms;">
          Hören Sie auf, Stellen zu posten.
        </span>
        <span id="js-hero-line2" class="block text-4xl md:text-6xl lg:text-7xl font-display font-extrabold tracking-tight leading-[1.1] text-primary opacity-0 translate-y-8 transition-all duration-700 relative inline-block" style="transition-delay: 300ms;">
          Fangen Sie an, Jobs zu verkaufen.
          <svg class="absolute -bottom-3 left-0 w-full" viewBox="0 0 580 12" fill="none">
            <path id="js-hero-underline" d="M2 10C145 4 435 4 578 10" stroke="hsl(0 72% 50%)" stroke-width="4" stroke-linecap="round" style="stroke-dasharray: 580; stroke-dashoffset: 580; transition: stroke-dashoffset 1.2s ease-out;" />
          </svg>
        </span>
      </h1>

      <!-- Animated Counter -->
      <div id="js-hero-counter" class="opacity-0 scale-95 transition-all duration-800" style="transition-delay: 600ms;">
        <div class="relative inline-block">
          <span class="text-6xl md:text-8xl lg:text-9xl font-display font-extrabold tabular-nums js-counter" data-target="147000">0</span>
          <span class="text-5xl md:text-7xl lg:text-8xl font-display font-extrabold text-white/70">+</span>
          <div class="absolute inset-0 blur-3xl bg-primary/20 -z-10 scale-150 animate-pulse"></div>
        </div>
        <p class="text-lg md:text-xl text-white/50 mt-4 max-w-xl mx-auto">
          unbesetzte Stellen allein in Deutschland — jetzt gerade.
        </p>
      </div>

      <!-- Subline -->
      <p id="js-hero-sub" class="text-lg md:text-xl text-white/40 max-w-2xl mx-auto opacity-0 translate-y-8 transition-all duration-700" style="transition-delay: 900ms;">
        Während Sie hier lesen, verlieren Unternehmen die besten Kandidaten. Nicht weil es keine gibt. Sondern weil Recruiting noch immer wie 2005 funktioniert.
      </p>

      <!-- Scroll CTA -->
      <div id="js-hero-scroll" class="opacity-0 transition-opacity duration-1000" style="transition-delay: 1300ms;">
        <a href="#js-problem" class="inline-flex flex-col items-center gap-2 text-white/30 hover:text-white/60 transition-colors duration-300">
          <span class="text-sm font-medium tracking-wide uppercase">Die Wahrheit erfahren</span>
          <svg class="w-5 h-5 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Bottom fade to next section -->
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-gray-900 to-transparent"></div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 2: THE PROBLEM — Dark, pain points, statistics
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="js-problem" class="py-24 md:py-36 bg-gray-900 text-white relative overflow-hidden">
    <!-- Destructive glow -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-red-500/8 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-72 h-72 bg-red-500/5 rounded-full blur-3xl"></div>

    <div class="container relative mx-auto px-4">
      <!-- Header -->
      <div id="js-problem-header" class="text-center space-y-4 mb-20 opacity-0 translate-y-8 transition-all duration-700">
        <span class="inline-block px-4 py-1.5 text-xs font-semibold rounded-full border border-red-500/30 text-red-400 bg-red-500/10 uppercase tracking-wider">Das Problem</span>
        <h2 class="text-4xl md:text-6xl lg:text-7xl font-display font-extrabold tracking-tight">
          Recruiting ist <span class="text-red-400">kaputt</span>.
        </h2>
      </div>

      <!-- Stats Grid -->
      <div class="grid md:grid-cols-3 gap-8 lg:gap-12 max-w-4xl mx-auto mb-20">
        <div class="js-problem-stat text-center space-y-3 opacity-0 translate-y-12 transition-all duration-600" style="transition-delay: 150ms;">
          <div class="text-5xl md:text-6xl font-display font-extrabold text-red-400">73%</div>
          <p class="text-white/50 text-sm leading-relaxed">aller Stellenanzeigen erreichen die falschen Kandidaten</p>
        </div>
        <div class="js-problem-stat text-center space-y-3 opacity-0 translate-y-12 transition-all duration-600" style="transition-delay: 300ms;">
          <div class="text-5xl md:text-6xl font-display font-extrabold text-red-400">42 Tage</div>
          <p class="text-white/50 text-sm leading-relaxed">durchschnittliche Time-to-Hire in Deutschland</p>
        </div>
        <div class="js-problem-stat text-center space-y-3 opacity-0 translate-y-12 transition-all duration-600" style="transition-delay: 450ms;">
          <div class="text-5xl md:text-6xl font-display font-extrabold text-red-400">4.700 €</div>
          <p class="text-white/50 text-sm leading-relaxed">Kosten pro Fehlbesetzung — im Durchschnitt</p>
        </div>
      </div>

      <!-- Pain Points -->
      <div id="js-problem-list" class="max-w-2xl mx-auto opacity-0 translate-y-8 transition-all duration-700" style="transition-delay: 600ms;">
        <h3 class="text-xl font-display font-bold mb-8 text-white/70 text-center">So sieht Post & Pray heute aus:</h3>
        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-red-500/15 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </div>
            <p class="text-white/60">Stellenanzeige online stellen und hoffen, dass sich jemand bewirbt</p>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-red-500/15 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </div>
            <p class="text-white/60">Wochen warten, bis sich überhaupt jemand meldet</p>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-red-500/15 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </div>
            <p class="text-white/60">90% unqualifizierte Bewerbungen manuell aussortieren</p>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-red-500/15 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </div>
            <p class="text-white/60">Top-Kandidaten an die Konkurrenz verlieren — weil man zu langsam war</p>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-8 h-8 rounded-full bg-red-500/15 flex items-center justify-center shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </div>
            <p class="text-white/60">Am Ende: Kompromisse statt A-Player einstellen</p>
          </div>
        </div>

        <!-- Emotional closer -->
        <blockquote class="mt-16 text-center">
          <p class="text-xl md:text-2xl italic text-white/30 leading-relaxed">
            „Wir haben die Stelle seit 6 Monaten offen."
          </p>
          <p class="text-sm text-white/20 mt-3">— Kommt Ihnen das bekannt vor?</p>
        </blockquote>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 3: THE MANIFESTO — Gradient dark→white, emotional peak
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="js-manifesto" class="relative overflow-hidden">
    <div class="bg-gradient-to-b from-gray-900 via-gray-800/80 to-white py-32 md:py-48 lg:py-56">

      <!-- Intro text on dark bg -->
      <div id="js-manifesto-intro" class="container mx-auto px-4 text-center mb-20 md:mb-28 opacity-0 translate-y-8 transition-all duration-700">
        <p class="text-2xl md:text-3xl text-white/50 font-medium">Es gibt einen besseren Weg.</p>
      </div>

      <!-- The Manifesto: Three massive lines -->
      <div class="container mx-auto px-4 text-center space-y-6 md:space-y-10">
        <h2 id="js-manifesto-l1" class="text-4xl md:text-6xl lg:text-8xl font-display font-extrabold tracking-tight text-white/80 opacity-0 translate-y-12 transition-all duration-800" style="transition-delay: 200ms;">
          Jobs sind Produkte.
        </h2>
        <h2 id="js-manifesto-l2" class="text-4xl md:text-6xl lg:text-8xl font-display font-extrabold tracking-tight text-white/60 opacity-0 translate-y-12 transition-all duration-800" style="transition-delay: 450ms;">
          Kandidaten sind Kunden.
        </h2>
        <h2 id="js-manifesto-l3" class="text-4xl md:text-6xl lg:text-8xl font-display font-extrabold tracking-tight opacity-0 translate-y-12 transition-all duration-800" style="transition-delay: 700ms;">
          <span class="text-primary">Recruiting ist Marketing.</span>
        </h2>
      </div>

      <!-- Closing line on lighter bg -->
      <div id="js-manifesto-close" class="container mx-auto px-4 text-center mt-20 md:mt-28 opacity-0 transition-opacity duration-1000" style="transition-delay: 1100ms;">
        <p class="text-xl md:text-2xl font-display font-bold text-foreground/70">
          Willkommen in der Ära von{" "}
          <span class="text-primary relative inline-block">
            Sell the Job
            <svg class="absolute -bottom-1.5 left-0 w-full" viewBox="0 0 200 8" fill="none">
              <path id="js-manifesto-underline" d="M2 6C50 2 150 2 198 6" stroke="currentColor" stroke-width="3" stroke-linecap="round" style="stroke-dasharray: 200; stroke-dashoffset: 200; transition: stroke-dashoffset 1s ease-out;" />
            </svg>
          </span>.
        </p>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 4: HOW IT WORKS — 3-Step Process, clean & bright
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="js-process" class="py-24 md:py-36 relative overflow-hidden">
    <!-- Subtle decoration -->
    <div class="absolute top-20 right-0 w-72 h-72 bg-primary/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-0 w-64 h-64 bg-accent/5 rounded-full blur-3xl"></div>

    <div class="container relative mx-auto px-4">
      <!-- Header -->
      <div id="js-process-header" class="text-center space-y-4 mb-20 opacity-0 translate-y-8 transition-all duration-700">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 text-sm font-medium text-primary">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/></svg>
          So funktioniert's
        </span>
        <h2 class="text-3xl md:text-5xl lg:text-6xl font-display font-bold tracking-tight">
          Von der Stelle zum{" "}
          <span class="text-primary relative inline-block">
            A-Player
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 180 8" fill="none">
              <path id="js-process-underline" d="M2 6C45 2 135 2 178 6" stroke="currentColor" stroke-width="3" stroke-linecap="round" style="stroke-dasharray: 180; stroke-dashoffset: 180; transition: stroke-dashoffset 1s ease-out;" />
            </svg>
          </span>{" "}in 3 Schritten.
        </h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          ShortSelect automatisiert den gesamten Job-Selling-Prozess — von der Anzeige bis zur Einstellung.
        </p>
      </div>

      <!-- 3-Step Grid -->
      <div class="grid lg:grid-cols-3 gap-8 lg:gap-12 max-w-5xl mx-auto relative">
        <!-- Animated connecting arrows (lg only) -->
        <svg id="js-process-connector" class="hidden lg:block absolute top-[4rem] left-0 w-full h-12 overflow-visible pointer-events-none" viewBox="0 0 1000 48" fill="none" preserveAspectRatio="none">
          <!-- Line segment 1: Step 1 → Step 2 -->
          <path id="js-connector-line1" d="M200 24 L470 24" stroke="url(#connector-grad-1)" stroke-width="2" stroke-linecap="round" stroke-dasharray="6 6" style="stroke-dasharray: 270; stroke-dashoffset: 270; transition: stroke-dashoffset 0.8s ease-out;" />
          <!-- Arrow 1 -->
          <path id="js-connector-arrow1" d="M460 16 L478 24 L460 32" stroke="hsl(0 72% 50%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" style="opacity: 0; transition: opacity 0.4s ease-out;" />
          <!-- Dot at center 1 -->
          <circle id="js-connector-dot1" cx="478" cy="24" r="4" fill="hsl(12 76% 61%)" style="opacity: 0; transform: scale(0); transform-origin: 478px 24px; transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);" />

          <!-- Line segment 2: Step 2 → Step 3 -->
          <path id="js-connector-line2" d="M530 24 L800 24" stroke="url(#connector-grad-2)" stroke-width="2" stroke-linecap="round" stroke-dasharray="6 6" style="stroke-dasharray: 270; stroke-dashoffset: 270; transition: stroke-dashoffset 0.8s ease-out;" />
          <!-- Arrow 2 -->
          <path id="js-connector-arrow2" d="M790 16 L808 24 L790 32" stroke="hsl(12 76% 61%)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none" style="opacity: 0; transition: opacity 0.4s ease-out;" />
          <!-- Dot at center 2 -->
          <circle id="js-connector-dot2" cx="808" cy="24" r="4" fill="hsl(142 71% 45%)" style="opacity: 0; transform: scale(0); transform-origin: 808px 24px; transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);" />

          <defs>
            <linearGradient id="connector-grad-1" x1="200" y1="24" x2="470" y2="24" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="hsl(0 72% 50%)" stop-opacity="0.5" />
              <stop offset="100%" stop-color="hsl(12 76% 61%)" stop-opacity="0.5" />
            </linearGradient>
            <linearGradient id="connector-grad-2" x1="530" y1="24" x2="800" y2="24" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="hsl(12 76% 61%)" stop-opacity="0.5" />
              <stop offset="100%" stop-color="hsl(142 71% 45%)" stop-opacity="0.5" />
            </linearGradient>
          </defs>
        </svg>

        <!-- Step 1: Create -->
        <div class="js-process-step text-center space-y-6 opacity-0 translate-y-12 transition-all duration-600" style="transition-delay: 200ms;">
          <div class="relative mx-auto w-28 h-28 md:w-32 md:h-32">
            <div class="w-full h-full rounded-2xl bg-primary/10 border-2 border-primary/20 flex items-center justify-center transition-all duration-500 hover:shadow-xl hover:shadow-primary/10 hover:scale-105">
              <span class="text-4xl md:text-5xl font-display font-extrabold text-primary">1</span>
            </div>
          </div>
          <div>
            <h3 class="text-2xl font-display font-bold">Create</h3>
            <p class="text-sm text-primary font-medium mt-1">KI generiert optimierte Stellenanzeigen</p>
          </div>
          <p class="text-muted-foreground text-sm leading-relaxed max-w-xs mx-auto">
            Unser KI-Agent analysiert Ihre Anforderungen und erstellt hochkonvertierende Stellenanzeigen und Ad Creatives — in Sekunden statt Stunden.
          </p>
        </div>

        <!-- Step 2: Sell -->
        <div class="js-process-step text-center space-y-6 opacity-0 translate-y-12 transition-all duration-600" style="transition-delay: 400ms;">
          <div class="relative mx-auto w-28 h-28 md:w-32 md:h-32">
            <div class="w-full h-full rounded-2xl bg-accent/10 border-2 border-accent/20 flex items-center justify-center transition-all duration-500 hover:shadow-xl hover:shadow-accent/10 hover:scale-105">
              <span class="text-4xl md:text-5xl font-display font-extrabold text-accent">2</span>
            </div>
          </div>
          <div>
            <h3 class="text-2xl font-display font-bold">Sell</h3>
            <p class="text-sm text-accent font-medium mt-1">Multi-Channel Distribution</p>
          </div>
          <p class="text-muted-foreground text-sm leading-relaxed max-w-xs mx-auto">
            Ihre Jobs werden aktiv vermarktet: Social Media Ads, Jobbörsen, Google, Karriereseiten. Nicht posten und hoffen — gezielt platzieren.
          </p>
        </div>

        <!-- Step 3: Hire -->
        <div class="js-process-step text-center space-y-6 opacity-0 translate-y-12 transition-all duration-600" style="transition-delay: 600ms;">
          <div class="relative mx-auto w-28 h-28 md:w-32 md:h-32">
            <div class="w-full h-full rounded-2xl bg-green-500/10 border-2 border-green-500/20 flex items-center justify-center transition-all duration-500 hover:shadow-xl hover:shadow-green-500/10 hover:scale-105">
              <span class="text-4xl md:text-5xl font-display font-extrabold text-green-600">3</span>
            </div>
          </div>
          <div>
            <h3 class="text-2xl font-display font-bold">Hire</h3>
            <p class="text-sm text-green-600 font-medium mt-1">A-Player bewerben sich</p>
          </div>
          <p class="text-muted-foreground text-sm leading-relaxed max-w-xs mx-auto">
            Die besten Kandidaten kommen zu Ihnen. KI filtert, rankt und priorisiert automatisch. Sie konzentrieren sich nur noch auf die Top 5.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════
       SECTION 5: THE DIFFERENCE — Comparison cards + metrics
       ═══════════════════════════════════════════════════════════════════ -->
  <section id="js-comparison" class="py-24 md:py-36 bg-muted/30 relative overflow-hidden">
    <div class="container mx-auto px-4">
      <!-- Header -->
      <div id="js-comp-header" class="text-center space-y-4 mb-16 opacity-0 translate-y-8 transition-all duration-700">
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 text-sm font-medium text-primary">Der Unterschied</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight">
          Post & Pray vs.{" "}
          <span class="text-primary relative inline-block">
            Sell the Job
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 220 8" fill="none">
              <path id="js-comp-underline" d="M2 6C55 2 165 2 218 6" stroke="currentColor" stroke-width="3" stroke-linecap="round" style="stroke-dasharray: 220; stroke-dashoffset: 220; transition: stroke-dashoffset 1s ease-out;" />
            </svg>
          </span>
        </h2>
      </div>

      <!-- Comparison Cards -->
      <div class="grid md:grid-cols-2 gap-6 lg:gap-8 max-w-5xl mx-auto">
        <!-- Left: Post & Pray (old way) -->
        <div id="js-comp-left" class="rounded-xl border border-red-200 bg-red-50/50 p-8 opacity-0 translate-y-12 transition-all duration-700" style="transition-delay: 150ms;">
          <div class="flex items-center gap-3 mb-6">
            <div class="h-12 w-12 rounded-lg bg-red-100 flex items-center justify-center">
              <svg class="h-6 w-6 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            </div>
            <div>
              <h3 class="text-lg font-semibold text-red-900">Post & Pray</h3>
              <p class="text-sm text-red-500/70">Der alte Weg</p>
            </div>
          </div>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 text-red-400 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
              <span class="text-red-900/70">Stellenanzeige hochladen und warten</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="h-5 w-5 text-red-400 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/></svg>
              <span class="text-red-900/70">Passive Verbreitung auf 1–2 Kanälen</span>
            </li>
            <li class="flex items-start gap-3">
