<!-- ═══════════════════════════════════════════════════════════════════
     ALL ANIMATIONS — Single script block
     ═══════════════════════════════════════════════════════════════════ -->
<script is:inline>
(function() {
  // ─── Utility: easeOutExpo ───
  function easeOutExpo(t) {
    return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  // ─── Utility: animateCounter ───
  function animateCounter(el, end, duration) {
    var dur = duration || 2500;
    var startTime = performance.now();
    function animate(currentTime) {
      var elapsed = currentTime - startTime;
      var progress = Math.min(elapsed / dur, 1);
      var current = Math.floor(easeOutExpo(progress) * end);
      el.textContent = current.toLocaleString('de-DE');
      if (progress < 1) {
        requestAnimationFrame(animate);
      } else {
        el.textContent = end.toLocaleString('de-DE');
      }
    }
    requestAnimationFrame(animate);
  }

  // ─── Utility: reveal elements ───
  function reveal(el) {
    if (el) { el.style.opacity = '1'; el.style.transform = 'translateY(0) scale(1)'; }
  }
  function revealOpacity(el) {
    if (el) { el.style.opacity = '1'; }
  }

  // ═══════════════════════════════════════════════════════
  // SECTION 1: HERO — Mount immediately on page load
  // ═══════════════════════════════════════════════════════
  requestAnimationFrame(function() {
    reveal(document.getElementById('js-hero-badge'));
    reveal(document.getElementById('js-hero-line1'));
    reveal(document.getElementById('js-hero-line2'));
    reveal(document.getElementById('js-hero-counter'));
    reveal(document.getElementById('js-hero-sub'));
    revealOpacity(document.getElementById('js-hero-scroll'));

    // SVG underline draws after headline appears
    var underline = document.getElementById('js-hero-underline');
    if (underline) {
      setTimeout(function() { underline.style.strokeDashoffset = '0'; }, 800);
    }

    // Counter starts after delay
    var counterEl = document.querySelector('.js-counter');
    if (counterEl) {
      setTimeout(function() {
        animateCounter(counterEl, 147000, 3000);
      }, 900);
    }
  });

  // ═══════════════════════════════════════════════════════
  // SECTION 2: PROBLEM — Scroll reveal
  // ═══════════════════════════════════════════════════════
  (function() {
    var section = document.getElementById('js-problem');
    if (!section) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          reveal(document.getElementById('js-problem-header'));
          section.querySelectorAll('.js-problem-stat').forEach(function(el) { reveal(el); });
          reveal(document.getElementById('js-problem-list'));
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    observer.observe(section);
  })();

  // ═══════════════════════════════════════════════════════
  // SECTION 3: MANIFESTO — Scroll reveal with stagger
  // ═══════════════════════════════════════════════════════
  (function() {
    var section = document.getElementById('js-manifesto');
    if (!section) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          reveal(document.getElementById('js-manifesto-intro'));
          reveal(document.getElementById('js-manifesto-l1'));
          reveal(document.getElementById('js-manifesto-l2'));
          reveal(document.getElementById('js-manifesto-l3'));
          revealOpacity(document.getElementById('js-manifesto-close'));
          var underline = document.getElementById('js-manifesto-underline');
          if (underline) {
            setTimeout(function() { underline.style.strokeDashoffset = '0'; }, 1200);
          }
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    observer.observe(section);
  })();

  // ═══════════════════════════════════════════════════════
  // SECTION 4: PROCESS — Scroll reveal
  // ═══════════════════════════════════════════════════════
  (function() {
    var section = document.getElementById('js-process');
    if (!section) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          reveal(document.getElementById('js-process-header'));
          section.querySelectorAll('.js-process-step').forEach(function(el) { reveal(el); });
          var underline = document.getElementById('js-process-underline');
          if (underline) {
            setTimeout(function() { underline.style.strokeDashoffset = '0'; }, 300);
          }
          // Animated connector: draw lines → show arrows → pop dots
          var line1 = document.getElementById('js-connector-line1');
          var line2 = document.getElementById('js-connector-line2');
          var arrow1 = document.getElementById('js-connector-arrow1');
          var arrow2 = document.getElementById('js-connector-arrow2');
          var dot1 = document.getElementById('js-connector-dot1');
          var dot2 = document.getElementById('js-connector-dot2');
          // Line 1 draws
          setTimeout(function() {
            if (line1) line1.style.strokeDashoffset = '0';
          }, 600);
          // Arrow 1 + dot 1 appear after line 1
          setTimeout(function() {
            if (arrow1) arrow1.style.opacity = '1';
            if (dot1) { dot1.style.opacity = '1'; dot1.style.transform = 'scale(1)'; }
          }, 1200);
          // Line 2 draws
          setTimeout(function() {
            if (line2) line2.style.strokeDashoffset = '0';
          }, 1300);
          // Arrow 2 + dot 2 appear after line 2
          setTimeout(function() {
            if (arrow2) arrow2.style.opacity = '1';
            if (dot2) { dot2.style.opacity = '1'; dot2.style.transform = 'scale(1)'; }
          }, 1900);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    observer.observe(section);
  })();

  // ═══════════════════════════════════════════════════════
  // SECTION 5: COMPARISON — Scroll reveal
  // ═══════════════════════════════════════════════════════
  (function() {
    var section = document.getElementById('js-comparison');
    if (!section) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          reveal(document.getElementById('js-comp-header'));
          reveal(document.getElementById('js-comp-left'));
          reveal(document.getElementById('js-comp-right'));
          section.querySelectorAll('.js-comp-metric').forEach(function(el) { reveal(el); });
          var underline = document.getElementById('js-comp-underline');
          if (underline) {
            setTimeout(function() { underline.style.strokeDashoffset = '0'; }, 300);
          }
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    observer.observe(section);
  })();

  // ═══════════════════════════════════════════════════════
  // SECTION 6: STATS — Scroll reveal + animated counters
  // ═══════════════════════════════════════════════════════
  (function() {
    var section = document.getElementById('js-stats');
    if (!section) return;
    var animated = false;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !animated) {
          animated = true;
          section.querySelectorAll('.js-stats-item').forEach(function(el) {
            el.style.opacity = '1';
            el.style.transform = 'scale(1)';
          });
          section.querySelectorAll('.js-stat-counter').forEach(function(counter) {
            var target = parseInt(counter.getAttribute('data-target') || '0', 10);
            animateCounter(counter, target);
          });
          revealOpacity(document.getElementById('js-stats-quote'));
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    observer.observe(section);
  })();

  // ═══════════════════════════════════════════════════════
  // SECTION 7: VISION — Scroll reveal
  // ═══════════════════════════════════════════════════════
  (function() {
    var section = document.getElementById('js-vision');
    if (!section) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          reveal(document.getElementById('js-vision-header'));
          section.querySelectorAll('.js-vision-item').forEach(function(el) { reveal(el); });
          revealOpacity(document.getElementById('js-vision-close'));
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    observer.observe(section);
  })();

  // ═══════════════════════════════════════════════════════
  // SECTION 8: CTA — Scroll reveal with stagger
  // ═══════════════════════════════════════════════════════
  (function() {
    var section = document.getElementById('js-cta');
    if (!section) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          reveal(document.getElementById('js-cta-content'));
          revealOpacity(document.getElementById('js-cta-headline'));
          var underline = document.getElementById('js-cta-underline');
          if (underline) {
            setTimeout(function() { underline.style.strokeDashoffset = '0'; }, 500);
          }
          setTimeout(function() { revealOpacity(document.getElementById('js-cta-sub')); }, 200);
          setTimeout(function() { reveal(document.getElementById('js-cta-buttons')); }, 400);
          setTimeout(function() { revealOpacity(document.getElementById('js-cta-trust')); }, 600);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });
    observer.observe(section);
  })();

  // ─── Smooth scroll for anchor links ───
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(a.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
})();
</script>
