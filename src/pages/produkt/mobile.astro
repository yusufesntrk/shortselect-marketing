---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  { title: "Responsive Dashboard", description: "Dashboard passt sich jedem Geraet an -- von 4K bis Smartphone", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>' },
  { title: "Mobile Bewerbung", description: "Kandidaten bewerben sich in 60 Sekunden -- ohne Lebenslauf-Upload", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>' },
  { title: "Push-Benachrichtigungen", description: "Sofortige Benachrichtigung bei neuen Bewerbungen oder Feedback", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>' },
  { title: "Offline-faehig", description: "Kandidatenprofile auch ohne Internetverbindung einsehbar", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="1" x2="23" y1="1" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" x2="12.01" y1="20" y2="20"/></svg>' },
  { title: "Touch-optimiert", description: "Kanban-Board per Touch bedienbar -- Drag & Drop auf dem Tablet", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>' },
  { title: "Quick Actions", description: "Status aendern, E-Mails senden, Notizen hinzufuegen -- alles mit einem Tap", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>' },
];
---

<ProduktLayout
  title="Mobile App – Recruiting von ueberall | ShortSelect"
  description="Responsive Design fuer Desktop, Tablet und Smartphone. Push-Benachrichtigungen, Touch-optimiertes Kanban und Quick Actions."
  canonical="https://shortselect.com/produkt/mobile"
  badgeText="Mobile"
  heroTitle="Recruiting von ueberall."
  heroHighlight="Jederzeit"
  heroSuffix="."
  heroSubtitle="Responsive Design fuer Desktop, Tablet und Smartphone -- Kandidaten verwalten, wo auch immer Sie sind."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/></svg>'
  features={features}
  featuresSectionTitle="Recruiting geht ueberall"
  featuresSectionSubtitle="Responsive Dashboard, Touch-optimiertes Kanban und Quick Actions -- fuer produktives Recruiting unterwegs."
  featuresBadge="Features"
>
  <section class="py-16 md:py-24 text-white relative overflow-hidden" style="background: linear-gradient(to bottom right, hsl(var(--primary)), hsl(var(--primary) / 0.9), hsl(var(--accent)));">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:24px_24px] opacity-30"></div>
    <div class="container relative mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-12 text-center">
        {[
          { value: "100%", label: "Responsive" },
          { value: "60s", label: "Bewerbung" },
          { value: "Alle", label: "Features mobil" },
        ].map((stat, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 space-y-2" style={`transition-delay: ${i * 100}ms;`}>
            <div class="text-5xl md:text-6xl font-display font-bold">{stat.value}</div>
            <p class="text-lg text-white/80">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</ProduktLayout>

<script is:inline>
(function() {
  var items = document.querySelectorAll('.reveal-item');
  if (!items.length) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function(item) { observer.observe(item); });
})();
</script>
