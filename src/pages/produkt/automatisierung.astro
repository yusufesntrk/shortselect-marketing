---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  { title: "Auto-E-Mails", description: "Automatische E-Mails bei Bewerbungseingang, Stage-Wechsel oder Absage", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>' },
  { title: "Stage-Trigger", description: "Aktionen automatisch ausloesen wenn Kandidaten eine Pipeline-Stufe erreichen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="8" x="3" y="3" rx="2"/><path d="M7 11v4a2 2 0 0 0 2 2h4"/><rect width="8" height="8" x="13" y="13" rx="2"/></svg>' },
  { title: "Erinnerungen", description: "Automatische Erinnerungen fuer Follow-ups und ausstehende Feedback-Anfragen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' },
  { title: "Screening-Automation", description: "Knockout-Fragen filtern unqualifizierte Bewerber automatisch aus", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>' },
  { title: "Benachrichtigungen", description: "Hiring Manager und Team automatisch ueber neue Kandidaten informieren", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>' },
  { title: "KI-Screening", description: "Automatische Bewertung eingehender Bewerbungen durch KI. Match-Score, Knockout-Pruefung und Ranking -- in Sekunden statt Stunden.", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/></svg>' },
];
---

<ProduktLayout
  title="Automatisierung & Workflows – KI-gestuetzte Prozesse | ShortSelect"
  description="Automatisieren Sie repetitive Recruiting-Aufgaben: Auto-E-Mails, Stage-Trigger, Screening-Automation und KI-gestuetzte Workflows."
  canonical="https://shortselect.com/produkt/automatisierung"
  badgeText="Automatisierung"
  heroTitle="KI-gestuetzte Automatisierung: Workflows die"
  heroHighlight="arbeiten"
  heroSuffix="."
  heroSubtitle="Automatisieren Sie repetitive Aufgaben -- von E-Mail-Versand bis Stage-Wechsel. Mehr Zeit fuer das, was zaehlt."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>'
  features={features}
  featuresSectionTitle="Automatisieren statt manuell arbeiten"
  featuresSectionSubtitle="Von E-Mail-Versand bis KI-Screening -- lassen Sie Workflows die Routinearbeit erledigen."
  featuresBadge="Funktionen"
>
  <section class="py-16 md:py-24 bg-gradient-to-br from-primary via-primary/90 to-accent text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:24px_24px] opacity-30"></div>
    <div class="container relative mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-12 text-center">
        {[
          { value: "80%", label: "weniger manuelle Arbeit" },
          { value: "2x", label: "schnellere Time-to-Hire" },
          { value: "0", label: "vergessene Follow-ups" },
        ].map((stat, i) => (
          <div data-reveal data-reveal-delay={`${i * 100}`} class="space-y-2">
            <div class="text-5xl md:text-6xl font-display font-bold">{stat.value}</div>
            <p class="text-lg text-white/80">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</ProduktLayout>
