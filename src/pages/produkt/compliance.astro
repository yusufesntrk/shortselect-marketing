---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  { title: "Automatische Löschfristen", description: "Kandidatendaten werden nach konfigurierbarer Frist automatisch gelöscht", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' },
  { title: "Einwilligungsmanagement", description: "Rechtsgrundlage pro Kandidat dokumentiert -- Opt-in und Opt-out", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="m9 12 2 2 4-4"/></svg>' },
  { title: "Retention Consent", description: "Kandidaten können per Link der weiteren Speicherung zustimmen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m9 15 2 2 4-4"/></svg>' },
  { title: "Audit-Trail", description: "Lückenlose Protokollierung aller Datenzugriffe und Änderungen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M15 2H9a1 1 0 0 0-1 1v2a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1Z"/></svg>' },
  { title: "Rollenbasierte Zugriffe", description: "RBAC mit 5 Rollen -- vom Super-Admin bis Readonly", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
  { title: "DSGVO-konforme KI", description: "Alle KI-Entscheidungen nachvollziehbar, alle Daten in der EU, kein Training auf Kundendaten", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/></svg>' },
];
---

<ProduktLayout
  title="DSGVO & Compliance – Datenschutz im Recruiting | ShortSelect"
  description="DSGVO-konformes Recruiting: Automatische Löschfristen, Einwilligungsmanagement, Audit-Trail und Datentrennung. Datenschutz by Design."
  canonical="https://shortselect.com/produkt/compliance"
  badgeText="Datenschutz"
  heroTitle="DSGVO-konform. Ohne"
  heroHighlight="Kompromisse"
  heroSuffix="."
  heroSubtitle="Automatische Löschfristen, Einwilligungsmanagement und vollständige Audit-Trails -- Datenschutz by Design."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>'
  features={features}
  featuresSectionTitle="Datenschutz ohne Kompromisse"
  featuresSectionSubtitle="Von automatischen Löschfristen bis zur DSGVO-konformen KI -- alles was Sie für rechtssicheres Recruiting brauchen."
  featuresBadge="Features"
>
  <Fragment slot="before-features">
    <section class="py-20 md:py-28 bg-muted/30 relative overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center max-w-3xl mx-auto mb-16">
          <span class="inline-block mb-4 px-3 py-1 text-xs font-medium rounded-full border border-primary/20 text-primary">Compliance</span>
          <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight mb-4">Compliance-Checklist</h2>
          <p class="text-lg text-muted-foreground">Alles auf einen Blick -- Ihr DSGVO-Status in Echtzeit.</p>
        </div>
        <div class="max-w-2xl mx-auto space-y-3">
          {[
            { label: "Einwilligung eingeholt", status: true },
            { label: "Rechtsgrundlage dokumentiert", status: true },
            { label: "Loeschfrist konfiguriert (90 Tage)", status: true },
            { label: "Audit-Trail aktiv", status: true },
            { label: "Datenzugriff protokolliert", status: true },
            { label: "Letzte Prüfung: vor 3 Tagen", status: true },
          ].map((item, i) => (
            <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 flex items-center gap-3 p-3 rounded-lg bg-green-500/5 border border-green-500/10" style={`transition-delay: ${(i % 3) * 100}ms;`}>
              <div class="h-5 w-5 rounded-full bg-green-500 text-white flex items-center justify-center flex-shrink-0">
                <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              </div>
              <span class="text-sm">{item.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </Fragment>

  <!-- Trust Badges -->
  <section class="py-16 md:py-24 text-white relative overflow-hidden" style="background: linear-gradient(to bottom right, hsl(var(--primary)), hsl(var(--primary) / 0.9), hsl(var(--accent)));">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:24px_24px] opacity-30"></div>
    <div class="container relative mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 max-w-3xl mx-auto text-center">
        {[
          { label: "EU-Server" },
          { label: "DSGVO-konform" },
          { label: "ISO 27001" },
          { label: "Verschluesselt" },
        ].map((badge, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 space-y-3" style={`transition-delay: ${i * 100}ms;`}>
            <div class="mx-auto w-16 h-16 rounded-full bg-white/10 flex items-center justify-center">
              <svg class="h-8 w-8" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <p class="text-sm font-medium text-white/90">{badge.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</ProduktLayout>

<script is:inline>
(function() {
  var items = document.querySelectorAll('.reveal-item');
  if (!items.length) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function(item) { observer.observe(item); });
})();
</script>
