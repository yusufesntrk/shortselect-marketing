---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  { title: "Ein-Klick-Verteilung", description: "Stellenanzeige auf 10+ Jobbörsen gleichzeitig veröffentlichen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>' },
  { title: "Branded Karriereseite", description: "Eigene Karriereseite mit Ihrem Branding -- automatisch synchronisiert", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>' },
  { title: "Widget-Integration", description: "Embeddable Job-Widget für Ihre Website oder die Ihrer Kunden", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>' },
  { title: "Social Sharing", description: "Jobs direkt auf LinkedIn, XING und Social Media teilen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>' },
  { title: "Tracking & Analytics", description: "Sehen Sie welche Kanäle die besten Kandidaten liefern", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>' },
  { title: "Template-System", description: "Stellenanzeigen-Vorlagen für wiederkehrende Positionen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>' },
];
---

<ProduktLayout
  title="Multiposting – Stellenanzeigen auf 10+ Jobbörsen | ShortSelect"
  description="Veröffentlichen Sie Stellenanzeigen mit einem Klick auf StepStone, Indeed, LinkedIn, XING und mehr. Tracking & Analytics inklusive."
  canonical="https://www.shortselect.com/produkt/multiposting"
  badgeText="Reichweite"
  heroTitle="Multiposting: Eine Stelle,"
  heroHighlight="alle Kanäle"
  heroSuffix="."
  heroSubtitle="Veröffentlichen Sie Ihre Stellenanzeige mit einem Klick auf 10+ Jobbörsen -- und sehen Sie, welche Kanäle die besten Kandidaten liefern."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>'
  features={features}
  featuresSectionTitle="Maximale Reichweite, minimaler Aufwand"
  featuresSectionSubtitle="Ein-Klick-Verteilung, Social Sharing und detailliertes Tracking -- für die optimale Kandidatenreichweite."
  featuresBadge="Features"
>
  <section class="py-16 md:py-24 text-white relative overflow-hidden" style="background: linear-gradient(to bottom right, hsl(var(--primary)), hsl(var(--primary) / 0.9), hsl(var(--accent)));">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:24px_24px] opacity-30"></div>
    <div class="container relative mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-12 text-center">
        {[
          { value: "10+", label: "Jobbörsen" },
          { value: "1", label: "Klick" },
          { value: "100%", label: "Synchronisation" },
        ].map((stat, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 space-y-2" style={`transition-delay: ${i * 100}ms;`}>
            <div class="text-5xl md:text-6xl font-display font-bold">{stat.value}</div>
            <p class="text-lg text-white/80">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</ProduktLayout>

<script is:inline>
(function() {
  var items = document.querySelectorAll('.reveal-item');
  if (!items.length) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function(item) { observer.observe(item); });
})();
</script>
