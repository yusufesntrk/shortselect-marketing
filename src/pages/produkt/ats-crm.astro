---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  {
    title: "Kanban Pipeline",
    description: "Visualisieren Sie Ihren Recruiting-Prozess mit flexiblen Kanban-Boards. Bewegen Sie Kandidaten per Drag & Drop durch Ihre Phasen.",
    icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>',
  },
  {
    title: "Kandidatenmanagement",
    description: "Alle Kandidatendaten an einem Ort. Profile, Dokumente, Kommunikation und Bewertungen -- immer griffbereit.",
    icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  },
  {
    title: "E-Mail Integration",
    description: "Senden und empfangen Sie E-Mails direkt aus dem ATS. Templates und automatische Nachverfolgung inklusive.",
    icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>',
  },
  {
    title: "Interview Scheduling",
    description: "Koordinieren Sie Interviews mithilfe von Kalender-Sync. Kandidaten buchen ihre bevorzugten Slots selbst.",
    icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/></svg>',
  },
  {
    title: "Team Collaboration",
    description: "Teilen Sie Kandidaten, hinterlassen Sie Bewertungen und arbeiten Sie in Echtzeit mit Ihrem Team zusammen.",
    icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>',
  },
  {
    title: "Analytics & Reports",
    description: "Verstehen Sie Ihre Pipeline mit detaillierten Reports. Time-to-Hire, Source-Analyse und individuelle KPIs.",
    icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>',
  },
];

const timelineSteps = [
  { label: "Stelle ausschreiben", detail: "Job in Sekunden live auf Ihrer Karriereseite." },
  { label: "Bewerbungen screenen", detail: "KI-gestützte Vorauswahl spart Stunden." },
  { label: "Interviews führen", detail: "Koordination & Feedback an einem Ort." },
  { label: "Einstellen", detail: "Offer versenden und Onboarding starten." },
];
---

<ProduktLayout
  title="ATS & CRM Plattform – Bewerbermanagement | ShortSelect"
  description="All-in-One ATS & CRM für modernes Recruiting. Kanban Pipeline, Kandidatenmanagement, E-Mail Integration und Team Collaboration in einer Plattform."
  badgeText="All-in-One Bewerbermanagement"
  heroTitle="Ihr ATS, das"
  heroHighlight="mitdenkt"
  heroSuffix="."
  heroSubtitle="Schluss mit Tabellen-Chaos und verlorenen E-Mails. ShortSelect vereint Ihre gesamte Recruiting-Pipeline in einer intuitiven Plattform -- damit Sie sich auf das konzentrieren, was wirklich zählt: die besten Talente finden."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/></svg>'
  features={features}
  featuresSectionTitle="Alles, was Ihr Recruiting braucht"
  featuresSectionSubtitle="Sechs leistungsstarke Module, die nahtlos zusammenarbeiten. Kein Wechsel zwischen Tools -- nur ein einziger, klarer Workflow."
  featuresBadge="Features"
>
  <!-- Problem Section -->
  <Fragment slot="before-features">
    <section id="atscrm-problem" class="py-20 md:py-28 bg-muted/30 relative overflow-hidden">
      <div class="absolute -top-32 -right-32 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="container mx-auto px-4">
        <div id="atscrm-problem-header" class="text-center max-w-3xl mx-auto mb-16 transition-all duration-700" style="opacity: 0; transform: translateY(2rem);">
          <span class="inline-block mb-4 px-3 py-1 text-xs font-medium rounded-full border border-primary/20 text-primary">Das Problem</span>
          <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight mb-4">
            Recruiting-Chaos kostet Sie Talente
          </h2>
          <p class="text-lg text-muted-foreground">
            Verstreute Tools, verlorene E-Mails und endlose Tabellen. So sieht der Alltag vieler Recruiter aus -- und so gehen die besten Kandidaten verloren.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
          <!-- BEFORE -->
          <div class="atscrm-problem-card rounded-xl border border-destructive/20 bg-destructive/5 p-8 transition-all duration-500" style="opacity: 0; transform: translateY(3rem); transition-delay: 150ms;">
            <div class="flex items-center gap-3 mb-6">
              <div class="h-10 w-10 rounded-full bg-destructive/10 flex items-center justify-center">
                <svg class="h-5 w-5 text-destructive" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
              </div>
              <h3 class="text-xl font-display font-bold text-destructive">Vorher: Chaos</h3>
            </div>
            <div class="space-y-3">
              {["Excel-Listen", "E-Mail-Postfach", "WhatsApp", "Kalender"].map((tool) => (
                <div class="flex items-center gap-3 p-3 rounded-lg bg-background/80 border border-border/50">
                  <span class="text-sm text-muted-foreground">{tool}</span>
                </div>
              ))}
            </div>
            <p class="mt-6 text-sm text-muted-foreground italic">
              "Wo war nochmal die Bewerbung von Frau Mueller? In der Mail? Im Excel? Auf WhatsApp?"
            </p>
          </div>

          <!-- AFTER -->
          <div class="atscrm-problem-card rounded-xl border border-primary/20 bg-primary/5 p-8 transition-all duration-500" style="opacity: 0; transform: translateY(3rem); transition-delay: 300ms;">
            <div class="flex items-center gap-3 mb-6">
              <div class="h-10 w-10 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="h-5 w-5 text-primary" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
              </div>
              <h3 class="text-xl font-display font-bold text-primary">Nachher: Klarheit</h3>
            </div>
            <div class="space-y-3">
              {["Alles in einer Plattform", "Automatische E-Mail-Zuordnung", "Kanban-Pipeline pro Stelle", "Team-Kommunikation integriert"].map((item) => (
                <div class="flex items-center gap-3 p-3 rounded-lg bg-background/80 border border-primary/10">
                  <svg class="h-5 w-5 text-primary flex-shrink-0" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                  <span class="text-sm font-medium">{item}</span>
                </div>
              ))}
            </div>
            <p class="mt-6 text-sm text-muted-foreground italic">
              "Ein Klick -- und ich sehe alles zu jedem Kandidaten."
            </p>
          </div>
        </div>
      </div>
    </section>
  </Fragment>

  <!-- Timeline Section -->
  <section id="atscrm-timeline" class="py-20 md:py-28 bg-muted/30 relative overflow-hidden">
    <div class="absolute -bottom-32 -left-32 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
    <div class="container mx-auto px-4">
      <div id="atscrm-timeline-header" class="text-center max-w-3xl mx-auto mb-16 transition-all duration-700" style="opacity: 0; transform: translateY(2rem);">
        <span class="inline-block mb-4 px-3 py-1 text-xs font-medium rounded-full border border-primary/20 text-primary">Prozess</span>
        <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight mb-4">
          Von der Ausschreibung zur Einstellung
        </h2>
        <p class="text-lg text-muted-foreground">
          Vier einfache Schritte -- ShortSelect begleitet Sie durch den gesamten Recruiting-Prozess.
        </p>
      </div>

      <div class="max-w-2xl mx-auto space-y-12">
        {timelineSteps.map((step, i) => (
          <div class="atscrm-timeline-step relative flex items-start gap-6 md:gap-8 transition-all duration-500" style={`opacity: 0; transform: translateY(3rem); transition-delay: ${150 + i * 100}ms;`}
            <div class="relative z-10 flex-shrink-0">
              <div class="h-12 w-12 md:h-16 md:w-16 rounded-full bg-primary text-white shadow-lg shadow-primary/30 flex items-center justify-center font-display font-bold text-lg">
                {i + 1}
              </div>
            </div>
            <div class="pt-2 md:pt-4">
              <span class="text-xs font-medium text-primary uppercase tracking-wider">Schritt {i + 1}</span>
              <h3 class="text-xl font-display font-bold mt-1">{step.label}</h3>
              <p class="text-muted-foreground mt-1">{step.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section id="atscrm-stats" class="py-16 md:py-24 text-white relative overflow-hidden" style="background: linear-gradient(to bottom right, hsl(var(--primary)), hsl(var(--primary) / 0.9), hsl(var(--accent)));">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-10 left-10 w-64 h-64 bg-white/5 rounded-full blur-3xl animate-float-slow"></div>
      <div class="absolute bottom-10 right-10 w-80 h-80 bg-white/5 rounded-full blur-3xl animate-float-slow" style="animation-delay: -3s;"></div>
    </div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:24px_24px] opacity-30"></div>

    <div class="container relative mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-12 text-center">
        {[
          { value: "10.000+", label: "Kandidaten verwaltet" },
          { value: "50%", label: "Zeitersparnis" },
          { value: "500+", label: "Erfolgreiche Placements" },
        ].map((stat, i) => (
          <div class="atscrm-stat-item space-y-2 transition-all duration-500" style={`opacity: 0; transform: translateY(3rem); transition-delay: ${150 + i * 100}ms;`}
            <div class="text-5xl md:text-6xl lg:text-7xl font-display font-bold">{stat.value}</div>
            <p class="text-lg text-white/80">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</ProduktLayout>

<script is:inline>
(function() {
  function observeSection(sectionId, headerId, cardSelector) {
    var section = document.getElementById(sectionId);
    if (!section) return;
    var header = headerId ? document.getElementById(headerId) : null;
    var cards = cardSelector ? section.querySelectorAll(cardSelector) : [];
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          if (header) { header.style.opacity = '1'; header.style.transform = 'translateY(0)'; }
          cards.forEach(function(card) { card.style.opacity = '1'; card.style.transform = 'translateY(0)'; });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    observer.observe(section);
  }

  observeSection('atscrm-problem', 'atscrm-problem-header', '.atscrm-problem-card');
  observeSection('atscrm-timeline', 'atscrm-timeline-header', '.atscrm-timeline-step');
  observeSection('atscrm-stats', null, '.atscrm-stat-item');
})();
</script>
