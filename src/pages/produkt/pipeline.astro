---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  { title: "Drag & Drop", description: "Kandidaten per Drag & Drop durch die Pipeline schieben", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="1"/><circle cx="9" cy="5" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="19" r="1"/></svg>' },
  { title: "Custom Stages", description: "Eigene Pipeline-Stufen für jeden Job definierbar", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>' },
  { title: "Auto-Notifications", description: "Automatische E-Mails bei Stage-Wechsel", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>' },
  { title: "Knockout Questions", description: "Disqualifizierende Fragen filtern automatisch", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m15 9-6 6"/><path d="m9 9 6 6"/></svg>' },
  { title: "Bulk Actions", description: "Mehrere Kandidaten gleichzeitig verschieben oder kontaktieren", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 18H3"/><path d="m15 18 2 2 4-4"/><path d="M16 12H3"/><path d="M16 6H3"/></svg>' },
  { title: "Pipeline Templates", description: "Bewährte Pipelines als Vorlage speichern und wiederverwenden", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>' },
];
---

<ProduktLayout
  title="Recruiting Pipeline – Kanban Board & Visual Recruiting | ShortSelect"
  description="Visualisieren Sie Ihren Recruiting-Prozess mit Kanban Pipeline. Drag & Drop, Custom Stages, Bulk Actions und Pipeline Templates."
  canonical="https://shortselect.com/produkt/pipeline"
  badgeText="Visual Recruiting"
  heroTitle="Kanban Pipeline: Recruiting wird"
  heroHighlight="sichtbar"
  heroSuffix="."
  heroSubtitle="Drag & Drop statt Chaos. Sehen Sie auf einen Blick, wo jeder Kandidat steht."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="1"/><circle cx="9" cy="5" r="1"/><circle cx="9" cy="19" r="1"/><circle cx="15" cy="12" r="1"/><circle cx="15" cy="5" r="1"/><circle cx="15" cy="19" r="1"/></svg>'
  features={features}
  featuresSectionTitle="Mehr als nur ein Board"
  featuresSectionSubtitle="Automationen, Templates und Bulk-Aktionen machen Ihre Pipeline zum kraftvollen Recruiting-Motor."
  featuresBadge="Funktionen"
/>
