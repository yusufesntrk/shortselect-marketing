---

<ProduktLayout
  title="Interview Scheduling – Termine automatisch koordinieren | ShortSelect"
  description="Schluss mit E-Mail-Ping-Pong: Self-Service Buchung, Kalender-Sync, automatische Erinnerungen und Scheduling Links fuer effiziente Interviews."
  canonical="https://shortselect.com/produkt/interviews"
  badgeText="Smart Scheduling"
  heroTitle="Interview Scheduling: Schluss mit"
  heroHighlight="E-Mail-Ping-Pong"
  heroSuffix="."
  heroSubtitle="Kandidaten buchen selbst -- Sie fuehren Interviews."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>'
  features={features}
  featuresSectionTitle="Interviews effizient planen"
  featuresSectionSubtitle="Self-Service Buchung, Kalender-Sync und automatische Erinnerungen -- fuer stressfreie Interview-Koordination."
