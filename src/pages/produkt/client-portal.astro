---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  { title: "Branded Portal", description: "Jeder Mandant sieht sein eigenes Branding", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20a7 7 0 1 0 0-14 7 7 0 0 0 0 14Z"/><path d="M12 12m-2 0a2 2 0 1 0 4 0a2 2 0 1 0-4 0"/></svg>' },
  { title: "Shortlist-Sharing", description: "Kandidaten-Profile mit einem Klick teilen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/></svg>' },
  { title: "Live Feedback", description: "Kunden bewerten Kandidaten direkt im Portal", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>' },
  { title: "Anonymisierung", description: "Kandidaten-Daten optional anonymisieren (PII Masking)", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" x2="23" y1="1" y2="23"/></svg>' },
  { title: "Aktivitaets-Log", description: "Sehen Sie, welche Kandidaten Ihr Kunde angesehen hat", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v5h5"/><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8"/><path d="M12 7v5l4 2"/></svg>' },
  { title: "Separate Zugaenge", description: "Individuelle Logins pro Ansprechpartner", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="15.5" r="5.5"/><path d="m21 2-9.6 9.6"/><path d="m15.5 7.5 3 3L22 7l-3-3"/></svg>' },
];

const steps = [
  { title: "Mandant einladen", description: "Erstellen Sie einen Zugang fuer Ihren Kunden mit persoenlichem Login." },
  { title: "Shortlist freigeben", description: "Waehlen Sie die besten Kandidaten aus und teilen Sie die Shortlist." },
  { title: "Kunde bewertet", description: "Ihr Kunde gibt Feedback direkt im Portal -- in Echtzeit." },
  { title: "Placement", description: "Schnellere Entscheidungen fuehren zu schnelleren Placements." },
];
---

<ProduktLayout
  title="Client Portal – Mandanten-Portal fuer Personalagenturen | ShortSelect"
  description="Client Portal fuer Recruiting-Agenturen: Shortlist-Sharing, Live-Feedback, Anonymisierung und Branded Portal fuer Ihre Mandanten."
  canonical="https://shortselect.com/produkt/client-portal"
  badgeText="Fuer Agenturen"
  heroTitle="Client Portal: Transparenz schafft"
  heroHighlight="Vertrauen"
  heroSuffix="."
  heroSubtitle="Geben Sie Ihren Kunden Zugang zu Shortlists und erhalten Sie Feedback in Echtzeit."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/></svg>'
  features={features}
  featuresSectionTitle="Professionell praesentieren, effizient zusammenarbeiten"
  featuresSectionSubtitle="Branding, Anonymisierung und Live-Feedback -- alles, was Ihre Mandanten erwarten."
  featuresBadge="Features"
>
  <Fragment slot="before-features">
    <section class="py-20 md:py-28 bg-muted/30 relative overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center max-w-3xl mx-auto mb-16">
          <span class="inline-block mb-4 px-3 py-1 text-xs font-medium rounded-full border border-primary/20 text-primary">Workflow</span>
          <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight mb-4">In 4 Schritten zum Placement</h2>
          <p class="text-lg text-muted-foreground">Vom Einladen bis zum Placement -- transparent und effizient.</p>
        </div>
        <div class="grid md:grid-cols-4 gap-8 max-w-5xl mx-auto">
          {steps.map((step, i) => (
            <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center" style={`transition-delay: ${i * 100}ms;`}>
              <div class="relative mx-auto mb-6 w-24 h-24 rounded-full bg-background border-2 border-primary/20 flex items-center justify-center shadow-lg">
                <span class="text-2xl font-display font-bold text-primary">{i + 1}</span>
              </div>
              <h3 class="text-lg font-display font-bold mb-2">{step.title}</h3>
              <p class="text-sm text-muted-foreground">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </Fragment>
</ProduktLayout>

<script is:inline>
(function() {
  var items = document.querySelectorAll('.reveal-item');
  if (!items.length) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function(item) { observer.observe(item); });
})();
</script>
