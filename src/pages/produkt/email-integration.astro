---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  { title: "Gmail 2-Way-Sync", description: "Alle E-Mails automatisch im Kandidaten-Profil", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>' },
  { title: "E-Mail Templates", description: "Professionelle Vorlagen für jede Situation", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>' },
  { title: "Auto-Notifications", description: "Automatische Status-Updates bei Pipeline-Wechsel", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>' },
  { title: "Massen-E-Mails", description: "Personalisierte E-Mails an mehrere Kandidaten gleichzeitig", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>' },
  { title: "Tracking", description: "Sehen Sie, ob und wann Ihre E-Mail gelesen wurde", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>' },
  { title: "Thread-Ansicht", description: "Komplette Kommunikationshistorie pro Kandidat", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>' },
];
---

<ProduktLayout
  title="E-Mail Integration – Gmail Sync & Templates | ShortSelect"
  description="Gmail 2-Way-Sync, E-Mail Templates, automatische Benachrichtigungen und Tracking. Kommunizieren Sie direkt aus ShortSelect."
  canonical="https://www.shortselect.com/produkt/email-integration"
  badgeText="Communication"
  heroTitle="E-Mail Integration: Kommunikation ohne"
  heroHighlight="Medienbruch"
  heroSuffix="."
  heroSubtitle="Gmail 2-Way-Sync, Templates und automatische Benachrichtigungen -- alles in ShortSelect."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>'
  features={features}
  featuresSectionTitle="E-Mail, die zum Recruiting gehört"
  featuresSectionSubtitle="Versenden, empfangen und tracken Sie E-Mails direkt im Kandidaten-Profil -- ohne Wechsel zwischen Tools."
  featuresBadge="Features"
/>
