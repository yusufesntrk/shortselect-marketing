---
import ProduktLayout from '../../layouts/ProduktLayout.astro';

const features = [
  { title: "Echtzeit-Dashboards", description: "Live-Daten zu allen Recruiting-KPIs", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/></svg>' },
  { title: "Custom Reports", description: "Individuelle Reports per Drag & Drop zusammenstellen", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M8 18v-1"/><path d="M12 18v-6"/><path d="M16 18v-3"/></svg>' },
  { title: "Export", description: "CSV und PDF Export für Stakeholder", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>' },
  { title: "Mandanten-Reports", description: "Performance pro Kunde auf einen Blick", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/></svg>' },
  { title: "Trend-Analyse", description: "Erkennen Sie Trends bevor sie zum Problem werden", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>' },
  { title: "Team-Performance", description: "Vergleichen Sie die Performance Ihres Teams", icon: '<svg class="h-6 w-6 text-primary group-hover:text-white transition-colors" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' },
];
---

<ProduktLayout
  title="Analytics & Reports – Recruiting-KPIs & Dashboards | ShortSelect"
  description="Echtzeit-Dashboards und Recruiting-Reports: Time-to-Hire, Cost-per-Hire, Pipeline-Conversion und Source-Performance auf einen Blick."
  canonical="https://shortselect.com/produkt/analytics"
  badgeText="Business Intelligence"
  heroTitle="Analytics: Recruiting-Performance auf einen"
  heroHighlight="Blick"
  heroSuffix="."
  heroSubtitle="KPIs, Dashboards und Reports -- für datenbasierte Entscheidungen."
  heroIcon='<svg class="h-4 w-4 text-primary animate-pulse" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/></svg>'
  features={features}
  featuresSectionTitle="Mehr als nur Zahlen"
  featuresSectionSubtitle="Dashboards, Reports und Exporte -- alles, was Sie für datenbasierte Entscheidungen brauchen."
  featuresBadge="Funktionen"
>
  <Fragment slot="before-features">
    <section class="py-20 md:py-28 bg-muted/30 relative overflow-hidden">
      <div class="container mx-auto px-4">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center max-w-3xl mx-auto mb-16">
          <span class="inline-block mb-4 px-3 py-1 text-xs font-medium rounded-full border border-primary/20 text-primary">KPIs</span>
          <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight mb-4">Die wichtigsten Recruiting-Metriken</h2>
          <p class="text-lg text-muted-foreground">Messen Sie, was zählt -- und optimieren Sie Ihren Recruiting-Prozess kontinuierlich.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          {[
            { title: "Time-to-Hire", value: "18 Tage", description: "Durchschnittliche Zeit von Stellenausschreibung bis Einstellung", color: "text-blue-500 bg-blue-500/10" },
            { title: "Cost-per-Hire", value: "2.400 EUR", description: "Kosten pro erfolgreicher Einstellung ueber alle Kanäle", color: "text-green-500 bg-green-500/10" },
            { title: "Pipeline-Conversion", value: "67%", description: "Anteil der Bewerber, die erfolgreich eingestellt werden", color: "text-primary bg-primary/10" },
            { title: "Source-Performance", value: "5 Kanäle", description: "Performance-Vergleich Ihrer Recruiting-Kanäle", color: "text-accent bg-accent/10" },
          ].map((kpi, i) => (
            <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 rounded-xl border bg-card p-8 hover:shadow-xl hover:border-primary/20 transition-all duration-300" style={`transition-delay: ${i * 100}ms;`}>
              <div class="flex items-center gap-4 mb-4">
                <div class={`h-14 w-14 rounded-xl ${kpi.color} flex items-center justify-center`}>
                  <span class="text-lg font-bold">{kpi.value.split(' ')[0]}</span>
                </div>
                <div>
                  <h3 class="text-xl font-display font-bold">{kpi.title}</h3>
                  <div class="text-2xl font-display font-bold text-primary mt-1">{kpi.value}</div>
                </div>
              </div>
              <p class="text-sm text-muted-foreground leading-relaxed">{kpi.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </Fragment>
</ProduktLayout>

<script is:inline>
(function() {
  var items = document.querySelectorAll('.reveal-item');
  if (!items.length) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function(item) { observer.observe(item); });
})();
</script>
