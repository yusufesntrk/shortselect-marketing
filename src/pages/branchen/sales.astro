---
import BrancheLayout from '../../layouts/BrancheLayout.astro';

const painPoints = [
  { title: "Hohe Fluktuation", description: "Vertrieb hat die hoechste Fluktuation. ständig offene Positionen.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" x2="22" y1="11" y2="11"/>' },
  { title: "Performance schwer messbar", description: "Track Record und Abschlussquoten lassen sich schwer im CV prüfen.", iconPath: '<line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/>' },
  { title: "Schnelle Entscheidungen", description: "Top-Seller sind maximal 2 Wochen auf dem Markt.", iconPath: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' },
];

const features = [
  { title: "KI-Scoring", description: "Automatische Bewertung von Sales-Profilen nach Erfahrung, Branche und Abschlussstaerke.", iconPath: '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>' },
  { title: "Pipeline-Speed", description: "Vom Erstgespraech zum Angebot in unter 48 Stunden. schneller als der Wettbewerb.", iconPath: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>' },
  { title: "Talent Pool Sales", description: "Exklusiver Pool mit vorqualifizierten Vertriebsprofis. sofort ansprechbar.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { title: "Quick-Screening", description: "3 gezielte Fragen: Abschlussquote? Branchenerfahrung? Gehaltsvorstellung?", iconPath: '<path d="M11 18H3"/><path d="m15 18 2 2 4-4"/><path d="M16 12H3"/><path d="M16 6H3"/>' },
  { title: "Team-Feedback", description: "Strukturiertes Feedback vom gesamten Hiring-Team. in Echtzeit.", iconPath: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/>' },
  { title: "Performance Analytics", description: "Time-to-Hire, Cost-per-Hire und Pipeline-Conversion auf einen Blick.", iconPath: '<path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/>' },
];

const steps = [
  { step: "1", title: "Profil definieren", description: "Ideales Sales-Profil festlegen: Branche, Erfahrung, Vergütung, KPIs." },
  { step: "2", title: "Aktive Ansprache", description: "Top-Vertriebler direkt ansprechen. per E-Mail, LinkedIn oder Telefon." },
  { step: "3", title: "Schnell-Interview", description: "Strukturierte Kurzinterviews mit Fokus auf Sales-KPIs und Culture Fit." },
  { step: "4", title: "Schnelles Angebot", description: "Angebot innerhalb von 48 Stunden. bevor die Konkurrenz zuschlaegt." },
];
---

<BrancheLayout
  title="Sales Recruiting Software | Vertriebsprofis finden"
  description="Sales-Recruiting: KI-Scoring, Pipeline-Speed, Quick-Screening. Top-Vertriebler schneller finden und einstellen."
  badgeText="Sales & Vertrieb"
  badgeIcon='<path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/>'
  headline="Sales & Vertrieb:"
  highlightedWord="Top-Seller"
  headlineSuffix="finden, bevor es die Konkurrenz tut."
  subline="Account Manager, Sales Director, BDR, mit ShortSelect finden Sie Vertriebsprofis schneller als der Wettbewerb."
  painBadge="Die Realität"
  painTitle="Warum Sales-Recruiting"
  painHighlight="anders"
  painPoints={painPoints}
  steps={steps}
  stepsSubline="4 Schritte vom idealen Profil bis zum schnellen Angebot."
  featuresTitle="Gemacht für"
  featuresHighlight="Sales"
  features={features}
/>
