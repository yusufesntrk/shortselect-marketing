---
import BrancheLayout from '../../layouts/BrancheLayout.astro';

const painPoints = [
  { title: "Fachkräftemangel", description: "87% der IT-Stellen bleiben länger als 3 Monate unbesetzt.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" x2="22" y1="11" y2="11"/>' },
  { title: "Passive Kandidaten", description: "Die besten Entwickler suchen nicht aktiv.", iconPath: '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" x2="23" y1="1" y2="23"/>' },
  { title: "Technische Bewertung", description: "Wie bewerten Sie Skills, die Sie selbst nicht haben?", iconPath: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' },
];

const features = [
