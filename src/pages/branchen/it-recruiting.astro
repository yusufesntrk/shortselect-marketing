  { title: "Talent Pools nach Tech Stack", description: "Pools für Frontend, Backend, DevOps, Data.", iconPath: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m6.08 9.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/><path d="m6.08 14.5-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/>' },
  { title: "Schnelle Bewerbung", description: "Entwickler hassen lange Formulare. Ein-Klick-Bewerbung.", iconPath: '<path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>' },
  { title: "GitHub/LinkedIn Import", description: "CV-Upload aus allen Formaten, auch LinkedIn-PDFs.", iconPath: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>' },
  { title: "Screening Fragen", description: "Technische Screening-Fragen vor dem Erstgespraech.", iconPath: '<path d="M9 11 5 15l4 4"/><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>' },
  { title: "Analytics pro Tech-Rolle", description: "Time-to-Hire Benchmarks für jede Tech-Rolle.", iconPath: '<line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/>' },
];
---

<BrancheLayout
  title="IT-Recruiting Software | Tech-Talente finden mit ShortSelect"
  description="IT-Recruiting mit KI-Skills-Matching auf Framework-Level. Software Engineers, DevOps, Data Scientists schneller finden."
  badgeText="IT & Tech"
  badgeIcon='<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>'
  headline="IT-Recruiting: Die besten"
  highlightedWord="Entwickler"
  headlineSuffix="finden."
  subline="Software Engineers, DevOps, Data Scientists, mit ShortSelect finden Sie Tech-Talente schneller."
  painBadge="Die Herausforderung"
  painTitle="Warum IT-Recruiting so"
  painHighlight="schwer"
  painPoints={painPoints}
  featuresTitle="Features für"
  featuresHighlight="IT-Recruiting"
  features={features}
/>
