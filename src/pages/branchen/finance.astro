---
import BrancheLayout from '../../layouts/BrancheLayout.astro';

const painPoints = [
  { title: "Vertraulichkeit", description: "Kandidaten wollen diskret wechseln — klassische Portale sind zu oeffentlich.", iconPath: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>' },
  { title: "Regulatorik", description: "BaFin, MiFID, Compliance — Qualifikationen muessen dokumentiert werden.", iconPath: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>' },
  { title: "War for Talent", description: "Big 4, Banken und Fintechs konkurrieren um denselben Talentpool.", iconPath: '<circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>' },
];

const features = [
  { title: "Diskrete Stellenanzeigen", description: "Positionen nur fuer eingeladene Kandidaten sichtbar.", iconPath: '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" x2="23" y1="1" y2="23"/>' },
  { title: "Compliance-Tracking", description: "Lizenzen und Zertifizierungen als Pflichtfelder.", iconPath: '<path d="M9 11 5 15l4 4"/><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>' },
  { title: "Talent Pool Finance", description: "Spezialisierter Pool fuer Finance-Professionals.", iconPath: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/>' },
  { title: "Executive Search", description: "Pipeline optimiert fuer C-Level und Director-Positionen.", iconPath: '<path d="M2 4v16"/><path d="M6 2v4"/><path d="M6 18v4"/><path d="M6 10v4"/><path d="M18 2v4"/><path d="M18 18v4"/><path d="M18 10v4"/><path d="M22 4v16"/><path d="M2 4h4"/><path d="M2 20h4"/><path d="M18 4h4"/><path d="M18 20h4"/>' },
  { title: "Client Portal", description: "Hiring Manager sehen nur ihre Kandidaten — DSGVO-konform.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { title: "Analytics", description: "Time-to-Hire, Cost-per-Hire und Kanal-Performance.", iconPath: '<path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/>' },
];

const steps = [
  { step: "1", title: "Diskrete Pipeline", description: "Vertrauliche Stellenanzeigen mit Zugangsschutz." },
  { step: "2", title: "Qualifikations-Screening", description: "Lizenzen, Zertifikate und Erfahrung systematisch pruefen." },
  { step: "3", title: "KI-Matching", description: "Passive Kandidaten aus dem Talent Pool automatisch matchen." },
  { step: "4", title: "Schneller Abschluss", description: "Vom Erstkontakt zum Angebot in unter 2 Wochen." },
];
---

<BrancheLayout
  title="Finance & Banking Recruiting | Diskret und Compliance-ready"
  description="Finance-Recruiting: Diskrete Stellenanzeigen, Compliance-Tracking, Executive Search. Top-Talente in einem umkaempften Markt finden."
  badgeText="Finance & Banking"
  badgeIcon='<line x1="3" x2="21" y1="22" y2="22"/><line x1="6" x2="6" y1="18" y2="11"/><line x1="10" x2="10" y1="18" y2="11"/><line x1="14" x2="14" y1="18" y2="11"/><line x1="18" x2="18" y1="18" y2="11"/><polygon points="12 2 20 7 4 7"/>'
  headline="Finance & Banking:"
  highlightedWord="Top-Talente"
  headlineSuffix="in einem umkaempften Markt."
  subline="Compliance-Anforderungen, hohe Gehaelter, diskrete Kandidaten — Finance-Recruiting braucht Praezision."
  painBadge="Die Realitaet"
  painTitle="Warum klassisches Recruiting in"
  painHighlight="Finance"
  painPoints={painPoints}
  steps={steps}
  stepsSubline="4 Schritte von der vertraulichen Suche bis zur Besetzung."
  featuresTitle="Gemacht fuer"
  featuresHighlight="Finance"
  features={features}
/>
