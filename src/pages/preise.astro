---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import FAQSection from '../components/landing/FAQSection.astro';
import CTASection from '../components/landing/CTASection.astro';
import {
  PIONEER_PRICE_EUR,
  PIONEER_LIMIT,
  PIONEER_DISPLAY_AVAILABLE,
  STANDARD_PRICE_EUR,
  SLOT_STATUS_ENDPOINT,
} from '../lib/billing-constants';

const SIGNUP_URL = 'https://app.shortselect.com/signup?utm_source=marketing&utm_medium=cta&utm_campaign=pioneer_plan&utm_content=pricing_main';

const pricingSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "ShortSelect Pioneer Plan",
  description: `ShortSelect ATS für Recruiting-Agenturen. Alle Funktionen, ein Preis pro User. Pioneer Plan: ${PIONEER_PRICE_EUR} EUR pro User und Monat für die ersten ${PIONEER_LIMIT} Agenturen, danach ${STANDARD_PRICE_EUR} EUR pro User und Monat.`,
  brand: { "@type": "Brand", name: "ShortSelect" },
  offers: {
    "@type": "Offer",
    name: "Pioneer Plan",
    description: `Pioneer Plan: ${PIONEER_PRICE_EUR} EUR pro User und Monat, alle Funktionen inklusive. Noch ${PIONEER_DISPLAY_AVAILABLE} von ${PIONEER_LIMIT} Plätzen frei. Danach ${STANDARD_PRICE_EUR} EUR pro User und Monat.`,
    price: `${PIONEER_PRICE_EUR}.00`,
    priceCurrency: "EUR",
    availability: "https://schema.org/LimitedAvailability",
    priceValidUntil: "2099-12-31",
    url: "https://www.shortselect.com/preise/",
    priceSpecification: {
      "@type": "UnitPriceSpecification",
      price: `${PIONEER_PRICE_EUR}.00`,
      priceCurrency: "EUR",
      billingDuration: "P1M",
      unitText: "MONTH",
      referenceQuantity: {
        "@type": "QuantitativeValue",
        value: "1",
        unitText: "User",
      },
    },
    seller: {
      "@type": "Organization",
      name: "ShortSelect",
      url: "https://www.shortselect.com",
    },
  },
};

const features = [
  "Unbegrenzte Jobs, Kandidaten und Pipelines",
  "Ein Preis pro User, alle Funktionen inklusive",
  "AgentBurst KI-Engine: Matching, Screening, Ranking, Nurturing",
  "Multi-Mandanten mit Whitelabel-Client-Portal",
  "Karriereseite, Embeddable Widget, Multiposting",
  "CRM, Talent Pools, Interview Scheduling",
  "REST API, Webhooks, n8n-ready",
  "Priority Support per E-Mail, persönliches Onboarding",
  "DSGVO-konform, EU-Server, Audit Logging, RBAC",
  "Alle zukünftigen Updates inklusive, kein Aufpreis",
];

const competitors = [
  { name: "Bullhorn Core", price: "825 $/Monat", model: "5 User à 165 $ pro User/Monat" },
  { name: "Vincere CRM + Elite AI", price: "ab £694/Monat", model: "5 User à £69 plus Elite-AI-Paket ab £349" },
  { name: "Teamtailor", price: "Auf Anfrage", model: "Angebot auf Anfrage, unbegrenzte User" },
  { name: "Tellent Recruitee", price: "Individuelles Angebot", model: "Agenturen bekommen ein individuelles Angebot" },
  { name: "Ezekia", price: "Auf Anfrage", model: "User-basiertes Modell, Angebot auf Anfrage" },
];
---

<MarketingLayout
  title={`Preise, ShortSelect Pioneer Plan | ${PIONEER_PRICE_EUR} € pro User`}
  description={`Pioneer Plan: ShortSelect für ${PIONEER_PRICE_EUR} € pro User/Monat. Alle Funktionen, ein Preis pro User. 30 Tage kostenlos testen, keine Kreditkarte.`}
  jsonLd={pricingSchema}
>
  <!-- Hero -->
  <section class="pt-32 pb-12">
    <div class="container mx-auto px-4">
      <div id="pricing-hero" class="text-center max-w-3xl mx-auto opacity-0 translate-y-8 transition-all duration-700">
        <span class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-primary/10 text-primary text-sm font-semibold">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          <span id="pioneer-slot-pill">Noch {PIONEER_DISPLAY_AVAILABLE} von {PIONEER_LIMIT} frei</span>
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold tracking-tight mb-4">
          Pioneer Plan:
          <span class="text-primary">{PIONEER_PRICE_EUR} € pro User.</span>
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground">
          Ein Preis, kein Tier-Wirrwarr, alle Funktionen inklusive. Nur für die ersten {PIONEER_LIMIT} Recruiting-Agenturen.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Card -->
  <section class="pb-16">
    <div class="container mx-auto px-4">
      <div id="pricing-card" class="max-w-xl mx-auto opacity-0 translate-y-8 transition-all duration-700">
        <div class="relative rounded-2xl border-2 border-primary bg-card text-card-foreground shadow-xl p-8 md:p-10">
          <!-- Pioneer Badge mit animierter Flamme + Slot-Counter -->
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
            <span class="inline-flex items-center gap-1.5 bg-primary text-primary-foreground text-xs font-semibold pl-2.5 pr-4 py-1.5 rounded-full shadow-lg whitespace-nowrap">
              <svg class="badge-flame" viewBox="0 0 24 32" width="14" height="18" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="bf-outer-grad" x1="50%" y1="100%" x2="50%" y2="0%">
                    <stop offset="0%" stop-color="#FBBF24" />
                    <stop offset="55%" stop-color="#FDE68A" />
                    <stop offset="100%" stop-color="#FFFFFF" />
                  </linearGradient>
                  <linearGradient id="bf-core-grad" x1="50%" y1="100%" x2="50%" y2="0%">
                    <stop offset="0%" stop-color="#FDE68A" />
                    <stop offset="100%" stop-color="#FFFFFF" />
                  </linearGradient>
                </defs>
                <path class="bf-outer" fill="url(#bf-outer-grad)" d="M12 31 C 4 30, 1 24, 3 17 C 4.5 13, 7 11, 8 6 C 10 9, 11 13, 12 16 C 13 12, 15 8, 17 2 C 19 7, 22 13, 23 19 C 24 26, 19 31, 12 31 Z" />
                <path class="bf-core" fill="url(#bf-core-grad)" d="M12 28 C 7 27, 5.5 22, 7 18 C 8.5 15, 10 13, 11 10 C 12 13, 13.5 16, 14.5 19 C 16 23, 14 28, 12 28 Z" />
              </svg>
              <span id="pioneer-badge-text">Noch {PIONEER_DISPLAY_AVAILABLE} von {PIONEER_LIMIT} frei</span>
            </span>
          </div>

          <!-- Plan Name -->
          <div class="text-center mb-6 mt-2">
            <h2 class="text-2xl font-display font-bold mb-2">ShortSelect Pioneer</h2>
            <p class="text-sm text-muted-foreground">
              Alle Funktionen, ein Preis pro User, Lifetime-Preisgarantie
            </p>
          </div>

          <!-- Pricing Display -->
          <div class="text-center mb-8 pb-8 border-b border-border">
            <div class="flex items-baseline justify-center gap-3 mb-2 flex-wrap">
              <span class="text-5xl md:text-6xl font-display font-bold text-foreground">{PIONEER_PRICE_EUR} €</span>
              <span class="text-lg text-muted-foreground">pro User/Monat</span>
            </div>
            <p class="text-sm text-muted-foreground">
              Pro User, alle Funktionen inklusive.
              <br/>Preis ist auf Lebenszeit garantiert, solange das Abo aktiv bleibt.
            </p>
          </div>

          <!-- Feature Liste -->
          <ul class="space-y-3 mb-8">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-0.5 h-5 w-5 rounded-full bg-primary/15 flex items-center justify-center">
                  <svg class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span class="text-sm">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={SIGNUP_URL}
            class="block w-full text-center py-4 px-6 rounded-lg bg-primary text-primary-foreground font-semibold text-lg hover:bg-primary/90 shadow-md hover:shadow-xl transition-all duration-300"
          >
            30 Tage kostenlos starten
          </a>

          <!-- Trust Zeile -->
          <p class="text-center text-xs text-muted-foreground mt-4">
            30 Tage kostenlos. Keine Kreditkarte erforderlich. Setup in 5 Minuten. Jederzeit kündbar.
          </p>
        </div>

        <!-- Knappheits Subline -->
        <p class="text-center text-sm text-muted-foreground mt-6">
          Der Pioneer-Preis von {PIONEER_PRICE_EUR} € pro User ist auf Lebenszeit gesichert, solange das Abo ununterbrochen aktiv bleibt. Danach gilt der Standard-Tarif von {STANDARD_PRICE_EUR} € pro User und Monat.
        </p>
      </div>
    </div>
  </section>

  <!-- Vergleichs Block -->
  <section id="comparison" class="py-16 md:py-20 bg-muted/30">
    <div class="container mx-auto px-4">
      <div id="comparison-content" class="max-w-4xl mx-auto opacity-0 translate-y-8 transition-all duration-700">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight text-center mb-4">
          ShortSelect ist der günstigste transparente Einstieg
        </h2>
        <p class="text-center text-muted-foreground mb-12 max-w-2xl mx-auto">
          Für 5 User kostet ShortSelect 745 € pro Monat. Vergleichbare Agentur-Setups mit ATS, CRM, Automatisierung und KI liegen öffentlich höher oder sind nur auf Anfrage erhältlich.
        </p>

        <div class="bg-card rounded-2xl border border-border/50 shadow-card overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-2">
            <!-- Wettbewerber -->
            <div class="p-6 md:p-8 border-b md:border-b-0 md:border-r border-border/50">
              <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-widest mb-4">
                Andere ATS-Plattformen (5 Plätze)
              </h3>
              <ul class="space-y-3">
                {competitors.map((c) => (
                  <li class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 text-sm">
                    <div>
                      <span class="text-foreground font-medium">{c.name}</span>
                      <span class="block text-xs text-muted-foreground">{c.model}</span>
                    </div>
                    <span class="font-semibold tabular-nums">{c.price}</span>
                  </li>
                ))}
              </ul>
              <p class="text-xs text-muted-foreground mt-6 pt-4 border-t border-border/30">
                Öffentliche Preisangaben und Anbieter-Preislogik, Stand Mai 2026. Anbieter mit Preisen auf Anfrage nennen keine feste Einstiegssumme und kalkulieren häufig nach Teamgröße, Paket und Add-ons.
              </p>
            </div>

            <!-- ShortSelect -->
            <div class="p-6 md:p-8 bg-primary/5">
              <h3 class="text-sm font-semibold text-primary uppercase tracking-widest mb-4">
                ShortSelect Pioneer Plan
              </h3>
              <div class="flex items-baseline gap-2 mb-4">
                <span class="text-4xl md:text-5xl font-display font-bold">745 €</span>
                <span class="text-lg text-muted-foreground">/Monat bei 5 Usern</span>
              </div>
              <p class="text-sm mb-4">
                {PIONEER_PRICE_EUR} € pro User und Monat. Damit ist ShortSelect der günstigste transparente Einstieg in diesem Vergleich.
              </p>
              <p class="text-xs text-muted-foreground">
                Inklusive AgentBurst-KI, Multi-Mandanten, Client Portal, API, Multiposting und allen zukünftigen Updates.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQSection />
  <CTASection />

  <script is:inline>
  (function() {
    var hero = document.getElementById('pricing-hero');
    var card = document.getElementById('pricing-card');
    var comparison = document.getElementById('comparison-content');
    var items = [hero, card, comparison].filter(Boolean);
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>

  <script is:inline define:vars={{ endpoint: SLOT_STATUS_ENDPOINT, totalLimit: PIONEER_LIMIT, displayAvailable: PIONEER_DISPLAY_AVAILABLE }}>
  (function() {
    var pill = document.getElementById('pioneer-slot-pill');
    var badge = document.getElementById('pioneer-badge-text');
    if (!pill && !badge) return;

    function render(available, totalSlots, soldOut) {
      var pillText, badgeText;
      if (soldOut) {
        pillText = 'Pioneer-Plätze ausverkauft';
        badgeText = 'Pioneer ausverkauft';
      } else {
        var shownAvailable = displayAvailable;
        pillText = 'Noch ' + shownAvailable + ' von ' + totalSlots + ' frei';
        badgeText = 'Noch ' + shownAvailable + ' von ' + totalSlots + ' frei';
      }
      if (pill) pill.textContent = pillText;
      if (badge) badge.textContent = badgeText;
    }

    try {
      fetch(endpoint, { method: 'GET', headers: { 'Accept': 'application/json' } })
        .then(function(r) { return r.ok ? r.json() : null; })
        .then(function(data) {
          if (!data) return;
          render(data.available, data.total || totalLimit, data.sold_out);
        })
        .catch(function() { /* silent fail, statischer Fallback bleibt */ });
    } catch (e) { /* noop */ }
  })();
  </script>

  <style is:global>
    .badge-flame {
      display: inline-block;
      flex-shrink: 0;
      filter: drop-shadow(0 0 3px rgba(254, 240, 138, 0.7));
      overflow: visible;
    }
    .bf-outer {
      transform-origin: 50% 100%;
      transform-box: fill-box;
      animation: bfFlicker 1.6s ease-in-out infinite;
    }
    .bf-core {
      transform-origin: 50% 100%;
      transform-box: fill-box;
      animation: bfFlickerCore 1.2s ease-in-out infinite;
      animation-delay: 0.25s;
    }
    @keyframes bfFlicker {
      0%, 100% { transform: scale(1, 1) skewX(-2deg); opacity: 1; }
      30% { transform: scale(1.06, 0.96) skewX(3deg); opacity: 0.95; }
      60% { transform: scale(0.96, 1.05) skewX(-3deg); opacity: 1; }
      80% { transform: scale(1.02, 0.98) skewX(1deg); opacity: 0.92; }
    }
    @keyframes bfFlickerCore {
      0%, 100% { transform: scale(1, 1); opacity: 1; }
      40% { transform: scale(0.92, 1.08); opacity: 0.85; }
      70% { transform: scale(1.05, 0.94); opacity: 1; }
    }
    @media (prefers-reduced-motion: reduce) {
      .bf-outer, .bf-core { animation: none; }
    }
  </style>
</MarketingLayout>
