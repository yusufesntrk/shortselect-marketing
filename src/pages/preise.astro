---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import FAQSection from '../components/landing/FAQSection.astro';
import CTASection from '../components/landing/CTASection.astro';
import {
  PRO_PRICE_MONTHLY_EUR,
  PRO_PRICE_ANNUAL_EUR,
  PRO_ANNUAL_MONTHS_FREE,
} from '../lib/billing-constants';

const SIGNUP_URL = 'https://app.shortselect.com/signup?utm_source=marketing&utm_medium=cta&utm_campaign=pro_plan&utm_content=pricing_main';

// 1.791 € / 12 = 149,25 € effektiver Monatspreis bei Jahreszahlung.
// Anzeige-Konvention (Close-CRM-Style): Jahresplan wird als Monatspreis
// "bei jährlicher Abrechnung" beworben, die Jahressumme steht nur dezent
// im Kleingedruckten.
const ANNUAL_EFFECTIVE_MONTHLY = (PRO_PRICE_ANNUAL_EUR / 12).toLocaleString('de-DE', {
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
});
const ANNUAL_PRICE_FORMATTED = PRO_PRICE_ANNUAL_EUR.toLocaleString('de-DE');
const FIVE_USER_MONTHLY = (5 * PRO_PRICE_MONTHLY_EUR).toLocaleString('de-DE');
const FIVE_USER_ANNUAL_MONTHLY = ((5 * PRO_PRICE_ANNUAL_EUR) / 12).toLocaleString('de-DE', {
  maximumFractionDigits: 0,
});

const pricingSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "ShortSelect Pro Plan",
  description: `ShortSelect ATS für Recruiting-Agenturen. Alle Funktionen, ein Preis pro User. Pro Plan: ${PRO_PRICE_MONTHLY_EUR} EUR pro User und Monat oder ${PRO_PRICE_ANNUAL_EUR} EUR pro User und Jahr (${PRO_ANNUAL_MONTHS_FREE} Monate geschenkt).`,
  brand: { "@type": "Brand", name: "ShortSelect" },
  offers: [
    {
      "@type": "Offer",
      name: "Pro Plan (monatlich)",
      description: `Pro Plan: ${PRO_PRICE_MONTHLY_EUR} EUR pro User und Monat, alle Funktionen inklusive.`,
      price: `${PRO_PRICE_MONTHLY_EUR}.00`,
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      priceValidUntil: "2099-12-31",
      url: "https://www.shortselect.com/preise/",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: `${PRO_PRICE_MONTHLY_EUR}.00`,
        priceCurrency: "EUR",
        billingDuration: "P1M",
        unitText: "MONTH",
        referenceQuantity: {
          "@type": "QuantitativeValue",
          value: "1",
          unitText: "User",
        },
      },
      seller: {
        "@type": "Organization",
        name: "ShortSelect",
        url: "https://www.shortselect.com",
      },
    },
    {
      "@type": "Offer",
      name: "Pro Plan (jährlich)",
      description: `Pro Plan Jahresabo: ${PRO_PRICE_ANNUAL_EUR} EUR pro User und Jahr (9 statt 12 Monatsraten, Vorauszahlung).`,
      price: `${PRO_PRICE_ANNUAL_EUR}.00`,
      priceCurrency: "EUR",
      availability: "https://schema.org/InStock",
      priceValidUntil: "2099-12-31",
      url: "https://www.shortselect.com/preise/",
      priceSpecification: {
        "@type": "UnitPriceSpecification",
        price: `${PRO_PRICE_ANNUAL_EUR}.00`,
        priceCurrency: "EUR",
        billingDuration: "P1Y",
        unitText: "YEAR",
        referenceQuantity: {
          "@type": "QuantitativeValue",
          value: "1",
          unitText: "User",
        },
      },
      seller: {
        "@type": "Organization",
        name: "ShortSelect",
        url: "https://www.shortselect.com",
      },
    },
  ],
};

const features = [
  "Unbegrenzte Jobs, Kandidaten und Pipelines",
  "Ein Preis pro User, alle Funktionen inklusive",
  "AgentBurst KI-Engine: Matching, Screening, Ranking, Nurturing",
  "Multi-Mandanten mit Whitelabel-Client-Portal",
  "Karriereseite, Embeddable Widget, Multiposting",
  "CRM, Talent Pools, Interview Scheduling",
  "REST API, Webhooks, n8n-ready",
  "Priority Support per E-Mail, persönliches Onboarding",
  "DSGVO-konform, EU-Server, Audit Logging, RBAC",
  "Alle zukünftigen Updates inklusive, kein Aufpreis",
];

const competitors = [
  { name: "Bullhorn Core", price: "825 $/Monat", model: "5 User à 165 $ pro User/Monat" },
  { name: "Vincere CRM + Elite AI", price: "ab £694/Monat", model: "5 User à £69 plus Elite-AI-Paket ab £349" },
  { name: "Teamtailor", price: "Auf Anfrage", model: "Angebot auf Anfrage, unbegrenzte User" },
  { name: "Tellent Recruitee", price: "Individuelles Angebot", model: "Agenturen bekommen ein individuelles Angebot" },
  { name: "Ezekia", price: "Auf Anfrage", model: "User-basiertes Modell, Angebot auf Anfrage" },
];
---

<MarketingLayout
  title={`Preise, ShortSelect Pro Plan | ${PRO_PRICE_MONTHLY_EUR} € pro User`}
  description={`Pro Plan: ShortSelect für ${PRO_PRICE_MONTHLY_EUR} € pro User/Monat oder ${ANNUAL_PRICE_FORMATTED} € pro User/Jahr (${PRO_ANNUAL_MONTHS_FREE} Monate geschenkt). 30 Tage kostenlos testen, keine Kreditkarte.`}
  jsonLd={pricingSchema}
>
  <!-- Hero -->
  <section class="pt-32 pb-12">
    <div class="container mx-auto px-4">
      <div id="pricing-hero" class="text-center max-w-3xl mx-auto opacity-0 translate-y-8 transition-all duration-700">
        <span class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-primary/10 text-primary text-sm font-semibold">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          Alle Funktionen, ein Preis pro User
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold tracking-tight mb-4">
          Pro Plan:
          <span class="text-primary">{PRO_PRICE_MONTHLY_EUR} € pro User.</span>
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground">
          Ein Preis, kein Tier-Wirrwarr, alle Funktionen inklusive. Jährliche Zahlung spart {PRO_ANNUAL_MONTHS_FREE} Monatsraten.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Card -->
  <section class="pb-16">
    <div class="container mx-auto px-4">
      <div id="pricing-card" class="max-w-xl mx-auto opacity-0 translate-y-8 transition-all duration-700">

        <!-- Monat/Jahr Toggle -->
        <div class="flex justify-center mb-6">
          <div class="inline-flex items-center rounded-full border border-border bg-card p-1" role="group" aria-label="Abrechnungszeitraum wählen">
            <button
              type="button"
              id="interval-monthly"
              aria-pressed="true"
              class="px-4 py-1.5 text-sm font-medium rounded-full transition-colors bg-primary text-primary-foreground shadow"
            >
              Monatlich
            </button>
            <button
              type="button"
              id="interval-annual"
              aria-pressed="false"
              class="px-4 py-1.5 text-sm font-medium rounded-full transition-colors text-muted-foreground hover:text-foreground"
            >
              Jährlich <span class="text-xs">({PRO_ANNUAL_MONTHS_FREE} Monate geschenkt)</span>
            </button>
          </div>
        </div>

        <div class="relative rounded-2xl border-2 border-primary bg-card text-card-foreground shadow-xl p-8 md:p-10">
          <!-- Plan Name -->
          <div class="text-center mb-6 mt-2">
            <h2 class="text-2xl font-display font-bold mb-2">ShortSelect Pro</h2>
            <p class="text-sm text-muted-foreground">
              Alle Funktionen, ein Preis pro User
            </p>
          </div>

          <!-- Pricing Display -->
          <div class="text-center mb-8 pb-8 border-b border-border">
            <div id="price-monthly-block">
              <div class="flex items-baseline justify-center gap-3 mb-2 flex-wrap">
                <span class="text-5xl md:text-6xl font-display font-bold text-foreground">{PRO_PRICE_MONTHLY_EUR} €</span>
                <span class="text-lg text-muted-foreground">pro User/Monat</span>
              </div>
              <p class="text-sm text-muted-foreground">
                Pro aktivem User, alle Funktionen inklusive.
                <br/>Monatliche Abrechnung, netto zzgl. MwSt.
              </p>
            </div>
            <div id="price-annual-block" class="hidden">
              <div class="flex items-baseline justify-center gap-3 mb-2 flex-wrap">
                <span class="text-5xl md:text-6xl font-display font-bold text-foreground">{ANNUAL_EFFECTIVE_MONTHLY} €</span>
                <span class="text-lg text-muted-foreground">pro User/Monat</span>
                <span class="text-xl line-through text-muted-foreground/60">{PRO_PRICE_MONTHLY_EUR} €</span>
              </div>
              <p class="text-sm text-muted-foreground">
                Bei jährlicher Abrechnung, {PRO_ANNUAL_MONTHS_FREE} Monatsraten geschenkt.
                <br/>Pro aktivem User, netto zzgl. MwSt.
              </p>
            </div>
          </div>

          <!-- Feature Liste -->
          <ul class="space-y-3 mb-8">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-0.5 h-5 w-5 rounded-full bg-primary/15 flex items-center justify-center">
                  <svg class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span class="text-sm">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={SIGNUP_URL}
            class="block w-full text-center py-4 px-6 rounded-lg bg-primary text-primary-foreground font-semibold text-lg hover:bg-primary/90 shadow-md hover:shadow-xl transition-all duration-300"
          >
            30 Tage kostenlos starten
          </a>

          <!-- Trust Zeile -->
          <p class="text-center text-xs text-muted-foreground mt-4">
            30 Tage kostenlos. Keine Kreditkarte erforderlich. Setup in 5 Minuten.
          </p>
          <p id="annual-terms-note" class="hidden text-center text-xs text-muted-foreground mt-2">
            Abrechnung jährlich im Voraus ({ANNUAL_PRICE_FORMATTED} € pro User/Jahr). 12 Monate Laufzeit, verlängert sich um jeweils 12 Monate, kündbar mit 6 Monaten Frist zum Laufzeitende, Details in den AGB (§ 7).
          </p>
        </div>

        <!-- Subline -->
        <p class="text-center text-sm text-muted-foreground mt-6">
          Abgerechnet wird pro aktivem User in deinem Team. Neue Teammitglieder werden anteilig nachberechnet, entfernte User reduzieren die nächste Rechnung.
        </p>
      </div>
    </div>
  </section>

  <!-- Vergleichs Block -->
  <section id="comparison" class="py-16 md:py-20 bg-muted/30">
    <div class="container mx-auto px-4">
      <div id="comparison-content" class="max-w-4xl mx-auto opacity-0 translate-y-8 transition-all duration-700">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight text-center mb-4">
          ShortSelect ist der transparenteste Einstieg
        </h2>
        <p class="text-center text-muted-foreground mb-12 max-w-2xl mx-auto">
          Für 5 User kostet ShortSelect {FIVE_USER_MONTHLY} € pro Monat, bei jährlicher Zahlung effektiv {FIVE_USER_ANNUAL_MONTHLY} € pro Monat. Vergleichbare Agentur-Setups mit ATS, CRM, Automatisierung und KI liegen öffentlich ähnlich hoch oder sind nur auf Anfrage erhältlich.
        </p>

        <div class="bg-card rounded-2xl border border-border/50 shadow-card overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-2">
            <!-- Wettbewerber -->
            <div class="p-6 md:p-8 border-b md:border-b-0 md:border-r border-border/50">
              <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-widest mb-4">
                Andere ATS-Plattformen (5 Plätze)
              </h3>
              <ul class="space-y-3">
                {competitors.map((c) => (
                  <li class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 text-sm">
                    <div>
                      <span class="text-foreground font-medium">{c.name}</span>
                      <span class="block text-xs text-muted-foreground">{c.model}</span>
                    </div>
                    <span class="font-semibold tabular-nums">{c.price}</span>
                  </li>
                ))}
              </ul>
              <p class="text-xs text-muted-foreground mt-6 pt-4 border-t border-border/30">
                Öffentliche Preisangaben und Anbieter-Preislogik, Stand Mai 2026. Anbieter mit Preisen auf Anfrage nennen keine feste Einstiegssumme und kalkulieren häufig nach Teamgröße, Paket und Add-ons.
              </p>
            </div>

            <!-- ShortSelect -->
            <div class="p-6 md:p-8 bg-primary/5">
              <h3 class="text-sm font-semibold text-primary uppercase tracking-widest mb-4">
                ShortSelect Pro Plan
              </h3>
              <div class="flex items-baseline gap-2 mb-4">
                <span class="text-4xl md:text-5xl font-display font-bold">{FIVE_USER_MONTHLY} €</span>
                <span class="text-lg text-muted-foreground">/Monat bei 5 Usern</span>
              </div>
              <p class="text-sm mb-4">
                {PRO_PRICE_MONTHLY_EUR} € pro User und Monat, bei jährlicher Zahlung effektiv {ANNUAL_EFFECTIVE_MONTHLY} € pro User und Monat. Ein transparenter Preis, alle Funktionen inklusive.
              </p>
              <p class="text-xs text-muted-foreground">
                Inklusive AgentBurst-KI, Multi-Mandanten, Client Portal, API, Multiposting und allen zukünftigen Updates.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQSection />
  <CTASection />

  <script is:inline>
  (function() {
    var hero = document.getElementById('pricing-hero');
    var card = document.getElementById('pricing-card');
    var comparison = document.getElementById('comparison-content');
    var items = [hero, card, comparison].filter(Boolean);
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>

  <script is:inline>
  (function() {
    var monthlyBtn = document.getElementById('interval-monthly');
    var annualBtn = document.getElementById('interval-annual');
    var monthlyBlock = document.getElementById('price-monthly-block');
    var annualBlock = document.getElementById('price-annual-block');
    var termsNote = document.getElementById('annual-terms-note');
    if (!monthlyBtn || !annualBtn || !monthlyBlock || !annualBlock) return;

    var ACTIVE = ['bg-primary', 'text-primary-foreground', 'shadow'];
    var INACTIVE = ['text-muted-foreground', 'hover:text-foreground'];

    function setInterval(isAnnual) {
      monthlyBlock.classList.toggle('hidden', isAnnual);
      annualBlock.classList.toggle('hidden', !isAnnual);
      if (termsNote) termsNote.classList.toggle('hidden', !isAnnual);

      [monthlyBtn, annualBtn].forEach(function(btn) {
        var active = (btn === annualBtn) === isAnnual;
        btn.setAttribute('aria-pressed', active ? 'true' : 'false');
        ACTIVE.forEach(function(c) { btn.classList.toggle(c, active); });
        INACTIVE.forEach(function(c) { btn.classList.toggle(c, !active); });
      });
    }

    monthlyBtn.addEventListener('click', function() { setInterval(false); });
    annualBtn.addEventListener('click', function() { setInterval(true); });
  })();
  </script>
</MarketingLayout>
