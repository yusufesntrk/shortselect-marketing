---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import FAQSection from '../components/landing/FAQSection.astro';
import CTASection from '../components/landing/CTASection.astro';

const SIGNUP_URL = 'https://app.shortselect.com/signup?utm_source=marketing&utm_medium=cta&utm_campaign=founders_deal&utm_content=pricing_main';

const pricingSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: "ShortSelect Founders Deal",
  description: "ShortSelect ATS für Recruiting-Agenturen. Alle Funktionen, ein Preis pro Tenant. KI-gestütztes Matching, Multi-Mandanten, Client Portal, Multiposting und API-Zugang inklusive.",
  brand: { "@type": "Brand", name: "ShortSelect" },
  offers: {
    "@type": "Offer",
    name: "Founders Deal",
    description: "Founders Deal: 89 EUR pro Monat pro Tenant, alle Funktionen inklusive. Limitiert auf die ersten 100 Recruiting-Agenturen. Preis auf Lebenszeit garantiert.",
    price: "89.00",
    priceCurrency: "EUR",
    availability: "https://schema.org/InStock",
    priceValidUntil: "2099-12-31",
    url: "https://www.shortselect.com/preise",
    priceSpecification: {
      "@type": "UnitPriceSpecification",
      price: "89.00",
      priceCurrency: "EUR",
      billingDuration: "P1M",
      unitText: "MONTH",
      referenceQuantity: {
        "@type": "QuantitativeValue",
        value: "1",
        unitText: "Tenant",
      },
    },
    seller: {
      "@type": "Organization",
      name: "ShortSelect",
      url: "https://www.shortselect.com",
    },
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    ratingCount: "127",
    bestRating: "5",
  },
};

const features = [
  "Unbegrenzte Jobs, Kandidaten und Pipelines",
  "Unbegrenzte Recruiter-Plätze pro Agentur",
  "AgentBurst KI-Engine: Matching, Screening, Ranking, Nurturing",
  "Multi-Mandanten mit Whitelabel-Client-Portal",
  "Karriereseite, Embeddable Widget, Multiposting",
  "CRM, Talent Pools, Interview Scheduling",
  "REST API, Webhooks, n8n-ready",
  "Priority Support per E-Mail, persönliches Onboarding",
  "DSGVO-konform, EU-Server, Audit Logging, RBAC",
  "Alle zukünftigen Updates inklusive, kein Aufpreis",
];

const competitors = [
  { name: "Bullhorn", price: "ab ca. 495 €/Monat", model: "Per User, ca. 99 € pro Platz" },
  { name: "Vincere", price: "ab ca. 400 €/Monat", model: "Per User, ca. 80 € pro Platz" },
  { name: "Teamtailor", price: "ab ca. 290 €/Monat", model: "Subscription plus Per User" },
  { name: "Recruitee", price: "ab ca. 245 €/Monat", model: "Per User, ca. 49 € pro Platz" },
  { name: "Ezekia", price: "ab ca. 700 €/Monat", model: "Per User, 120 GBP plus pro Platz" },
];
---

<MarketingLayout
  title="Preise, ShortSelect Founders Deal | 89 €/Monat"
  description="Founders Deal: ShortSelect für 89 €/Monat statt 150 €. Alle Funktionen, ein Preis pro Agentur. 30 Tage kostenlos testen, keine Kreditkarte nötig."
  jsonLd={pricingSchema}
>
  <!-- Hero -->
  <section class="pt-32 pb-12">
    <div class="container mx-auto px-4">
      <div id="pricing-hero" class="text-center max-w-3xl mx-auto opacity-0 translate-y-8 transition-all duration-700">
        <span class="inline-flex items-center gap-2 px-4 py-2 mb-6 rounded-full bg-primary/10 text-primary text-sm font-semibold">
          <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
          Limitiertes Founders Angebot
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold tracking-tight mb-4">
          Founders Deal:
          <span class="text-primary">alle Funktionen, ein Preis.</span>
        </h1>
        <p class="text-lg md:text-xl text-muted-foreground">
          Ein Preis, kein Tier-Wirrwarr, keine Limits. Nur für die ersten 100 Recruiting-Agenturen.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing Card -->
  <section class="pb-16">
    <div class="container mx-auto px-4">
      <div id="pricing-card" class="max-w-xl mx-auto opacity-0 translate-y-8 transition-all duration-700">
        <div class="relative rounded-2xl border-2 border-primary bg-card text-card-foreground shadow-xl p-8 md:p-10">
          <!-- Animierte Flamme über der Card -->
          <div class="flame-container absolute -top-20 md:-top-24 left-1/2 -translate-x-1/2 z-20 pointer-events-none" aria-hidden="true">
            <div class="flame-glow"></div>
            <svg class="flame-svg" viewBox="0 0 80 110" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <radialGradient id="flame-outer-grad" cx="50%" cy="80%" r="60%">
                  <stop offset="0%" stop-color="#FBBF24" stop-opacity="0.95" />
                  <stop offset="50%" stop-color="#F97316" stop-opacity="0.9" />
                  <stop offset="100%" stop-color="#DC2626" stop-opacity="0.7" />
                </radialGradient>
                <radialGradient id="flame-mid-grad" cx="50%" cy="80%" r="55%">
                  <stop offset="0%" stop-color="#FEF3C7" stop-opacity="1" />
                  <stop offset="55%" stop-color="#FBBF24" stop-opacity="0.95" />
                  <stop offset="100%" stop-color="#F97316" stop-opacity="0.85" />
                </radialGradient>
                <radialGradient id="flame-core-grad" cx="50%" cy="75%" r="55%">
                  <stop offset="0%" stop-color="#FFFFFF" stop-opacity="1" />
                  <stop offset="60%" stop-color="#FEF3C7" stop-opacity="0.95" />
                  <stop offset="100%" stop-color="#FBBF24" stop-opacity="0.6" />
                </radialGradient>
              </defs>
              <!-- Äußere Flamme -->
              <path class="flame flame-outer" d="M40 105 C 14 95 6 70 16 48 C 22 35 30 28 30 16 C 38 22 42 28 44 36 C 50 30 56 24 60 16 C 66 32 72 44 70 60 C 68 82 60 96 40 105 Z" fill="url(#flame-outer-grad)" />
              <!-- Mittlere Flamme -->
              <path class="flame flame-mid" d="M40 100 C 22 92 18 72 26 56 C 32 46 36 38 38 28 C 42 36 46 42 46 50 C 52 44 56 38 58 30 C 62 42 64 54 62 64 C 60 80 54 92 40 100 Z" fill="url(#flame-mid-grad)" />
              <!-- Innerer Kern -->
              <path class="flame flame-core" d="M40 96 C 30 90 28 76 32 66 C 36 58 38 50 40 42 C 44 50 46 58 48 66 C 50 76 48 90 40 96 Z" fill="url(#flame-core-grad)" />
            </svg>
            <div class="flame-spark flame-spark-1"></div>
            <div class="flame-spark flame-spark-2"></div>
            <div class="flame-spark flame-spark-3"></div>
          </div>

          <!-- Founders Badge -->
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
            <span class="inline-flex items-center gap-1.5 bg-primary text-primary-foreground text-xs font-semibold px-4 py-1.5 rounded-full shadow-lg whitespace-nowrap">
              Founders Deal, ersten 100 Agenturen
            </span>
          </div>

          <!-- Plan Name -->
          <div class="text-center mb-6 mt-2">
            <h2 class="text-2xl font-display font-bold mb-2">ShortSelect Founders</h2>
            <p class="text-sm text-muted-foreground">
              Alle Funktionen, ein Preis pro Agentur
            </p>
          </div>

          <!-- Pricing Display -->
          <div class="text-center mb-8 pb-8 border-b border-border">
            <div class="flex items-baseline justify-center gap-3 mb-2 flex-wrap">
              <span class="text-2xl text-muted-foreground line-through font-medium">150 €</span>
              <span class="text-5xl md:text-6xl font-display font-bold text-foreground">89 €</span>
              <span class="text-lg text-muted-foreground">/Monat</span>
            </div>
            <p class="text-sm text-muted-foreground">
              Pro Tenant, alle Recruiter-Plätze inklusive.
              <br/>Preis ist auf Lebenszeit garantiert.
            </p>
          </div>

          <!-- Feature Liste -->
          <ul class="space-y-3 mb-8">
            {features.map((feature) => (
              <li class="flex items-start gap-3">
                <span class="flex-shrink-0 mt-0.5 h-5 w-5 rounded-full bg-primary/15 flex items-center justify-center">
                  <svg class="h-3 w-3 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <span class="text-sm">{feature}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={SIGNUP_URL}
            class="block w-full text-center py-4 px-6 rounded-lg bg-primary text-primary-foreground font-semibold text-lg hover:bg-primary/90 shadow-md hover:shadow-xl transition-all duration-300"
          >
            30 Tage kostenlos starten
          </a>

          <!-- Trust Zeile -->
          <p class="text-center text-xs text-muted-foreground mt-4">
            30 Tage kostenlos. Keine Kreditkarte erforderlich. Setup in 5 Minuten. Jederzeit kündbar.
          </p>
        </div>

        <!-- Knappheits Subline -->
        <p class="text-center text-sm text-muted-foreground mt-6">
          Der Founders-Preis von 89 € ist auf Lebenszeit gesichert. Nach den ersten 100 Plätzen wechseln neue Tenants in den Standard-Tarif.
        </p>
      </div>
    </div>
  </section>

  <!-- Vergleichs Block -->
  <section id="comparison" class="py-16 md:py-20 bg-muted/30">
    <div class="container mx-auto px-4">
      <div id="comparison-content" class="max-w-4xl mx-auto opacity-0 translate-y-8 transition-all duration-700">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight text-center mb-4">
          Was Wettbewerber für vergleichbaren Funktionsumfang aufrufen
        </h2>
        <p class="text-center text-muted-foreground mb-12 max-w-2xl mx-auto">
          Wir kennen den Markt. Hier sind typische Listenpreise vergleichbarer ATS-Plattformen, skaliert auf eine Recruiting-Agentur mit 5 Plätzen.
        </p>

        <div class="bg-card rounded-2xl border border-border/50 shadow-card overflow-hidden">
          <div class="grid grid-cols-1 md:grid-cols-2">
            <!-- Wettbewerber -->
            <div class="p-6 md:p-8 border-b md:border-b-0 md:border-r border-border/50">
              <h3 class="text-sm font-semibold text-muted-foreground uppercase tracking-widest mb-4">
                Andere ATS-Plattformen (5 Plätze)
              </h3>
              <ul class="space-y-3">
                {competitors.map((c) => (
                  <li class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 text-sm">
                    <div>
                      <span class="text-foreground font-medium">{c.name}</span>
                      <span class="block text-xs text-muted-foreground">{c.model}</span>
                    </div>
                    <span class="font-semibold tabular-nums">{c.price}</span>
                  </li>
                ))}
              </ul>
              <p class="text-xs text-muted-foreground mt-6 pt-4 border-t border-border/30">
                Listenpreise laut öffentlichen Tarifen, Stand 2026. Plus Onboarding-Fees und Add-Ons für KI-Module.
              </p>
            </div>

            <!-- ShortSelect -->
            <div class="p-6 md:p-8 bg-primary/5">
              <h3 class="text-sm font-semibold text-primary uppercase tracking-widest mb-4">
                ShortSelect Founders Deal
              </h3>
              <div class="flex items-baseline gap-2 mb-4">
                <span class="text-4xl md:text-5xl font-display font-bold">89 €</span>
                <span class="text-lg text-muted-foreground">/Monat</span>
              </div>
              <p class="text-sm mb-4">
                Eine Pauschale für die ganze Agentur, alle Plätze inklusive. Keine User-Lizenzen, keine Add-On-Fees, keine Onboarding-Gebühren.
              </p>
              <p class="text-xs text-muted-foreground">
                Inklusive AgentBurst-KI, Multi-Mandanten, Client Portal, API, Multiposting und allen zukünftigen Updates.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQSection />
  <CTASection />

  <script is:inline>
  (function() {
    var hero = document.getElementById('pricing-hero');
    var card = document.getElementById('pricing-card');
    var comparison = document.getElementById('comparison-content');
    var items = [hero, card, comparison].filter(Boolean);
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>

  <style is:global>
    .flame-container {
      width: 80px;
      height: 110px;
      filter: drop-shadow(0 0 24px rgba(249, 115, 22, 0.55)) drop-shadow(0 0 48px rgba(220, 38, 38, 0.3));
    }
    @media (min-width: 768px) {
      .flame-container { width: 96px; height: 132px; }
    }
    .flame-svg {
      width: 100%;
      height: 100%;
      display: block;
      transform-origin: 50% 100%;
    }
    .flame {
      transform-origin: 50% 100%;
      transform-box: fill-box;
    }
    .flame-outer {
      animation: flameFlickerOuter 2.4s ease-in-out infinite;
    }
    .flame-mid {
      animation: flameFlickerMid 1.8s ease-in-out infinite;
      animation-delay: 0.15s;
    }
    .flame-core {
      animation: flameFlickerCore 1.3s ease-in-out infinite;
      animation-delay: 0.3s;
    }
    @keyframes flameFlickerOuter {
      0%, 100% { transform: scale(1, 1) skewX(-2deg) translateY(0); opacity: 0.92; }
      20% { transform: scale(1.03, 1.06) skewX(3deg) translateY(-2px); opacity: 1; }
      45% { transform: scale(0.96, 0.94) skewX(-4deg) translateY(2px); opacity: 0.85; }
      70% { transform: scale(1.05, 1.08) skewX(2deg) translateY(-3px); opacity: 1; }
      85% { transform: scale(0.98, 1.02) skewX(-1deg) translateY(0); opacity: 0.95; }
    }
    @keyframes flameFlickerMid {
      0%, 100% { transform: scale(1, 1) skewX(2deg) translateY(0); opacity: 0.95; }
      25% { transform: scale(0.92, 1.1) skewX(-5deg) translateY(-3px); opacity: 1; }
      50% { transform: scale(1.06, 0.92) skewX(4deg) translateY(2px); opacity: 0.88; }
      75% { transform: scale(0.94, 1.06) skewX(-2deg) translateY(-2px); opacity: 1; }
    }
    @keyframes flameFlickerCore {
      0%, 100% { transform: scale(1, 1) translateY(0); opacity: 1; }
      30% { transform: scale(1.08, 0.94) translateY(2px); opacity: 0.85; }
      60% { transform: scale(0.9, 1.1) translateY(-4px); opacity: 1; }
      80% { transform: scale(1.04, 0.96) translateY(1px); opacity: 0.9; }
    }
    .flame-glow {
      position: absolute;
      bottom: -8px;
      left: 50%;
      transform: translateX(-50%);
      width: 140%;
      height: 60px;
      background: radial-gradient(ellipse at center, rgba(249, 115, 22, 0.5) 0%, rgba(220, 38, 38, 0.25) 40%, transparent 70%);
      filter: blur(12px);
      border-radius: 50%;
      animation: flameGlowPulse 2.4s ease-in-out infinite;
      z-index: -1;
    }
    @keyframes flameGlowPulse {
      0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
      50% { opacity: 1; transform: translateX(-50%) scale(1.15); }
    }
    .flame-spark {
      position: absolute;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: radial-gradient(circle, #FEF3C7 0%, #F97316 70%, transparent 100%);
      opacity: 0;
      pointer-events: none;
    }
    .flame-spark-1 {
      top: 20%;
      left: 35%;
      animation: sparkRise1 2.6s ease-out infinite;
    }
    .flame-spark-2 {
      top: 30%;
      right: 30%;
      width: 3px;
      height: 3px;
      animation: sparkRise2 3.1s ease-out infinite;
      animation-delay: 0.7s;
    }
    .flame-spark-3 {
      top: 25%;
      left: 55%;
      width: 5px;
      height: 5px;
      animation: sparkRise3 2.9s ease-out infinite;
      animation-delay: 1.3s;
    }
    @keyframes sparkRise1 {
      0% { transform: translateY(0) translateX(0); opacity: 0; }
      15% { opacity: 1; }
      80% { opacity: 0.6; }
      100% { transform: translateY(-60px) translateX(-8px); opacity: 0; }
    }
    @keyframes sparkRise2 {
      0% { transform: translateY(0) translateX(0); opacity: 0; }
      20% { opacity: 1; }
      80% { opacity: 0.5; }
      100% { transform: translateY(-70px) translateX(10px); opacity: 0; }
    }
    @keyframes sparkRise3 {
      0% { transform: translateY(0) translateX(0); opacity: 0; }
      25% { opacity: 1; }
      80% { opacity: 0.7; }
      100% { transform: translateY(-80px) translateX(-4px); opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .flame-outer, .flame-mid, .flame-core, .flame-glow, .flame-spark { animation: none; }
      .flame-spark { opacity: 0; }
    }
  </style>
</MarketingLayout>
