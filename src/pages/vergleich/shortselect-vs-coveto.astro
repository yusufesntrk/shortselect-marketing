---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "Autonome KI-Agenten", ssStatus: "check" as const, ssLabel: "AgentBurst-Agenten, always-on", compStatus: "x" as const, compLabel: "Keine KI-Agenten" },
  { feature: "UI/UX", ssStatus: "check" as const, ssLabel: "Modern, Kanban", compStatus: "warn" as const, compLabel: "Funktional, klassisch" },
  { feature: "KI-Features", ssStatus: "check" as const, ssLabel: "AgentBurst", compStatus: "warn" as const, compLabel: "Begrenzt" },
  { feature: "Preise", ssStatus: "check" as const, ssLabel: "Ab 0\u20AC/Monat", compStatus: "warn" as const, compLabel: "Auf Anfrage" },
  { feature: "Cloud", ssStatus: "check" as const, ssLabel: "100% Cloud", compStatus: "check" as const, compLabel: "Cloud + On-Premise" },
  { feature: "Karriereseite", ssStatus: "check" as const, ssLabel: "Widget + Seite", compStatus: "check" as const, compLabel: "Verfügbar" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "check" as const, compLabel: "Verfügbar" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "check" as const, compLabel: "Verfügbar" },
  { feature: "Pipeline", ssStatus: "check" as const, ssLabel: "Drag & Drop", compStatus: "check" as const, compLabel: "Verfügbar" },
  { feature: "Multiposting", ssStatus: "check" as const, ssLabel: "Wachsend", compStatus: "check" as const, compLabel: "Stark" },
  { feature: "API", ssStatus: "check" as const, ssLabel: "REST + Webhooks", compStatus: "check" as const, compLabel: "Verfügbar" },
];
---

<VergleichLayout
  title="ShortSelect vs. coveto - ATS Vergleich 2026"
  description="Modernes ATS oder etablierter Klassiker? coveto ist seit Jahren im DACH-Markt etabliert. Vergleich mit ShortSelect."
  competitorName="coveto"
  heroSubline="Modernes ATS oder etablierter Klassiker? coveto ist seit Jahren im DACH-Markt etabliert. Wir vergleichen mit dem modernen Ansatz von ShortSelect."
  heroBadge="Vergleich"
  ssDescription="KI-Agent-ATS mit autonomen AgentBurst-Agenten"
  ssHighlights={["Autonome AgentBurst-Agenten", "Moderne Kanban-Pipeline", "Transparente Preise ab 0€", "100% Cloud, sofort einsatzbereit"]}
  compDescription="Etabliertes ATS mit breitem Funktionsumfang"
  compHighlights={["Starkes Multiposting-Netzwerk", "On-Premise und Cloud verfügbar", "Umfangreiche Integrationen", "Langjährige DACH-Erfahrung"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann coveto besser passt",
    intro: "coveto ist die richtige Wahl, wenn Sie auf bewährte Strukturen setzen:",
    items: [
      "Starkes Multiposting mit vielen Jobbörsen-Anbindungen",
      "On-Premise-Installation gewuenscht oder erforderlich",
      "Langjährige Erfahrung und etablierter Support im DACH-Raum",
      "Umfangreiche Integrationen mit bestehenden HR-Systemen",
      "Klassische Oberflaeche bevorzugt",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Sie ein modernes, KI-gestütztes ATS suchen:",
    items: [
      "Autonome KI-Agenten statt manuelle Workflows",
      "KI-gestütztes Smart Matching für bessere Kandidatenauswahl",
      "Transparente Preise mit kostenlosem Einstieg",
      "100% Cloud ohne Installations- oder Wartungsaufwand",
      "REST API und Webhooks für flexible Integrationen",
    ]
  }}
/>
