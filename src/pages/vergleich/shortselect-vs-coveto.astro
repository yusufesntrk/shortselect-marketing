---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "KI-Agenten", ssStatus: "check" as const, ssLabel: "AgentBurst-Agenten, always-on", compStatus: "x" as const, compLabel: "Keine KI-Agenten" },
  { feature: "UI/UX", ssStatus: "check" as const, ssLabel: "Modern, Kanban", compStatus: "warn" as const, compLabel: "Funktional, klassisch" },
  { feature: "KI-Features", ssStatus: "check" as const, ssLabel: "AgentBurst", compStatus: "warn" as const, compLabel: "Begrenzt" },
  { feature: "Preise", ssStatus: "check" as const, ssLabel: "199 € pro User/Monat", compStatus: "warn" as const, compLabel: "Auf Anfrage" },
  { feature: "Cloud", ssStatus: "check" as const, ssLabel: "100% Cloud", compStatus: "check" as const, compLabel: "Cloud + On-Premise" },
  { feature: "Karriereseite", ssStatus: "check" as const, ssLabel: "Widget + Seite", compStatus: "check" as const, compLabel: "Verfügbar" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "check" as const, compLabel: "Verfügbar" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "check" as const, compLabel: "Verfügbar" },
  { feature: "Pipeline", ssStatus: "check" as const, ssLabel: "Drag & Drop", compStatus: "check" as const, compLabel: "Verfügbar" },
  { feature: "Multiposting", ssStatus: "check" as const, ssLabel: "Wachsend", compStatus: "check" as const, compLabel: "Stark" },
  { feature: "API", ssStatus: "check" as const, ssLabel: "REST + Webhooks", compStatus: "check" as const, compLabel: "Verfügbar" },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen ShortSelect und coveto?",
    answer: "coveto ist ein etabliertes DACH-ATS mit starkem Multiposting-Netzwerk und optionaler On-Premise-Installation. ShortSelect ist ein modernes Cloud-ATS mit KI-Engine AgentBurst, die Screening, Matching und Ranking im Hintergrund übernimmt, dazu Kanban-Pipeline und transparente Preise.",
  },
  {
    question: "Für wen ist coveto besser geeignet?",
    answer: "coveto passt gut, wenn Sie starkes Multiposting mit vielen Jobbörsen-Anbindungen brauchen, eine On-Premise-Installation gewünscht oder vorgeschrieben ist oder Sie einen langjährig etablierten Anbieter mit klassischer Oberfläche bevorzugen.",
  },
  {
    question: "Was kostet ShortSelect im Vergleich zu coveto?",
    answer: "ShortSelect kostet im Pro Plan 199 € pro User/Monat oder 1.791 € pro User/Jahr (3 Monate geschenkt). Sie testen 30 Tage kostenlos ohne Kreditkarte. coveto nennt Preise nur auf Anfrage, die Kosten hängen also vom individuellen Angebot ab.",
  },
  {
    question: "Hat coveto KI-Agenten wie ShortSelect?",
    answer: "Nein. coveto bietet begrenzte KI-Features, aber keine KI-Agenten. Bei ShortSelect übernimmt die KI-Engine AgentBurst Matching, Screening und Ranking selbstständig, ohne dass Sie manuelle Workflows anstoßen müssen.",
  },
  {
    question: "Wie wechsle ich von coveto zu ShortSelect?",
    answer: "Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer Wechsel-Seite.",
    answerHtml: 'Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer <a href="/wechsel/" class="text-primary hover:underline">Wechsel-Seite</a>.',
  },
];
---

<VergleichLayout
  title="ShortSelect vs. Coveto - ATS Vergleich 2026"
  description="coveto ist der DACH-Klassiker mit starkem Multiposting. ShortSelect bietet KI-Agenten und Kanban-Pipeline ab 199 € pro User. Fairer Vergleich mit Preisen."
  competitorName="coveto"
  heroSubline="Modernes ATS oder etablierter Klassiker? coveto ist seit Jahren im DACH-Markt etabliert. Wir vergleichen mit dem modernen Ansatz von ShortSelect."
  heroBadge="Vergleich"
  ssDescription="KI-Agent-ATS mit autonomen AgentBurst-Agenten"
  ssHighlights={["AgentBurst-Agenten rund um die Uhr", "Moderne Kanban-Pipeline", "199 € pro User/Monat transparent", "100% Cloud, sofort einsatzbereit"]}
  compDescription="Etabliertes ATS mit breitem Funktionsumfang"
  compHighlights={["Starkes Multiposting-Netzwerk", "On-Premise und Cloud verfügbar", "Umfangreiche Integrationen", "Langjährige DACH-Erfahrung"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann coveto besser passt",
    intro: "coveto ist die richtige Wahl, wenn Sie auf bewährte Strukturen setzen:",
    items: [
      "Starkes Multiposting mit vielen Jobbörsen-Anbindungen",
      "On-Premise-Installation gewünscht oder erforderlich",
      "Langjährige Erfahrung und etablierter Support im DACH-Raum",
      "Umfangreiche Integrationen mit bestehenden HR-Systemen",
      "Klassische Oberfläche bevorzugt",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Sie ein modernes, KI-gestütztes ATS suchen:",
    items: [
      "KI-Agenten statt manuelle Workflows",
      "KI-gestütztes Smart Matching für bessere Kandidatenauswahl",
      "Transparente Preise: 199 € pro User/Monat",
      "100% Cloud ohne Installations- oder Wartungsaufwand",
      "REST API und Webhooks für flexible Integrationen",
    ]
  }}
  faqs={faqs}
/>
