---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "KI-Matching", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Kanban Pipeline", ssStatus: "check" as const, ssLabel: "Drag & Drop", compStatus: "check" as const, compLabel: "Drag & Drop" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Talent Pools", ssStatus: "check" as const, ssLabel: "Unbegrenzt", compStatus: "warn" as const, compLabel: "Eingeschränkt" },
  { feature: "Analytics", ssStatus: "check" as const, ssLabel: "Umfassend", compStatus: "check" as const, compLabel: "Standard" },
  { feature: "Embed Widget", ssStatus: "check" as const, ssLabel: "Frei gestaltbar", compStatus: "warn" as const, compLabel: "Eingeschränkt" },
  { feature: "API Zugang", ssStatus: "check" as const, ssLabel: "REST API", compStatus: "check" as const, compLabel: "REST API" },
  { feature: "Preis", ssStatus: "check" as const, ssLabel: "149 € pro User/Monat", compStatus: "warn" as const, compLabel: "Auf Anfrage" },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen ShortSelect und Softgarden?",
    answer: "Softgarden ist ein etabliertes ATS für den Mittelstand mit Kanban-Board, Karriereseite und Analytics, aber ohne KI-Matching, Multi-Tenancy oder Client Portal. ShortSelect bringt genau diese drei Bausteine mit und richtet sich damit vor allem an Recruiting-Agenturen und Personalberatungen.",
  },
  {
    question: "Für wen ist Softgarden besser geeignet?",
    answer: "Softgarden passt gut, wenn Sie ein etabliertes ATS ohne KI-Features suchen, Ihre Recruiting-Prozesse einfach und standardisiert sind, Sie kein Multi-Mandanten-Management brauchen oder bereits in das Softgarden-Ökosystem integriert sind.",
  },
  {
    question: "Was kostet ShortSelect im Vergleich zu Softgarden?",
    answer: "ShortSelect kostet im Pioneer Plan 149 € pro User/Monat für die ersten 100 Agenturen, danach 300 € pro User/Monat, und Sie testen 30 Tage kostenlos ohne Kreditkarte. Softgarden nennt Preise nur auf Anfrage, die Kosten hängen also vom individuellen Angebot ab.",
  },
  {
    question: "Hat Softgarden KI-Matching wie ShortSelect?",
    answer: "Nein. Softgarden bietet kein KI-Matching. Bei ShortSelect ist KI-gestütztes Kandidaten-Matching integriert: Das System gleicht Profile und Anforderungen automatisch ab und schlägt die passendsten Kandidaten vor.",
  },
  {
    question: "Wie wechsle ich von Softgarden zu ShortSelect?",
    answer: "Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer Wechsel-Seite.",
    answerHtml: 'Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer <a href="/wechsel/" class="text-primary hover:underline">Wechsel-Seite</a>.',
  },
];
---

<VergleichLayout
  title="ShortSelect vs. Softgarden - ATS Vergleich 2026"
  description="Softgarden ist solide für den Mittelstand. ShortSelect ergänzt KI-Matching, Multi-Tenancy und Client Portal ab 149 € pro User. Ehrlicher Vergleich."
  competitorName="Softgarden"
  heroSubline="Modernes ATS mit KI-Power statt Legacy-Software."
  heroBadge="Feature-Vergleich"
  ssDescription="KI-gestütztes ATS für Recruiter & Agenturen"
  ssHighlights={["KI-gestütztes Kandidaten-Matching", "Multi-Mandanten für Agenturen", "Client Portal inklusive", "149 € pro User/Monat transparent"]}
  compDescription="Etabliertes ATS für den Mittelstand"
  compHighlights={["Kanban Board", "Karriereseite", "Analytics", "Auf Anfrage"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Softgarden passt",
    intro: "Softgarden kann die richtige Wahl sein, wenn:",
    items: [
      "Sie ein etabliertes ATS ohne KI-Features suchen",
      "Sie bereits in das Softgarden-Ökosystem integriert sind",
      "Ihre Recruiting-Prozesse einfach und standardisiert sind",
      "Sie kein Multi-Mandanten-Management brauchen",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist die bessere Wahl, wenn:",
    items: [
      "Sie KI-gestütztes Matching und Automatisierung wollen",
      "Sie als Agentur mehrere Mandanten verwalten",
      "Sie ein Client Portal für Ihre Kunden brauchen",
      "Sie 30 Tage testen und dann pro User skalieren wollen",
      "Sie ein modernes, schnelles Interface bevorzugen",
    ]
  }}
  faqs={faqs}
/>
