---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "Fokus", ssStatus: "check" as const, ssLabel: "Reines ATS", compStatus: "warn" as const, compLabel: "HR-Suite (Recruiting + HR + TM)" },
  { feature: "UI/UX", ssStatus: "check" as const, ssLabel: "Modern & intuitiv", compStatus: "warn" as const, compLabel: "Funktional / klassisch" },
  { feature: "Preise", ssStatus: "check" as const, ssLabel: "199 € pro User/Monat", compStatus: "warn" as const, compLabel: "Auf Anfrage (ab ~300€/Monat)" },
  { feature: "Setup-Zeit", ssStatus: "check" as const, ssLabel: "Minuten", compStatus: "warn" as const, compLabel: "Wochen" },
  { feature: "KI-Features", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "warn" as const, compLabel: "Begrenzt" },
  { feature: "Cloud", ssStatus: "check" as const, ssLabel: "100% Cloud", compStatus: "check" as const, compLabel: "Cloud + On-Premise" },
  { feature: "Karriereseite", ssStatus: "check" as const, ssLabel: "Embeddable Widget", compStatus: "check" as const, compLabel: "Eigene Karriereseite" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "warn" as const, compLabel: "Begrenzt" },
  { feature: "Talent Management", ssStatus: "warn" as const, ssLabel: "Talent Pools", compStatus: "check" as const, compLabel: "Umfangreich" },
  { feature: "API Zugang", ssStatus: "check" as const, ssLabel: "REST API", compStatus: "check" as const, compLabel: "REST API" },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen ShortSelect und rexx systems?",
    answer: "rexx systems ist eine modulare HR-Suite mit Recruiting, HR und Talent Management, die seit über 20 Jahren im DACH-Raum etabliert ist und deren Einführung typischerweise Wochen dauert. ShortSelect ist ein reines Recruiting-ATS mit KI-Features und Client Portal, das zu 100 Prozent in der Cloud läuft und in Minuten einsatzbereit ist.",
  },
  {
    question: "Für wen ist rexx systems besser geeignet?",
    answer: "rexx systems passt besser für große HR-Abteilungen, die viele Module wie Talent Management mit Nachfolgeplanung brauchen, On-Premise-Hosting aus Compliance-Gründen benötigen oder umfangreiches Enterprise-Customizing planen.",
  },
  {
    question: "Was kostet ShortSelect im Vergleich zu rexx systems?",
    answer: "ShortSelect kostet im Pro Plan 199 € pro User/Monat oder 1.791 € pro User/Jahr (3 Monate geschenkt), mit 30 Tagen kostenlosem Test ohne Kreditkarte. rexx systems nennt Preise auf Anfrage, üblich sind Einstiegspreise ab etwa 300 € pro Monat je nach Modulumfang.",
  },
  {
    question: "Wie schnell ist ShortSelect im Vergleich zu rexx systems einsatzbereit?",
    answer: "ShortSelect ist als reine Cloud-Lösung in Minuten startklar, ohne Installation und ohne Wartungsaufwand. Bei rexx systems müssen Sie für die Einführung typischerweise mehrere Wochen einplanen, vor allem wenn mehrere Module konfiguriert werden.",
  },
  {
    question: "Wie wechsle ich von rexx systems zu ShortSelect?",
    answer: "Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer Wechsel-Seite.",
    answerHtml: 'Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer <a href="/wechsel/" class="text-primary hover:underline">Wechsel-Seite</a>.',
  },
];
---

<VergleichLayout
  title="ShortSelect vs. rexx systems - ATS Vergleich 2026"
  description="rexx systems ist die modulare HR-Suite mit langem Setup. ShortSelect: reines ATS mit KI, startklar in Minuten, ab 199 € pro User. Fairer Vergleich."
  competitorName="rexx systems"
  heroSubline="Modularer Klassiker oder modernes ATS? rexx systems bietet HR-Software seit 20+ Jahren. Wir vergleichen den etablierten Anbieter mit dem modernen Ansatz."
  heroBadge="Vergleich"
  ssDescription="Modernes ATS mit KI-Fokus"
  ssHighlights={["KI-gestütztes Kandidaten-Matching", "100% Cloud, sofort einsatzbereit", "Client Portal inklusive", "199 € pro User/Monat transparent"]}
  compDescription="Modulare HR-Suite seit 20+ Jahren"
  compHighlights={["Recruiting + HR + Talent Management", "Cloud- und On-Premise-Optionen", "Umfangreiches Talent Management", "Etablierter Anbieter im DACH-Raum"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann rexx systems besser passt",
    intro: "rexx systems ist die richtige Wahl, wenn Sie eine umfassende HR-Suite mit modularem Aufbau benötigen:",
    items: [
      "Umfangreiches Talent Management mit Nachfolgeplanung",
      "On-Premise-Hosting aus Compliance-Gründen nötig",
      "Große HR-Abteilung mit vielen Modulen (HR + Recruiting + TM)",
      "Etablierter Anbieter mit 20+ Jahren Erfahrung gewünscht",
      "Komplexe Enterprise-Anforderungen und Customizing",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Recruiting Ihr Kerngeschäft ist:",
    items: [
      "Personalberatungen und Recruiting-Agenturen",
      "Teams, die KI-gestütztes Matching brauchen",
      "Schneller Start ohne wochenlange Implementierung",
      "Client Portal für transparente Zusammenarbeit",
      "30-Tage-Test ohne Mindestlaufzeit",
    ]
  }}
  faqs={faqs}
/>
