---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "Zielgruppe", ssStatus: "check" as const, ssLabel: "Recruiting-Agenturen", compStatus: "warn" as const, compLabel: "Inhouse-HR-Teams" },
  { feature: "KI-Agenten", ssStatus: "check" as const, ssLabel: "AgentBurst-Agenten", compStatus: "x" as const, compLabel: "Keine" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "KI-Matching", ssStatus: "check" as const, ssLabel: "AgentBurst Match", compStatus: "warn" as const, compLabel: "Basis-KI" },
  { feature: "Karriereseite", ssStatus: "check" as const, ssLabel: "Widget + Seite", compStatus: "check" as const, compLabel: "Stark" },
  { feature: "Agentur-Features", ssStatus: "check" as const, ssLabel: "Komplett", compStatus: "x" as const, compLabel: "Null" },
  { feature: "Preise", ssStatus: "check" as const, ssLabel: "Ab 0\u20AC/Monat", compStatus: "warn" as const, compLabel: "Ab 2.400\u20AC/Jahr" },
  { feature: "Autonomes Screening", ssStatus: "check" as const, ssLabel: "AgentBurst Screen", compStatus: "x" as const, compLabel: "Manuell" },
  { feature: "DSGVO", ssStatus: "check" as const, ssLabel: "EU-nativ", compStatus: "check" as const, compLabel: "EU (Schweden)" },
];
---

<VergleichLayout
  title="ShortSelect vs. Teamtailor - ATS Vergleich 2026"
  description="Teamtailor ist ein Employer-Branding-Tool, kein Agentur-ATS. Null Multi-Tenancy, kein Client Portal, keine autonomen KI-Agenten."
  competitorName="Teamtailor"
  heroSubline="Teamtailor glänzt beim Employer Branding. aber für Recruiting-Agenturen fehlt alles: Kein Multi-Tenancy, kein Client Portal, keine autonomen KI-Agenten."
  heroBadge="Vergleich"
  ssDescription="KI-Agent-ATS für Recruiting-Agenturen"
  ssHighlights={["AgentBurst-Agenten arbeiten autonom", "Multi-Tenancy für Agenturen", "Client Portal für Ihre Kunden", "Autonomes Matching, Screening und Ranking"]}
  compDescription="Employer-Branding-Plattform für Inhouse-HR"
  compHighlights={["Starke Karriereseite und Employer Branding", "Moderne Oberflaeche", "Gute Integrationen", "EU-basiert (Schweden)"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Teamtailor besser passt",
    intro: "Teamtailor ist die richtige Wahl für Inhouse-HR-Teams mit Employer-Branding-Fokus:",
    items: [
      "Inhouse-HR-Team ohne Agentur-Anforderungen",
      "Employer Branding und Karriereseite haben hoechste Prioritaet",
      "Kein Multi-Tenancy oder Client Portal benötigt",
      "Keine autonomen KI-Agenten benötigt",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal für Recruiting-Agenturen mit mehreren Mandanten:",
    items: [
      "Agentur mit mehreren Mandanten und Multi-Tenancy-Bedarf",
      "Autonome AgentBurst-Agenten statt manueller Prozesse",
      "Client Portal für transparente Zusammenarbeit mit Kunden",
      "Faire Preise ab 0\u20AC statt 2.400\u20AC/Jahr",
      "DSGVO-konforme KI für autonomes Matching und Screening",
    ]
  }}
/>
