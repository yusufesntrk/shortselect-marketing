---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "Zielgruppe", ssStatus: "check" as const, ssLabel: "Recruiting-Agenturen", compStatus: "warn" as const, compLabel: "Inhouse-HR-Teams" },
  { feature: "KI-Agenten", ssStatus: "check" as const, ssLabel: "AgentBurst-Agenten", compStatus: "x" as const, compLabel: "Keine" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "KI-Matching", ssStatus: "check" as const, ssLabel: "AgentBurst Match", compStatus: "warn" as const, compLabel: "Basis-KI" },
  { feature: "Karriereseite", ssStatus: "check" as const, ssLabel: "Widget + Seite", compStatus: "check" as const, compLabel: "Stark" },
  { feature: "Agentur-Features", ssStatus: "check" as const, ssLabel: "Komplett", compStatus: "x" as const, compLabel: "Null" },
  { feature: "Preise", ssStatus: "check" as const, ssLabel: "199 € pro User/Monat", compStatus: "warn" as const, compLabel: "Ab 2.400€/Jahr" },
  { feature: "KI-Screening", ssStatus: "check" as const, ssLabel: "AgentBurst Screen", compStatus: "x" as const, compLabel: "Manuell" },
  { feature: "DSGVO", ssStatus: "check" as const, ssLabel: "EU-nativ", compStatus: "check" as const, compLabel: "EU (Schweden)" },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen ShortSelect und Teamtailor?",
    answer: "Teamtailor ist eine Employer-Branding-Plattform aus Schweden für Inhouse-HR-Teams mit starker Karriereseite. ShortSelect ist ein ATS für Recruiting-Agenturen mit Multi-Tenancy, Client Portal und der KI-Engine AgentBurst für Matching, Screening und Ranking. Beides sind EU-Anbieter, die Zielgruppen unterscheiden sich aber grundlegend.",
  },
  {
    question: "Für wen ist Teamtailor besser geeignet?",
    answer: "Teamtailor passt besser für Inhouse-HR-Teams, bei denen Employer Branding und eine schöne Karriereseite höchste Priorität haben und die weder Mandantenverwaltung noch Client Portal oder KI-Agenten benötigen.",
  },
  {
    question: "Was kostet ShortSelect im Vergleich zu Teamtailor?",
    answer: "ShortSelect kostet im Pro Plan 199 € pro User/Monat oder 1.791 € pro User/Jahr (3 Monate geschenkt), mit 30 Tagen kostenlosem Test ohne Kreditkarte. Teamtailor startet ab etwa 2.400 € pro Jahr, der genaue Preis hängt von Teamgröße und Tarif ab.",
  },
  {
    question: "Kann ich Teamtailor als Recruiting-Agentur nutzen?",
    answer: "Nur eingeschränkt. Teamtailor bietet weder Multi-Tenancy noch ein Client Portal, mehrere Mandanten lassen sich also nicht sauber trennen und Kunden können nicht in den Prozess einbezogen werden. ShortSelect ist genau für dieses Agentur-Szenario gebaut.",
  },
  {
    question: "Wie wechsle ich von Teamtailor zu ShortSelect?",
    answer: "Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer Wechsel-Seite.",
    answerHtml: 'Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer <a href="/wechsel/" class="text-primary hover:underline">Wechsel-Seite</a>.',
  },
];
---

<VergleichLayout
  title="ShortSelect vs. Teamtailor - ATS Vergleich 2026"
  description="Teamtailor glänzt bei Employer Branding für Inhouse-HR. ShortSelect: Multi-Tenancy, Client Portal, KI-Agenten ab 199 € pro User. Der Agentur-Vergleich."
  competitorName="Teamtailor"
  heroSubline="Teamtailor glänzt beim Employer Branding. Aber für Recruiting-Agenturen fehlt alles: Kein Multi-Tenancy, kein Client Portal, keine selbstständigen KI-Agenten."
  heroBadge="Vergleich"
  ssDescription="KI-Agent-ATS für Recruiting-Agenturen"
  ssHighlights={["AgentBurst-Agenten arbeiten im Hintergrund", "Multi-Tenancy für Agenturen", "Client Portal für Ihre Kunden", "Matching, Screening und Ranking ohne manuellen Klick"]}
  compDescription="Employer-Branding-Plattform für Inhouse-HR"
  compHighlights={["Starke Karriereseite und Employer Branding", "Moderne Oberfläche", "Gute Integrationen", "EU-basiert (Schweden)"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Teamtailor besser passt",
    intro: "Teamtailor ist die richtige Wahl für Inhouse-HR-Teams mit Employer-Branding-Fokus:",
    items: [
      "Inhouse-HR-Team ohne Agentur-Anforderungen",
      "Employer Branding und Karriereseite haben höchste Priorität",
      "Kein Multi-Tenancy oder Client Portal benötigt",
      "Keine selbstständigen KI-Agenten benötigt",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal für Recruiting-Agenturen mit mehreren Mandanten:",
    items: [
      "Agentur mit mehreren Mandanten und Multi-Tenancy-Bedarf",
      "Autonome AgentBurst-Agenten statt manueller Prozesse",
      "Client Portal für transparente Zusammenarbeit mit Kunden",
      "Faire Preise: 199 € pro User/Monat statt 2.400€/Jahr",
      "DSGVO-konforme KI für Matching und Screening im Hintergrund",
    ]
  }}
  faqs={faqs}
/>
