---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "Autonome KI-Agenten", ssStatus: "check" as const, ssLabel: "AgentBurst-Agenten, 24/7", compStatus: "x" as const, compLabel: "Keine autonomen Agenten" },
  { feature: "Zielgruppe", ssStatus: "check" as const, ssLabel: "KMU bis Enterprise", compStatus: "check" as const, compLabel: "Enterprise Staffing" },
  { feature: "Preise", ssStatus: "check" as const, ssLabel: "199 € pro User/Monat", compStatus: "warn" as const, compLabel: "Ab ~$99/User/Monat" },
  { feature: "Setup-Zeit", ssStatus: "check" as const, ssLabel: "Minuten", compStatus: "warn" as const, compLabel: "Wochen-Monate" },
  { feature: "UI / Design", ssStatus: "check" as const, ssLabel: "Modern (2024 Design)", compStatus: "warn" as const, compLabel: "Funktional (Legacy)" },
  { feature: "KI-Matching", ssStatus: "check" as const, ssLabel: "AgentBurst Match (autonom)", compStatus: "check" as const, compLabel: "Amplify AI" },
  { feature: "DSGVO", ssStatus: "check" as const, ssLabel: "EU-nativ", compStatus: "warn" as const, compLabel: "Mit EU-Addon" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "check" as const, compLabel: "Integriert" },
  { feature: "Karriereseite", ssStatus: "check" as const, ssLabel: "Embeddable Widget", compStatus: "check" as const, compLabel: "CareerPortal" },
  { feature: "Integrationen", ssStatus: "warn" as const, ssLabel: "API + wachsend", compStatus: "check" as const, compLabel: "300+ Marketplace" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "check" as const, compLabel: "Vollständig" },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen ShortSelect und Bullhorn?",
    answer: "Bullhorn ist eine Enterprise-Staffing-Suite mit über 300 Marketplace-Integrationen, deren Einführung Wochen bis Monate dauert. ShortSelect ist ein DSGVO-konformes, EU-natives ATS mit KI-Engine AgentBurst, das in Minuten einsatzbereit ist und sich an Recruiting-Agenturen von KMU bis Enterprise richtet.",
  },
  {
    question: "Für wen ist Bullhorn besser geeignet?",
    answer: "Bullhorn passt besser für große Staffing-Unternehmen mit 100 und mehr Recruitern weltweit, komplexen Compliance-Anforderungen, Bedarf an hunderten fertigen Integrationen und einem dedizierten IT-Team für Setup und Wartung.",
  },
  {
    question: "Was kostet ShortSelect im Vergleich zu Bullhorn?",
    answer: "ShortSelect kostet im Pro Plan 199 € pro User/Monat oder 1.791 € pro User/Jahr (3 Monate geschenkt), inklusive 30 Tage kostenlosem Test ohne Kreditkarte. Bullhorn startet ab etwa 99 US-Dollar pro User/Monat, die Gesamtkosten hängen aber stark von Modulen und Setup ab.",
  },
  {
    question: "Ist ShortSelect DSGVO-konformer als Bullhorn?",
    answer: "ShortSelect ist EU-nativ mit EU-Hosting und DSGVO-Konformität ab Werk. Bullhorn ist ein US-Anbieter, bei dem DSGVO-Konformität über ein EU-Addon gelöst wird. Für Teams mit strengen Datenschutz-Anforderungen im DACH-Raum ist ShortSelect der direktere Weg.",
  },
  {
    question: "Wie wechsle ich von Bullhorn zu ShortSelect?",
    answer: "Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer Wechsel-Seite.",
    answerHtml: 'Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer <a href="/wechsel/" class="text-primary hover:underline">Wechsel-Seite</a>.',
  },
];
---

<VergleichLayout
  title="ShortSelect vs. Bullhorn - ATS Vergleich 2026"
  description="Bullhorn ist Enterprise-Staffing mit langem Setup. ShortSelect: DSGVO EU-nativ, KI-Agenten, ab 199 € pro User, startklar in Minuten. Fairer Vergleich."
  competitorName="Bullhorn"
  heroSubline="Enterprise-Gigant oder agile Innovation? Bullhorn ist der weltgrößte ATS-Anbieter für Personaldienstleister. Aber ist größer immer besser?"
  heroBadge="Vergleich"
  ssDescription="KI-Agent-ATS mit autonomen AgentBurst-Agenten"
  ssHighlights={["AgentBurst-Agenten arbeiten 24/7", "Setup in wenigen Minuten", "DSGVO-konform ab Werk (EU-nativ)", "199 € pro User/Monat transparent"]}
  compDescription="Enterprise-ATS für globales Staffing"
  compHighlights={["300+ Marketplace-Integrationen", "Amplify AI für Automatisierung", "Globale Enterprise-Skalierung", "Umfassende Staffing-Suite"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Bullhorn besser passt",
    intro: "Bullhorn ist die richtige Wahl für große Staffing-Unternehmen mit komplexen Anforderungen:",
    items: [
      "Enterprise mit 100+ Recruitern weltweit",
      "Sie brauchen 300+ fertige Integrationen",
      "Globales Staffing mit mehreren Ländern",
      "Komplexe Compliance- und Reporting-Anforderungen",
      "Dediziertes IT-Team für Setup und Wartung",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Sie schnell und ohne Overhead starten wollen:",
    items: [
      "Autonome KI-Agenten statt manuelle Features",
      "Faire Preise ohne versteckte Kosten",
      "Modernes UI, das Recruiter lieben",
      "KI-Matching ohne Enterprise-Preise",
      "DSGVO-konform ohne zusätzliche Add-ons",
    ]
  }}
  faqs={faqs}
/>
