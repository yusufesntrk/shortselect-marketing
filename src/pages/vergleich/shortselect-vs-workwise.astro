---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "Modell", ssStatus: "check" as const, ssLabel: "Pure SaaS", compStatus: "warn" as const, compLabel: "SaaS + Service-Hybrid" },
  { feature: "Preise", ssStatus: "check" as const, ssLabel: "199 € pro User/Monat", compStatus: "warn" as const, compLabel: "15-25% des Jahresgehalts" },
  { feature: "KI-Features", ssStatus: "check" as const, ssLabel: "Voll integriert", compStatus: "warn" as const, compLabel: "Begrenzt" },
  { feature: "Kontrolle", ssStatus: "check" as const, ssLabel: "Volle Kontrolle", compStatus: "warn" as const, compLabel: "Workwise steuert teilweise" },
  { feature: "Karriereseite", ssStatus: "check" as const, ssLabel: "Embeddable Widget", compStatus: "check" as const, compLabel: "Vorhanden" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Pipeline", ssStatus: "check" as const, ssLabel: "Drag & Drop", compStatus: "check" as const, compLabel: "Vorhanden" },
  { feature: "Talent Pool", ssStatus: "check" as const, ssLabel: "Unbegrenzt", compStatus: "warn" as const, compLabel: "Begrenzt" },
  { feature: "API Zugang", ssStatus: "check" as const, ssLabel: "REST API", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen ShortSelect und Workwise?",
    answer: "Workwise ist ein Hybrid aus Software und Recruiting-Dienstleistung: Workwise schaltet Anzeigen, sourct Kandidaten und berät, steuert damit aber auch Teile Ihres Prozesses. ShortSelect ist eine reine SaaS-Plattform, mit der Sie Ihre Recruiting-Prozesse selbst aufbauen und volle Kontrolle behalten, inklusive KI-Matching, Multi-Tenancy und Client Portal.",
  },
  {
    question: "Für wen ist Workwise besser geeignet?",
    answer: "Workwise passt besser, wenn Sie Recruiting komplett auslagern möchten, kein internes Recruiting-Team haben, schnelle Besetzung wichtiger ist als eigener Prozessaufbau und Budget für erfolgsbasierte Vermittlung vorhanden ist.",
  },
  {
    question: "Was kostet ShortSelect im Vergleich zu Workwise?",
    answer: "ShortSelect kostet im Pro Plan planbar 199 € pro User/Monat oder 1.791 € pro User/Jahr (3 Monate geschenkt), mit 30 Tagen kostenlosem Test ohne Kreditkarte. Workwise rechnet erfolgsbasiert mit 15 bis 25 Prozent des Jahresgehalts pro Vermittlung ab, bei einer einzigen Besetzung kann das ein Vielfaches kosten.",
  },
  {
    question: "Hat Workwise eine API wie ShortSelect?",
    answer: "Nein. Workwise bietet keinen API-Zugang, auch Client Portal und Multi-Tenancy fehlen. ShortSelect stellt eine REST API bereit, mit der Sie das ATS in bestehende Systeme und Workflows integrieren können.",
  },
  {
    question: "Wie wechsle ich von Workwise zu ShortSelect?",
    answer: "Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer Wechsel-Seite.",
    answerHtml: 'Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer <a href="/wechsel/" class="text-primary hover:underline">Wechsel-Seite</a>.',
  },
];
---

<VergleichLayout
  title="ShortSelect vs. Workwise - ATS Vergleich 2026"
  description="Workwise: Service-Hybrid mit erfolgsbasierten Gebühren. ShortSelect: pure SaaS mit KI und voller Kontrolle ab 199 € pro User. Fairer Vergleich."
  competitorName="Workwise"
  heroSubline="Workwise kombiniert Software mit Recruiting-Dienstleistung. Wir zeigen die Unterschiede."
  heroBadge="Vergleich"
  ssDescription="Pure SaaS-Plattform mit voller Kontrolle"
  ssHighlights={["KI-gestütztes Kandidaten-Matching", "Volle Kontrolle über Prozesse", "199 € pro User/Monat", "Multi-Tenancy & Client Portal"]}
  compDescription="Recruiting-Service mit Software-Komponente"
  compHighlights={["Erfolgsbasierte Vermittlung", "Jobanzeigen-Schaltung inklusive", "Kandidaten-Sourcing durch Workwise", "Beratung im Recruiting-Prozess"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Workwise besser passt",
    intro: "Workwise ist die richtige Wahl, wenn Sie wenig Zeit haben und Budget für eine Dienstleistung mitbringen:",
    items: [
      "Sie möchten Recruiting komplett auslagern",
      "Kein internes Recruiting-Team vorhanden",
      "Schnelle Besetzung wichtiger als Prozessaufbau",
      "Budget für erfolgsbasierte Vermittlung (15-25%)",
      "Keine eigene Karriereseiten-Strategie geplant",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Sie volle Kontrolle und eigene Prozesse wollen:",
    items: [
      "Eigene Recruiting-Prozesse aufbauen und steuern",
      "KI-gestütztes Matching ohne Abhängigkeit",
      "Multi-Mandanten-Verwaltung für Agenturen",
      "Client Portal für transparente Zusammenarbeit",
      "Kostenloser Start ohne erfolgsbasierte Gebuehren",
    ]
  }}
  faqs={faqs}
/>
