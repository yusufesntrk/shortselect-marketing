---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "KI-Agenten", ssStatus: "check" as const, ssLabel: "AgentBurst-Agenten", compStatus: "x" as const, compLabel: "Keine" },
  { feature: "Autonomes Matching", ssStatus: "check" as const, ssLabel: "AgentBurst Match", compStatus: "warn" as const, compLabel: "Manuell auslösen" },
  { feature: "Preistransparenz", ssStatus: "check" as const, ssLabel: "Ab 0\u20AC/Monat", compStatus: "x" as const, compLabel: "Versteckte Kosten" },
  { feature: "Support-Qualität", ssStatus: "check" as const, ssLabel: "Persönlicher Support", compStatus: "warn" as const, compLabel: "Rückläufig seit Access-Übernahme" },
  { feature: "Suchgeschwindigkeit", ssStatus: "check" as const, ssLabel: "Echtzeit", compStatus: "warn" as const, compLabel: "Langsam" },
  { feature: "UI/Design", ssStatus: "check" as const, ssLabel: "Modern", compStatus: "warn" as const, compLabel: "Veraltet" },
  { feature: "DSGVO", ssStatus: "check" as const, ssLabel: "EU-nativ", compStatus: "warn" as const, compLabel: "Australischer Anbieter" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "check" as const, compLabel: "Integriert" },
  { feature: "CV Parsing", ssStatus: "check" as const, ssLabel: "AgentBurst Parse", compStatus: "warn" as const, compLabel: "Basis" },
  { feature: "Setup-Zeit", ssStatus: "check" as const, ssLabel: "Minuten", compStatus: "warn" as const, compLabel: "Wochen" },
];
---

<VergleichLayout
  title="ShortSelect vs Vincere: DSGVO-ATS ab 0 € statt Access"
  description="Seit Access-Übernahme: weniger Support, versteckte Kosten, langsame Suche. ShortSelect: ab 0 €, DSGVO EU-nativ, Echtzeit-Suche, autonome KI. In 15 Min umziehen."
  competitorName="Vincere"
  heroSubline="Vincere war ein starkes ATS. bis Access Group übernahm. Seitdem: Support-Probleme, versteckte Kosten, langsame Suche. Zeit für eine Alternative mit echten KI-Agenten."
  heroBadge="Vergleich"
  ssDescription="KI-Agent-ATS mit autonomen AgentBurst-Agenten"
  ssHighlights={["AgentBurst-Agenten arbeiten 24/7", "Transparente Preise ab 0\u20AC", "Persönlicher Support ohne Wartezeiten", "Echtzeit-Suche und blitzschnelles CV Parsing"]}
  compDescription="Recruiting-CRM nach Access-Übernahme"
  compHighlights={["Breites Feature-Set für Agenturen", "CRM + ATS in einer Plattform", "Etabliert im UK/ANZ-Markt", "Integriertes Client Portal"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Vincere besser passt",
    intro: "Vincere kann die richtige Wahl sein, wenn Sie bereits tief integriert sind:",
    items: [
      "Bereits tief in Vincere integriert mit vielen Workflows",
      "Fokus auf den UK- oder ANZ-Markt",
      "Keine autonomen KI-Agenten benötigt",
      "Bisheriger Support-Level war ausreichend",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Sie autonome KI und faire Preise wollen:",
    items: [
      "Autonome AgentBurst-Agenten statt manueller Prozesse",
      "Transparente Preise ohne versteckte Kosten",
      "Schneller, persönlicher Support ohne Wartezeiten",
      "DSGVO-konform und EU-nativ ohne Kompromisse",
      "Modernes Interface mit Echtzeit-Suche",
    ]
  }}
/>
