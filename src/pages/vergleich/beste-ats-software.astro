---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import CTASection from '../../components/landing/CTASection.astro';

const pageDescription = "Die 5 besten ATS 2026 im DACH-Vergleich: ShortSelect, Personio, Softgarden, Recruitee, SAP. Features, Preise, KI-Matching, Empfehlung für Agenturen.";

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Beste ATS Software 2026 im Vergleich",
  description: pageDescription,
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.shortselect.com/" },
    { "@type": "ListItem", "position": 2, "name": "Vergleich", "item": "https://www.shortselect.com/vergleich/" },
    { "@type": "ListItem", "position": 3, "name": "Beste ATS Software 2026" }
  ]
};

const faqs = [
  {
    question: "Welche ist die beste ATS Software 2026 im DACH-Raum?",
    answer: "Für Personalberatungen und Recruiting-Agenturen ist ShortSelect unsere Empfehlung: KI-Matching, Multi-Tenancy und Client Portal sind integriert, der Preis ist transparent pro User. Für Unternehmen, die eine komplette HR-Suite suchen, ist Personio die stärkere Wahl, für globale Konzerne SAP SuccessFactors.",
  },
  {
    question: "Worauf sollte ich bei der Auswahl einer ATS Software achten?",
    answer: "Die fünf wichtigsten Kriterien: echtes KI-Matching statt reiner Keyword-Suche, Skalierbarkeit mit Multi-Tenancy für Agenturen, offene Integrationen über REST API und Webhooks, transparente Preise ohne versteckte Kosten mit Testphase sowie deutschsprachiger Support mit schnellen Reaktionszeiten.",
  },
  {
    question: "Was kostet ShortSelect?",
    answer: "ShortSelect kostet im Pro Plan 199 € pro User/Monat oder 1.791 € pro User/Jahr (3 Monate geschenkt). Sie testen 14 Tage kostenlos ohne Kreditkarte. Von den fünf verglichenen Systemen bietet nur ShortSelect einen 14-Tage-Test.",
  },
  {
    question: "Was ist der Unterschied zwischen einem ATS und einer HR-Suite?",
    answer: "Ein ATS wie ShortSelect ist auf Bewerbermanagement und Recruiting spezialisiert: Pipeline, Kandidaten, Matching, Karriereseite. Eine HR-Suite wie Personio oder SAP SuccessFactors deckt zusätzlich Lohnabrechnung, Zeiterfassung und Personalverwaltung ab, das Recruiting-Modul ist dort aber oft weniger tief.",
  },
  {
    question: "Welches ATS eignet sich für Recruiting-Agenturen mit mehreren Kunden?",
    answer: "Von den fünf verglichenen Systemen bietet nur ShortSelect die Kombination aus Multi-Tenancy und integriertem Client Portal. Damit verwalten Agenturen mehrere Mandanten getrennt und binden ihre Kunden transparent in den Prozess ein. Personio, Softgarden und Recruitee sind auf einzelne Unternehmen ausgelegt.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer,
    },
  })),
};

const jsonLd = [webPageSchema, breadcrumbSchema, faqSchema];

const rankingData = [
  { rank: 1, name: "ShortSelect", tagline: "Bestes KI-ATS für Agenturen", recommended: true, highlights: ["KI-Matching", "Multi-Tenancy", "Client Portal", "199 € pro User"] },
  { rank: 2, name: "Personio", tagline: "Beste HR-Suite mit ATS", recommended: false, highlights: ["HR All-in-One", "Lohnabrechnung", "Zeiterfassung", "Ab ~200€"] },
  { rank: 3, name: "Softgarden", tagline: "Solides ATS für Mittelstand", recommended: false, highlights: ["Kanban Board", "Karriereseite", "Analytics", "Auf Anfrage"] },
  { rank: 4, name: "Recruitee", tagline: "Gutes ATS für kleine Teams", recommended: false, highlights: ["Einfache Bedienung", "Karriereseite", "Kollaboration", "Ab ~99€"] },
  { rank: 5, name: "SAP SuccessFactors", tagline: "Enterprise HR-Suite", recommended: false, highlights: ["Enterprise-Grade", "SAP Integration", "Global", "Enterprise-Pricing"] },
];

const comparisonGrid = [
  { feature: "KI-Matching", ss: "check", personio: "x", softgarden: "x", recruitee: "x", sap: "warn" },
  { feature: "Kanban Pipeline", ss: "check", personio: "warn", softgarden: "check", recruitee: "check", sap: "check" },
  { feature: "Multi-Tenancy", ss: "check", personio: "x", softgarden: "x", recruitee: "x", sap: "check" },
  { feature: "Client Portal", ss: "check", personio: "x", softgarden: "x", recruitee: "x", sap: "x" },
  { feature: "Talent Pools", ss: "check", personio: "warn", softgarden: "warn", recruitee: "check", sap: "check" },
  { feature: "Karriereseite", ss: "check", personio: "check", softgarden: "check", recruitee: "check", sap: "check" },
  { feature: "Analytics", ss: "check", personio: "check", softgarden: "check", recruitee: "warn", sap: "check" },
  { feature: "API Zugang", ss: "check", personio: "check", softgarden: "check", recruitee: "check", sap: "check" },
  { feature: "DSGVO-konform", ss: "check", personio: "check", softgarden: "check", recruitee: "check", sap: "check" },
  { feature: "14-Tage-Test", ss: "check", personio: "x", softgarden: "x", recruitee: "x", sap: "x" },
];

function statusSvg(status: string) {
  if (status === 'check') return '<svg class="h-4 w-4 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>';
  if (status === 'x') return '<svg class="h-4 w-4 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
  return '<svg class="h-4 w-4 text-yellow-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>';
}

const buyerTips = [
  { title: "KI-Features", description: "Prüfen Sie, ob echtes KI-Matching integriert ist oder nur Keyword-Suche. Automatisches Kandidaten-Ranking spart Stunden." },
  { title: "Skalierbarkeit", description: "Wächst das System mit Ihrem Team? Multi-Tenancy und unbegrenzte Nutzer sind entscheidend für Agenturen." },
  { title: "Integrationen", description: "REST API, Webhooks und Widget-Embedding ermöglichen nahtlose Integration in bestehende Workflows." },
  { title: "Preis-Leistung", description: "Achten Sie auf versteckte Kosten. Ein transparenter User-Preis und ein kostenloser Test machen Angebote vergleichbar." },
  { title: "Support", description: "Deutschsprachiger Support und schnelle Reaktionszeiten sind im DACH-Markt ein Muss." },
];
---

<MarketingLayout title="Beste ATS Software 2026 im Vergleich - ShortSelect" description={pageDescription} jsonLd={jsonLd}>
  <!-- Sichtbare Breadcrumb-Navigation -->
  <nav aria-label="Breadcrumb" class="container mx-auto px-4 pt-6">
    <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted-foreground">
      <li><a href="/" class="hover:text-primary transition-colors">Start</a></li>
      <li aria-hidden="true">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </li>
      <li><a href="/vergleich/" class="hover:text-primary transition-colors">ATS-Vergleich</a></li>
      <li aria-hidden="true">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </li>
      <li aria-current="page" class="text-foreground font-medium">Beste ATS Software 2026</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="relative overflow-hidden py-20 md:py-32">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-accent/5 to-background"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,hsl(var(--primary)/0.15),transparent_50%)]"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-accent/10 rounded-full blur-3xl animate-float-slow" style="animation-delay: -3s;"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]"></div>

    <div class="container relative mx-auto px-4">
      <div class="mx-auto max-w-4xl text-center space-y-8">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 hero-badge-premium">
          <svg class="h-4 w-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          Aktualisiert März 2026
        </div>

        <h1 class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-4xl md:text-6xl lg:text-7xl font-display font-bold tracking-tight" style="transition-delay: 100ms;">
          Beste ATS Software{" "}
          <span class="relative inline-block text-primary">2026</span>{" "}
          im Vergleich
        </h1>

        <p class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto" style="transition-delay: 200ms;">
          Der ehrliche Vergleich der Top Bewerbermanagement-Systeme für den DACH-Markt.
        </p>

        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 flex flex-col sm:flex-row items-center justify-center gap-4 pt-4" style="transition-delay: 300ms;">
          <a href="#ranking" class="inline-flex items-center gap-2 px-8 py-3 border-2 border-border font-semibold rounded-lg text-base transition-all hover:bg-muted">
            Zum Ranking
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="https://app.shortselect.com/signup" class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-primary-foreground font-semibold rounded-lg text-base group relative overflow-hidden shadow-lg hover:shadow-xl transition-all hover:scale-105">
            <span class="relative z-10 flex items-center gap-2">
              <svg class="h-5 w-5 animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
              Testsieger ausprobieren
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ranking -->
  <section id="ranking" class="py-16 md:py-24 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight mb-4">Top 5 ATS-Systeme DACH</h2>
          <p class="text-muted-foreground text-lg">Basierend auf Features, Preis-Leistung und Nutzerbewertungen.</p>
        </div>

        <div class="space-y-4">
          {rankingData.map((item, index) => (
            <div class:list={["reveal-item opacity-0 translate-y-8 transition-all duration-700 relative rounded-xl border p-5", item.recommended ? "bg-primary/5 border-primary/20 shadow-md" : "bg-background hover:bg-muted/50 transition-colors"]} style={`transition-delay: ${Math.min((index + 1) * 100, 500)}ms;`}>
              <div class="flex items-start gap-4">
                <div class:list={["flex h-12 w-12 shrink-0 items-center justify-center rounded-full font-display font-bold text-lg", item.rank === 1 ? "bg-primary text-white shadow-lg" : "bg-muted text-muted-foreground"]}>
                  {item.rank}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 flex-wrap">
                    <h3 class="text-lg font-display font-bold">{item.name}</h3>
                    {item.recommended && (
                      <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-primary/10 text-primary border border-primary/20">Unsere Empfehlung</span>
                    )}
                  </div>
                  <p class="text-sm text-muted-foreground mt-1">{item.tagline}</p>
                  <div class="flex flex-wrap gap-2 mt-3">
                    {item.highlights.map((h) => (
                      <span class="inline-flex items-center text-xs px-2.5 py-1 rounded-full bg-muted text-muted-foreground">{h}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Grid -->
  <section class="py-16 md:py-24">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight mb-4">Detaillierter Feature-Vergleich</h2>
          <p class="text-muted-foreground text-lg">Alle 5 Systeme im direkten Vergleich.</p>
        </div>

        <div class="overflow-x-auto -mx-4 px-4">
          <div class="min-w-[700px]">
            <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 grid grid-cols-6 gap-2 px-4 py-3 rounded-t-lg bg-muted font-semibold text-sm">
              <span>Feature</span>
              <span class="text-center text-primary font-bold">ShortSelect</span>
              <span class="text-center">Personio</span>
              <span class="text-center">Softgarden</span>
              <span class="text-center">Recruitee</span>
              <span class="text-center">SAP SF</span>
            </div>

            {comparisonGrid.map((row, index) => (
              <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 grid grid-cols-6 gap-2 px-4 py-3 border-b last:border-b-0 items-center" style={`transition-delay: ${Math.min((index + 1) * 80, 500)}ms;`}>
                <span class="font-medium text-sm">{row.feature}</span>
                <div class="flex items-center justify-center bg-primary/5 rounded-lg py-1.5"><Fragment set:html={statusSvg(row.ss)} /></div>
                <div class="flex items-center justify-center py-1.5"><Fragment set:html={statusSvg(row.personio)} /></div>
                <div class="flex items-center justify-center py-1.5"><Fragment set:html={statusSvg(row.softgarden)} /></div>
                <div class="flex items-center justify-center py-1.5"><Fragment set:html={statusSvg(row.recruitee)} /></div>
                <div class="flex items-center justify-center py-1.5"><Fragment set:html={statusSvg(row.sap)} /></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Buyer's Guide -->
  <section class="py-16 md:py-24 bg-muted/30 relative overflow-hidden">
    <div class="absolute top-20 right-0 w-72 h-72 bg-primary/5 rounded-full blur-3xl animate-float-slow"></div>
    <div class="container relative mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center mb-12">
        <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-secondary text-secondary-foreground mb-4">Buyer's Guide</span>
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight mb-4">Worauf Sie achten sollten</h2>
        <p class="text-muted-foreground text-lg max-w-2xl mx-auto">Die wichtigsten Kriterien bei der ATS-Auswahl für den DACH-Markt.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {buyerTips.map((tip, index) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 rounded-xl border bg-card p-6 hover:shadow-lg transition-all duration-300 hover:-translate-y-1" style={`transition-delay: ${Math.min((index + 1) * 100, 500)}ms;`}>
            <h3 class="text-lg font-display font-bold mb-2">{tip.title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed">{tip.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Verdict -->
  <section class="py-16 md:py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-accent/5"></div>
    <div class="container relative mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-3xl mx-auto text-center">
        <span class="inline-flex items-center rounded-md px-2.5 py-0.5 text-xs font-semibold bg-primary/10 text-primary border border-primary/20 mb-6">Unser Fazit</span>
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight mb-6">
          ShortSelect ist die beste Wahl für{" "}
          <span class="text-primary">Recruiting-Teams</span>
        </h2>
        <p class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-lg text-muted-foreground mb-8" style="transition-delay: 200ms;">
          Für Personalberatungen, Recruiting-Agenturen und HR-Teams, die ein spezialisiertes ATS mit KI-Features suchen, bietet ShortSelect das beste Gesamtpaket. Der transparente User-Preis, Multi-Tenancy und das integrierte Client Portal machen es zur ersten Wahl im DACH-Markt 2026.
        </p>
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 flex flex-wrap items-center justify-center gap-6 mb-10 text-sm text-muted-foreground" style="transition-delay: 300ms;">
          {["KI-Matching inklusive", "14 Tage testen", "DSGVO-konform", "Deutsche Oberfläche"].map((item) => (
            <span class="flex items-center gap-2">
              <svg class="h-4 w-4 text-green-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {item}
            </span>
          ))}
        </div>
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700" style="transition-delay: 400ms;">
          <a href="https://app.shortselect.com/signup" class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-primary-foreground font-semibold rounded-lg text-base group relative overflow-hidden shadow-lg hover:shadow-xl transition-all hover:scale-105">
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700"></div>
            <span class="relative z-10 flex items-center gap-2">
              <svg class="h-5 w-5 animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
              Testsieger kostenlos testen
              <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-4 mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">
          Häufige Fragen zur{" "}
          <span class="text-primary">ATS-Auswahl</span>
        </h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          Antworten auf die wichtigsten Fragen rund um die beste ATS Software 2026.
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map((faq) => (
          <details class="reveal-item opacity-0 translate-y-8 transition-all duration-700 group border rounded-lg px-6 bg-background hover:border-primary/30">
            <summary class="flex items-center justify-between py-4 cursor-pointer text-left font-semibold list-none [&::-webkit-details-marker]:hidden">
              <span>{faq.question}</span>
              <svg class="h-5 w-5 text-muted-foreground shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <div class="pb-4 text-muted-foreground">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</MarketingLayout>

<script is:inline>
(function() {
  var items = document.querySelectorAll('.reveal-item');
  if (!items.length) return;
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(function(item) { observer.observe(item); });
})();
</script>
