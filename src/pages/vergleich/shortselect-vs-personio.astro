---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "KI-Matching", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfuegbar" },
  { feature: "Kanban Pipeline", ssStatus: "check" as const, ssLabel: "Drag & Drop", compStatus: "warn" as const, compLabel: "Basis" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollstaendig", compStatus: "x" as const, compLabel: "Single-Tenant" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfuegbar" },
  { feature: "Karriereseite Widget", ssStatus: "check" as const, ssLabel: "Embeddable", compStatus: "warn" as const, compLabel: "Nur eigene Seite" },
  { feature: "Talent Pools", ssStatus: "check" as const, ssLabel: "Unbegrenzt", compStatus: "warn" as const, compLabel: "Eingeschraenkt" },
  { feature: "Interview Scheduling", ssStatus: "check" as const, ssLabel: "Automatisch", compStatus: "warn" as const, compLabel: "Manuell" },
  { feature: "API Zugang", ssStatus: "check" as const, ssLabel: "REST API", compStatus: "check" as const, compLabel: "REST API" },
  { feature: "Preis", ssStatus: "check" as const, ssLabel: "Ab 0\u20AC/Monat", compStatus: "warn" as const, compLabel: "Ab ~200\u20AC/Monat" },
];
---

<VergleichLayout
  title="ShortSelect vs. Personio - ATS Vergleich 2026"
  description="Personio ist grossartig fuer HR. Fuer Recruiting brauchen Sie mehr. Vergleichen Sie Features, Preise und Usability von ShortSelect und Personio."
  competitorName="Personio"
  heroSubline="Personio ist grossartig fuer HR. Fuer Recruiting brauchen Sie mehr."
  heroBadge="Ehrlicher Vergleich"
  ssDescription="Spezialisiert auf Recruiting & ATS"
  ssHighlights={["KI-gestuetztes Kandidaten-Matching", "Multi-Mandanten fuer Agenturen", "Client Portal inklusive", "Kostenloser Einstieg"]}
  compDescription="HR-Suite mit ATS als Add-on"
  compHighlights={["Lohnabrechnung & Zeiterfassung", "Abwesenheitsmanagement", "Performance Reviews", "ATS als Zusatzmodul"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Personio besser passt",
    intro: "Personio ist die richtige Wahl, wenn Sie eine vollstaendige HR-Suite benoetigen:",
    items: [
      "Lohnabrechnung und Gehaltsmanagement",
      "Zeiterfassung und Arbeitszeitkonto",
      "Abwesenheitsmanagement",
      "Performance Reviews und Mitarbeitergespraeche",
      "All-in-One HR-Loesung ohne Spezialisierung",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Recruiting Ihr Kerngeschaeft ist:",
    items: [
      "Personalberatungen und Recruiting-Agenturen",
      "Teams, die KI-gestuetztes Matching brauchen",
      "Multi-Mandanten-Verwaltung fuer verschiedene Kunden",
      "Client Portal fuer transparente Zusammenarbeit",
      "Kostenloser Start ohne Mindestlaufzeit",
    ]
  }}
/>
