---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "KI-Matching", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Kanban Pipeline", ssStatus: "check" as const, ssLabel: "Drag & Drop", compStatus: "warn" as const, compLabel: "Basis" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "x" as const, compLabel: "Single-Tenant" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Karriereseite Widget", ssStatus: "check" as const, ssLabel: "Embeddable", compStatus: "warn" as const, compLabel: "Nur eigene Seite" },
  { feature: "Talent Pools", ssStatus: "check" as const, ssLabel: "Unbegrenzt", compStatus: "warn" as const, compLabel: "Eingeschränkt" },
  { feature: "Interview Scheduling", ssStatus: "check" as const, ssLabel: "Automatisch", compStatus: "warn" as const, compLabel: "Manuell" },
  { feature: "API Zugang", ssStatus: "check" as const, ssLabel: "REST API", compStatus: "check" as const, compLabel: "REST API" },
  { feature: "Preis", ssStatus: "check" as const, ssLabel: "149 € pro User/Monat", compStatus: "warn" as const, compLabel: "Ab ~200€/Monat" },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen ShortSelect und Personio?",
    answer: "Personio ist eine HR-Suite mit Lohnabrechnung, Zeiterfassung und Abwesenheitsmanagement, bei der das ATS ein Zusatzmodul ist. ShortSelect ist ein spezialisiertes Recruiting-ATS mit KI-Matching, Multi-Tenancy und Client Portal, gebaut für Personalberatungen und Recruiting-Agenturen.",
  },
  {
    question: "Für wen ist Personio besser geeignet?",
    answer: "Personio passt besser, wenn Sie eine vollständige HR-Suite für interne Prozesse brauchen: Lohnabrechnung, Gehaltsmanagement, Zeiterfassung, Abwesenheiten und Performance Reviews in einem System. Für reine Recruiting-Arbeit ist es dagegen nicht spezialisiert.",
  },
  {
    question: "Was kostet ShortSelect im Vergleich zu Personio?",
    answer: "ShortSelect kostet im Pioneer Plan 149 € pro User/Monat für die ersten 100 Agenturen, danach 300 € pro User/Monat, mit 30 Tagen kostenlosem Test ohne Kreditkarte und ohne Mindestlaufzeit. Personio startet ab etwa 200 € pro Monat, der genaue Preis hängt von Modulen und Mitarbeiterzahl ab.",
  },
  {
    question: "Kann ich mit Personio mehrere Mandanten verwalten wie mit ShortSelect?",
    answer: "Nein. Personio ist Single-Tenant und hat kein Client Portal. ShortSelect bietet vollständige Multi-Tenancy und ein integriertes Client Portal, sodass Recruiting-Agenturen mehrere Kunden getrennt verwalten und transparent zusammenarbeiten können.",
  },
  {
    question: "Wie wechsle ich von Personio zu ShortSelect?",
    answer: "Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer Wechsel-Seite.",
    answerHtml: 'Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer <a href="/wechsel/" class="text-primary hover:underline">Wechsel-Seite</a>.',
  },
];
---

<VergleichLayout
  title="ShortSelect vs. Personio - ATS Vergleich 2026"
  description="Personio ist HR-Suite mit ATS-Modul. ShortSelect ist reines Recruiting-ATS mit KI-Matching und Client Portal ab 149 € pro User. Fairer Vergleich."
  competitorName="Personio"
  heroSubline="Personio ist großartig für HR. Für Recruiting brauchen Sie mehr."
  heroBadge="Ehrlicher Vergleich"
  ssDescription="Spezialisiert auf Recruiting & ATS"
  ssHighlights={["KI-gestütztes Kandidaten-Matching", "Multi-Mandanten für Agenturen", "Client Portal inklusive", "149 € pro User/Monat transparent"]}
  compDescription="HR-Suite mit ATS als Add-on"
  compHighlights={["Lohnabrechnung & Zeiterfassung", "Abwesenheitsmanagement", "Performance Reviews", "ATS als Zusatzmodul"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Personio besser passt",
    intro: "Personio ist die richtige Wahl, wenn Sie eine vollständige HR-Suite benötigen:",
    items: [
      "Lohnabrechnung und Gehaltsmanagement",
      "Zeiterfassung und Arbeitszeitkonto",
      "Abwesenheitsmanagement",
      "Performance Reviews und Mitarbeitergespräche",
      "All-in-One HR-Lösung ohne Spezialisierung",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Recruiting Ihr Kerngeschäft ist:",
    items: [
      "Personalberatungen und Recruiting-Agenturen",
      "Teams, die KI-gestütztes Matching brauchen",
      "Multi-Mandanten-Verwaltung für verschiedene Kunden",
      "Client Portal für transparente Zusammenarbeit",
      "30-Tage-Test ohne Mindestlaufzeit",
    ]
  }}
  faqs={faqs}
/>
