---
import VergleichLayout from '../../layouts/VergleichLayout.astro';

const comparisonData = [
  { feature: "Sprache", ssStatus: "check" as const, ssLabel: "Deutsch-first", compStatus: "warn" as const, compLabel: "Englisch-first" },
  { feature: "DSGVO", ssStatus: "check" as const, ssLabel: "EU-Server, nativ", compStatus: "warn" as const, compLabel: "US-Server, Addon" },
  { feature: "KI-Features", ssStatus: "check" as const, ssLabel: "KI-Matching", compStatus: "check" as const, compLabel: "AI Screening" },
  { feature: "Preis", ssStatus: "check" as const, ssLabel: "199 € pro User/Monat", compStatus: "warn" as const, compLabel: "Ab ~$6.000/Jahr" },
  { feature: "Setup-Zeit", ssStatus: "check" as const, ssLabel: "Minuten", compStatus: "warn" as const, compLabel: "Wochen" },
  { feature: "Client Portal", ssStatus: "check" as const, ssLabel: "Integriert", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Multi-Tenancy", ssStatus: "check" as const, ssLabel: "Vollständig", compStatus: "x" as const, compLabel: "Nicht verfügbar" },
  { feature: "Karriereseite", ssStatus: "check" as const, ssLabel: "Embeddable Widget", compStatus: "check" as const, compLabel: "Job Board" },
  { feature: "Pipeline", ssStatus: "check" as const, ssLabel: "Kanban Drag & Drop", compStatus: "check" as const, compLabel: "Structured Hiring" },
  { feature: "Integrationen", ssStatus: "check" as const, ssLabel: "API + Webhooks", compStatus: "check" as const, compLabel: "400+ Integrationen" },
];

const faqs = [
  {
    question: "Was ist der Unterschied zwischen ShortSelect und Greenhouse?",
    answer: "Greenhouse ist der US-Marktführer mit Englisch-first-Oberfläche, US-Servern und über 400 Integrationen, ausgelegt auf internationale Enterprise-Teams. ShortSelect ist Deutsch-first, DSGVO-konform mit EU-Hosting und bietet Multi-Tenancy plus Client Portal, die Greenhouse nicht hat. Das macht ShortSelect zur besseren Wahl für Personalberatungen und Recruiting-Agenturen im DACH-Raum.",
  },
  {
    question: "Für wen ist Greenhouse besser geeignet?",
    answer: "Greenhouse passt besser für internationale Enterprises mit Recruiting in 20 und mehr Ländern, 500 und mehr Mitarbeitern, eigenem HR-Tech-Team, Englisch als Unternehmenssprache und Bedarf an hunderten Tool-Integrationen oder der Structured-Hiring-Methodik.",
  },
  {
    question: "Was kostet ShortSelect im Vergleich zu Greenhouse?",
    answer: "ShortSelect kostet im Pro Plan 199 € pro User/Monat oder 1.791 € pro User/Jahr (3 Monate geschenkt), mit 14 Tagen kostenlosem Test ohne Kreditkarte. Greenhouse startet bei etwa 6.000 US-Dollar pro Jahr und erfordert ein mehrwöchiges Onboarding.",
  },
  {
    question: "Ist Greenhouse DSGVO-konform für deutsche Unternehmen?",
    answer: "Greenhouse läuft auf US-Servern, DSGVO-Konformität wird über Zusatzvereinbarungen gelöst. ShortSelect hostet in der EU und ist DSGVO-konform ab Werk. Für deutsche Recruiting-Teams mit strenger Datenschutz-Pflicht ist das der einfachere und sicherere Weg.",
  },
  {
    question: "Wie wechsle ich von Greenhouse zu ShortSelect?",
    answer: "Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer Wechsel-Seite.",
    answerHtml: 'Der Umzug dauert in der Regel etwa 15 Minuten: Account erstellen, Kandidaten und Jobs per CSV oder API importieren, Team einladen und loslegen. Eine Schritt-für-Schritt-Anleitung finden Sie auf unserer <a href="/wechsel/" class="text-primary hover:underline">Wechsel-Seite</a>.',
  },
];
---

<VergleichLayout
  title="ShortSelect vs Greenhouse: DACH-ATS für 199 € pro User"
  description="Greenhouse: US-Server, Englisch-first, ab ~6.000 $/Jahr. ShortSelect: Deutsch-first, DSGVO EU-nativ, ab 199 € pro User. Der Vergleich für DACH-Teams."
  competitorName="Greenhouse"
  heroSubline="Greenhouse ist der US-Marktführer. Aber passt ein amerikanisches Enterprise-Tool zu deutschen Recruiting-Teams?"
  heroBadge="Vergleich"
  ssDescription="Agiles ATS für den DACH-Markt"
  ssHighlights={["Deutsch-first mit DSGVO nativ", "KI-gestütztes Kandidaten-Matching", "Multi-Tenancy & Client Portal", "199 € pro User/Monat, sofort einsatzbereit"]}
  compDescription="US-Enterprise ATS mit globalem Fokus"
  compHighlights={["400+ Integrationen im Marketplace", "Structured Hiring Methodik", "Enterprise-Grade Reporting", "Englisch-first, US-Server"]}
  comparisonData={comparisonData}
  whenCompBetter={{
    title: "Wann Greenhouse besser passt",
    intro: "Greenhouse ist die richtige Wahl, wenn Sie ein großes, internationales Enterprise-Team sind:",
    items: [
      "Internationales Recruiting in 20+ Ländern",
      "Enterprise mit 500+ Mitarbeitern und eigenem HR-Tech-Team",
      "Hunderte bestehende Tool-Integrationen nötig",
      "Structured Hiring als feste Methodik",
      "Englisch als Unternehmenssprache",
    ]
  }}
  whenSSBetter={{
    title: "Wann ShortSelect besser passt",
    intro: "ShortSelect ist ideal, wenn Sie ein agiles deutschsprachiges Recruiting-Team sind:",
    items: [
      "Deutsches Recruiting-Team mit DSGVO-Pflicht",
      "Personalberatungen und Recruiting-Agenturen",
      "Schneller Start ohne wochenlanges Onboarding",
      "KI-Matching ohne Enterprise-Budget",
      "Multi-Mandanten und Client Portal für Kunden",
    ]
  }}
  faqs={faqs}
/>
