---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import CTASection from '../components/landing/CTASection.astro';

const migrationSteps = [
  { title: "Account erstellen", description: "Kostenloses Konto in 30 Sekunden. Keine Kreditkarte." },
  { title: "Daten importieren", description: "Kandidaten-CSV hochladen oder manuell anlegen." },
  { title: "Pipeline einrichten", description: "Eigene Stages definieren oder Templates nutzen." },
  { title: "Karriereseite aktivieren", description: "Widget einbetten und sofort live gehen." },
  { title: "Team einladen", description: "Recruiter per E-Mail einladen. Rollen zuweisen." },
  { title: "Loslegen", description: "Fertig! Ihr neues ATS ist einsatzbereit." },
];

const migrationSources = [
  { title: "Von Excel/Spreadsheets", description: "CSV-Import fuer alle Kandidatendaten. Spalten automatisch zuordnen, keine Daten verlieren. In Minuten statt Stunden." },
  { title: "Von Personio", description: "Export aus Personio, Import in ShortSelect. Wir helfen beim Mapping der Felder und stellen sicher, dass alles uebernommen wird." },
  { title: "Von anderem ATS", description: "Egal welches System -- unsere API und der CSV-Import machen den Umzug einfach. Persoenliche Unterstuetzung inklusive." },
];

const supportFeatures = [
  { title: "Persoenliches Onboarding", description: "Wir helfen Ihnen beim Einrichten und beantworten alle Fragen." },
  { title: "Migrations-Support", description: "Datenimport mit persoenlicher Unterstuetzung. Kein Datenpunkt geht verloren." },
  { title: "Knowledge Base", description: "Schritt-fuer-Schritt Anleitungen fuer jeden Anwendungsfall." },
];
---

<MarketingLayout
  title="Wechsel zu ShortSelect – Migration in 15 Minuten | ShortSelect"
  description="Von Excel, Personio oder einem anderen ATS zu ShortSelect wechseln. In 6 einfachen Schritten zum neuen Recruiting-System."
>
  <!-- Hero -->
  <section class="relative py-24 md:py-36 overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 right-20 w-72 h-72 bg-[hsl(var(--primary)/0.05)] rounded-full blur-3xl animate-float-slow"></div>
      <div class="absolute bottom-20 left-10 w-64 h-64 bg-[hsl(var(--accent)/0.05)] rounded-full blur-3xl animate-float-slow" style="animation-delay: -4s;"></div>
    </div>

    <div class="container relative mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-3xl mx-auto text-center space-y-6">
        <span class="inline-block px-3 py-1 rounded-full bg-[hsl(var(--primary)/0.1)] text-[hsl(var(--primary))] border border-[hsl(var(--primary)/0.2)] text-sm font-medium">Einfacher Wechsel</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold tracking-tight leading-tight">
          Wechseln Sie zu ShortSelect -- <span class="text-[hsl(var(--primary))]">in 15 Minuten</span>.
        </h1>
        <p class="text-lg md:text-xl text-[hsl(var(--muted-foreground))] max-w-2xl mx-auto">
          Egal ob Sie von Excel, Personio oder einem anderen ATS kommen: Der Umzug ist einfacher als Sie denken.
        </p>
      </div>
    </div>
  </section>

  <!-- Migration Steps (Timeline) -->
  <section class="py-20 md:py-28 bg-[hsl(var(--muted)/0.3)]">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">In 6 Schritten zum neuen ATS</h2>
        <p class="text-[hsl(var(--muted-foreground))] mt-4 max-w-2xl mx-auto">Der Wechsel ist strukturiert und begleitet. Kein Schritt wird uebersprungen.</p>
      </div>

      <div class="max-w-2xl mx-auto">
        {migrationSteps.map((step, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 relative flex gap-6" style={`transition-delay: ${i * 80}ms;`}>
            <div class="flex flex-col items-center">
              <div class="h-10 w-10 rounded-full bg-[hsl(var(--primary))] text-white flex items-center justify-center text-sm font-bold shrink-0">{i + 1}</div>
              {i < migrationSteps.length - 1 && <div class="w-0.5 flex-1 bg-[hsl(var(--primary)/0.2)] my-2"></div>}
            </div>
            <div class="pb-10">
              <h3 class="font-display font-bold text-lg">{step.title}</h3>
              <p class="text-sm text-[hsl(var(--muted-foreground))] mt-1">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Migration Sources -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight mb-4">Woher kommen Sie?</h2>
        <p class="text-lg text-[hsl(var(--muted-foreground))]">Egal von welchem System -- wir machen den Wechsel einfach.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {migrationSources.map((source, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border border-[hsl(var(--border))] bg-[hsl(var(--card))] p-8 space-y-4" style={`transition-delay: ${i * 100}ms;`}>
            <h3 class="text-xl font-display font-bold">{source.title}</h3>
            <p class="text-sm text-[hsl(var(--muted-foreground))] leading-relaxed">{source.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Support -->
  <section class="py-20 md:py-28 bg-[hsl(var(--muted)/0.3)]">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight mb-4">Wir lassen Sie nicht allein</h2>
        <p class="text-lg text-[hsl(var(--muted-foreground))]">Persoenlicher Support bei jedem Schritt.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {supportFeatures.map((feature, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border border-[hsl(var(--border))] bg-[hsl(var(--card))] p-8 space-y-4" style={`transition-delay: ${i * 100}ms;`}>
            <h3 class="text-xl font-display font-bold">{feature.title}</h3>
            <p class="text-sm text-[hsl(var(--muted-foreground))] leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 grid grid-cols-3 gap-8 max-w-3xl mx-auto text-center">
        <div><div class="text-3xl md:text-4xl font-display font-bold text-[hsl(var(--primary))]">15 min</div><p class="text-sm text-[hsl(var(--muted-foreground))] mt-1">Setup-Zeit</p></div>
        <div><div class="text-3xl md:text-4xl font-display font-bold text-[hsl(var(--primary))]">0 EUR</div><p class="text-sm text-[hsl(var(--muted-foreground))] mt-1">Migrationskosten</p></div>
        <div><div class="text-3xl md:text-4xl font-display font-bold text-[hsl(var(--primary))]">100%</div><p class="text-sm text-[hsl(var(--muted-foreground))] mt-1">Datenuebernahme</p></div>
      </div>
    </div>
  </section>

  <CTASection />

  <script is:inline>
  (function() {
    var items = document.querySelectorAll('.reveal-item');
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>
</MarketingLayout>
