---
import MarketingLayout from '../../../layouts/MarketingLayout.astro';
import CTASection from '../../../components/landing/CTASection.astro';

const steps = [
  { number: 1, title: "Talent Pool aufbauen", description: "Systematisch Profile sammeln, auch ohne aktuelle Vakanz. Nutzen Sie ShortSelect Talent Pools, um vielversprechende Kandidaten langfristig zu erfassen und zu segmentieren.", tips: ["LinkedIn-Recherche mit gezielten Suchfiltern", "Branchenevents und Konferenzen als Quelle nutzen", "Interne Empfehlungen systematisch erfassen"] },
  { number: 2, title: "Personalisierte Ansprache", description: "Individuelle Nachrichten statt Massenmail. Nennen Sie den Namen, die aktuelle Firma und einen konkreten Bezug zur Person.", tips: ["Bezug auf aktuelle Projekte oder Erfolge nehmen", "Gemeinsame Kontakte oder Interessen erwaehnen", "Kurz und praegnant -- max. 5 Saetze in der Erstansprache"] },
  { number: 3, title: "Timing ist alles", description: "Die beste Nachricht bringt nichts, wenn sie zum falschen Zeitpunkt kommt. Dienstag bis Donnerstag, zwischen 9 und 11 Uhr, erzielen Sie die hoechsten Antwortraten.", tips: ["Montag und Freitag vermeiden", "Follow-up freundlich formulieren, nicht draengend", "Maximal 3 Kontaktversuche pro Kandidat"] },
  { number: 4, title: "Mehrwert bieten", description: "Nicht nur einen Job anbieten, sondern eine echte Karrierechance aufzeigen. Passive Kandidaten brauchen einen Grund, ihren sicheren Hafen zu verlassen.", tips: ["Konkrete Wachstumsperspektiven benennen", "Teamkultur und Arbeitsweise beschreiben", "Gehaltsrahmen fruehzeitig kommunizieren"] },
  { number: 5, title: "Beziehung pflegen", description: "Auch bei einer Absage: Bleiben Sie in Kontakt. Senden Sie regelmaessige Updates aus Ihrem Talent Pool.", tips: ["Quartalweise Talent-Pool-Updates versenden", "Branchenrelevante Inhalte teilen", "Bei Absagen immer die Tuer offen halten"] },
];

const quickTips = [
  { title: "Betreffzeile entscheidet", description: "Die ersten 6 Worte bestimmen, ob Ihre Nachricht geoeffnet wird. Machen Sie sie persoenlich und neugierig." },
  { title: "Warm Intros nutzen", description: "Eine Vorstellung ueber gemeinsame Kontakte erzielt 5x hoehere Antwortraten als Cold Outreach." },
  { title: "Kein Copy-Paste", description: "Kandidaten erkennen Massenmails sofort. Jede Nachricht sollte mindestens einen individuellen Satz enthalten." },
  { title: "Schnell reagieren", description: "Wenn ein passiver Kandidat antwortet, reagieren Sie innerhalb von 24 Stunden." },
  { title: "Erst geben, dann nehmen", description: "Teilen Sie einen relevanten Artikel oder Insight, bevor Sie nach einem Gespraech fragen." },
];
---

<MarketingLayout title="Playbook: Passive Kandidaten aktivieren - ShortSelect" description="80% der besten Talente suchen nicht aktiv. So erreichen und ueberzeugen Sie passive Kandidaten mit systematischem Active Sourcing.">
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 md:py-36">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-primary/5 to-background"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,hsl(var(--primary)/0.15),transparent_50%)]"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]"></div>

    <div class="container relative mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center space-y-8">
        <nav class="reveal-item opacity-0 translate-y-8 transition-all duration-700 flex items-center justify-center gap-2 text-sm text-muted-foreground">
          <a href="/methode/smart-recruiting" class="hover:text-primary transition-colors">Smart Recruiting</a>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          <span class="text-primary font-medium">Playbook</span>
        </nav>
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500" style="transition-delay: 100ms;">
          <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-primary/10 text-primary border-primary/20 gap-1.5">Playbook</span>
        </div>
        <h1 class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-4xl md:text-6xl lg:text-7xl font-display font-bold tracking-tight" style="transition-delay: 200ms;">Passive Kandidaten <span class="text-primary">aktivieren</span></h1>
        <p class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto" style="transition-delay: 300ms;">80% der besten Talente suchen nicht aktiv. So erreichen und ueberzeugen Sie sie trotzdem.</p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- Stats -->
  <section class="py-16 md:py-20 bg-gradient-to-br from-primary via-primary/90 to-accent text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:24px_24px] opacity-30"></div>
    <div class="container relative mx-auto px-4">
      <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-8">
        {[
          { value: "80%", label: "passive Kandidaten" },
          { value: "3x", label: "hoehere Qualitaet" },
          { value: "5-7 Tage", label: "optimales Follow-up" },
        ].map((stat, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-center space-y-3" style={`transition-delay: ${i * 200}ms;`}>
            <div class="text-5xl md:text-6xl font-display font-bold">{stat.value}</div>
            <p class="text-white/80 font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Steps -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="container relative mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-4 mb-16">
        <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight">5 Schritte zum Erfolg</h2>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">Ein erprobter Prozess, um passive Kandidaten systematisch zu erreichen und fuer sich zu gewinnen.</p>
      </div>
      <div class="max-w-3xl mx-auto space-y-8">
        {steps.map((step, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border-2 border-primary/20 p-6 md:p-8 hover:shadow-lg bg-card" style={`transition-delay: ${Math.min(i * 100, 400)}ms;`}>
            <div class="flex items-start gap-5">
              <div class="flex-shrink-0 relative">
                <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center">
                  <span class="text-2xl font-display font-bold text-primary">{step.number}</span>
                </div>
              </div>
              <div class="space-y-4 flex-1">
                <div>
                  <p class="text-sm font-medium text-primary uppercase tracking-wider mb-1">Schritt {step.number}</p>
                  <h3 class="text-xl md:text-2xl font-display font-bold tracking-tight">{step.title}</h3>
                </div>
                <p class="text-muted-foreground leading-relaxed">{step.description}</p>
                <ul class="space-y-2">
                  {step.tips.map((tip) => (
                    <li class="flex items-start gap-2.5">
                      <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                      <span class="text-sm text-muted-foreground">{tip}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick Tips -->
  <section class="py-20 md:py-28 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-4 mb-16">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">Quick Tips</h2>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto">Konkrete Tipps fuer den Alltag im Active Sourcing.</p>
      </div>
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {quickTips.map((tip, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border p-6 hover:border-primary/20 hover:shadow-lg hover:-translate-y-1 bg-card" style={`transition-delay: ${Math.min(i * 100, 400)}ms;`}>
            <h3 class="font-display font-bold text-lg">{tip.title}</h3>
            <p class="text-sm text-muted-foreground mt-1 leading-relaxed">{tip.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-20 md:py-28 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-3xl mx-auto text-center space-y-8">
        <h2 class="text-3xl md:text-5xl font-display font-bold tracking-tight">Bereit, passive Talente <span class="text-primary">zu aktivieren?</span></h2>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto">ShortSelect gibt Ihnen die Werkzeuge, um dieses Playbook in die Praxis umzusetzen.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
          <a href="https://app.shortselect.com/signup" class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-primary-foreground font-semibold rounded-lg text-base group relative overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105">
            <span class="relative z-10 flex items-center gap-2">
              <svg class="h-5 w-5 animate-pulse" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/></svg>
              Jetzt kostenlos starten
              <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTASection />

  <script is:inline>
  (function() {
    var items = document.querySelectorAll('.reveal-item');
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>
</MarketingLayout>
