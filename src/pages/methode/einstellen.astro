---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import CTASection from '../../components/landing/CTASection.astro';

const features = [
  { title: "Interview Scheduling", description: "Self-Service Buchung fuer Kandidaten" },
  { title: "Client Portal", description: "Hiring Manager/Kunden in den Prozess einbinden" },
  { title: "E-Mail Automation", description: "Automatische Updates an alle Beteiligten" },
  { title: "Feedback Loop", description: "Strukturiertes Feedback nach jedem Interview" },
  { title: "Quick Offer", description: "Schnelle Angebotserstellung und -verwaltung" },
];
---

<MarketingLayout title="Phase 3: Einstellen - Smart Recruiting Methode" description="Interviews koordinieren, Angebote machen, Vertraege abschliessen -- ohne Reibungsverluste. Von der Bewerbung zum Vertrag in 22 Tagen.">
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 md:py-36">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/10 via-emerald-500/5 to-background"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-emerald-500/10 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]"></div>

    <div class="container relative mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center space-y-8">
        <nav class="reveal-item opacity-0 translate-y-8 transition-all duration-700 flex items-center justify-center gap-2 text-sm text-muted-foreground">
          <a href="/methode/smart-recruiting" class="hover:text-primary transition-colors">Smart Recruiting</a>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          <span class="text-emerald-500 font-medium">Einstellen</span>
        </nav>
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500" style="transition-delay: 100ms;">
          <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-emerald-500/10 text-emerald-500 border-emerald-500/20">Smart Recruiting</span>
        </div>
        <h1 class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-4xl md:text-6xl lg:text-7xl font-display font-bold tracking-tight" style="transition-delay: 200ms;">Phase 3: <span class="text-emerald-500">Einstellen</span></h1>
        <p class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto" style="transition-delay: 300ms;">Interviews koordinieren, Angebote machen, Vertraege abschliessen -- ohne Reibungsverluste.</p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- Features -->
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-4 mb-16">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">Was zu dieser Phase gehoert</h2>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto">Alle Werkzeuge fuer einen reibungslosen Einstellungsprozess.</p>
      </div>
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((f, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border p-6 hover:border-emerald-500/20 hover:shadow-lg hover:-translate-y-1 bg-card" style={`transition-delay: ${Math.min(i * 100, 400)}ms;`}>
            <h3 class="font-display font-bold text-lg">{f.title}</h3>
            <p class="text-sm text-muted-foreground mt-1">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-20 md:py-28 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-3xl mx-auto text-center space-y-10">
        <div class="space-y-4">
          <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">Von Bewerbung bis Vertrag</h2>
          <p class="text-lg text-muted-foreground">Durchschnittlich 22 Tage -- statt branchenueblicher 42.</p>
        </div>
        <div class="flex items-center justify-center gap-8 pt-4">
          <div class="text-center">
            <p class="text-3xl font-display font-bold text-emerald-500">22</p>
            <p class="text-xs text-muted-foreground mt-1">Tage mit ShortSelect</p>
          </div>
          <div class="text-2xl text-muted-foreground/50">vs.</div>
          <div class="text-center opacity-50">
            <p class="text-3xl font-display font-bold text-muted-foreground">42</p>
            <p class="text-xs text-muted-foreground mt-1">Branchendurchschnitt</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Next Phase -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-2xl mx-auto">
        <a href="/methode/binden" class="group flex items-center justify-between p-6 rounded-2xl border-2 border-primary/20 hover:border-primary/40 bg-primary/5 hover:bg-primary/10 transition-all duration-300">
          <div class="space-y-1">
            <p class="text-sm text-primary font-medium uppercase tracking-wider">Weiter zu Phase 4</p>
            <p class="text-xl font-display font-bold tracking-tight">Binden</p>
            <p class="text-sm text-muted-foreground">Talente langfristig gewinnen -- mit Talent Pools und Nurturing.</p>
          </div>
          <svg class="w-6 h-6 text-primary group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <CTASection />

  <script is:inline>
  (function() {
    var items = document.querySelectorAll('.reveal-item');
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>
</MarketingLayout>
