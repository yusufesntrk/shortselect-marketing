---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import CTASection from '../../components/landing/CTASection.astro';
import PhaseTestimonial from '../../components/landing/PhaseTestimonial.astro';

const features = [
  { title: "Karriereseite", description: "Ihre digitale Visitenkarte als Arbeitgeber" },
  { title: "Job Widget", description: "Stellen auf jeder Website -- einbetten und fertig" },
  { title: "Employer Branding", description: "Ihre Marke, Ihre Farben, Ihr Auftritt" },
  { title: "Multiposting", description: "Eine Anzeige, alle Kanäle" },
  { title: "SEO-Optimierung", description: "Ihre Stellen werden gefunden -- auf Google und Co." },
];

const bestPractices = [
  "Mobile-first Karriereseite",
  "Stellenanzeigen mit echten Einblicken",
  "Schnelle Bewerbung (max. 2 Minuten)",
  "Social Media als Recruiting-Kanal",
];
---

<MarketingLayout title="Phase 1: Anziehen - Smart Recruiting Methode" description="Machen Sie Ihr Unternehmen zum Magneten für Top-Talente. Karriereseite, Job Widget, Employer Branding und Multiposting.">
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 md:py-36">
    <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-primary/5 to-background"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_20%,hsl(var(--primary)/0.15),transparent_50%)]"></div>
    <div class="absolute top-20 left-10 w-72 h-72 bg-primary/10 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]"></div>

    <div class="container relative mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center space-y-8">
        <nav class="reveal-item opacity-0 translate-y-8 transition-all duration-700 flex items-center justify-center gap-2 text-sm text-muted-foreground">
          <a href="/methode/smart-recruiting" class="hover:text-primary transition-colors">Smart Recruiting</a>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          <span class="text-primary font-medium">Anziehen</span>
        </nav>
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500" style="transition-delay: 100ms;">
          <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-primary/10 text-primary border-primary/20">Smart Recruiting</span>
        </div>
        <h1 class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-4xl md:text-6xl lg:text-7xl font-display font-bold tracking-tight" style="transition-delay: 200ms;">Phase 1: <span class="text-primary">Anziehen</span></h1>
        <p class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto" style="transition-delay: 300ms;">Der erste Eindruck entscheidet. Machen Sie Ihr Unternehmen zum Magneten für Top-Talente.</p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- Features -->
  <section class="py-20 md:py-28 relative overflow-hidden">
    <div class="container relative mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-4 mb-16">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">Was zu dieser Phase gehört</h2>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto">Alle Werkzeuge, um Talente auf sich aufmerksam zu machen.</p>
      </div>
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature, index) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border p-6 hover:border-primary/20 hover:shadow-lg hover:-translate-y-1 bg-card" style={`transition-delay: ${Math.min(index * 100, 400)}ms;`}>
            <h3 class="font-display font-bold text-lg">{feature.title}</h3>
            <p class="text-sm text-muted-foreground mt-1">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Best Practices -->
  <section class="py-20 md:py-28 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-4 mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">Best Practices</h2>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto">4 Tipps, um mehr qualifizierte Bewerbungen zu erhalten.</p>
      </div>
      <div class="max-w-3xl mx-auto grid sm:grid-cols-2 gap-6">
        {bestPractices.map((practice, index) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border border-primary/10 p-5 flex items-start gap-4 bg-card" style={`transition-delay: ${index * 100}ms;`}>
            <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 mt-0.5">
              <svg class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <p class="font-medium">{practice}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Metric -->
  <section class="py-20 md:py-28 bg-gradient-to-br from-primary via-primary/90 to-accent text-white relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,255,255,0.1)_1px,transparent_1px)] bg-[size:24px_24px] opacity-30"></div>
    <div class="container relative mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-3xl mx-auto text-center space-y-6">
        <span class="text-6xl md:text-8xl font-display font-bold">200%</span>
        <p class="text-xl md:text-2xl text-white/90">mehr Bewerbungen mit optimierter Karriereseite</p>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <PhaseTestimonial
    names={["Bahadir Battal", "Dr. Thomas Wendel"]}
    title="Kunden, die ihre Pipeline neu aufgestellt haben"
    subtitle="So machen andere Recruiting-Teams ihre Pipeline messbar voller."
    accent="primary"
  />

  <!-- Next Phase -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-2xl mx-auto">
        <a href="/methode/auswaehlen" class="group flex items-center justify-between p-6 rounded-2xl border-2 border-accent/20 hover:border-accent/40 bg-accent/5 hover:bg-accent/10 transition-all duration-300">
          <div class="space-y-1">
            <p class="text-sm text-accent font-medium uppercase tracking-wider">Weiter zu Phase 2</p>
            <p class="text-xl font-display font-bold tracking-tight">Auswählen</p>
            <p class="text-sm text-muted-foreground">Die Besten erkennen -- mit KI-Matching und strukturiertem Screening.</p>
          </div>
          <svg class="w-6 h-6 text-accent group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <CTASection />

  <script is:inline>
  (function() {
    var items = document.querySelectorAll('.reveal-item');
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>
</MarketingLayout>
