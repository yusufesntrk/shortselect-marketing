---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import CTASection from '../../components/landing/CTASection.astro';

const features = [
  { title: "KI-Matching", description: "Automatischer Skills-Abgleich mit Match-Scores" },
  { title: "Kanban Pipeline", description: "Visuelles Pipeline-Management" },
  { title: "Screening Fragen", description: "Automatische Vorauswahl mit Knockout-Logik" },
  { title: "Smart Ranking", description: "Kandidaten nach Relevanz sortiert" },
  { title: "Team Collaboration", description: "Bewertungen und Notizen im Team teilen" },
];

const manualScreening = ["CVs einzeln durchlesen", "Bauchgefuehl statt Daten", "Unstrukturierte Notizen", "Kandidaten uebersehen", "Wochenlange Durchlaufzeit"];
const smartScreening = ["KI bewertet automatisch", "Match-Scores und Rankings", "Standardisierte Bewertungen", "Kein Kandidat geht verloren", "Entscheidung in Minuten"];
---

<MarketingLayout title="Phase 2: Auswaehlen - Smart Recruiting Methode" description="KI-gestuetztes Matching, strukturiertes Screening und datenbasierte Entscheidungen fuer bessere Kandidatenauswahl.">
  <!-- Hero -->
  <section class="relative overflow-hidden py-24 md:py-36">
    <div class="absolute inset-0 bg-gradient-to-br from-accent/10 via-accent/5 to-background"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_20%,hsl(var(--accent)/0.15),transparent_50%)]"></div>
    <div class="absolute top-20 right-10 w-72 h-72 bg-accent/10 rounded-full blur-3xl animate-float-slow"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(0,0,0,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(0,0,0,0.03)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_70%)]"></div>

    <div class="container relative mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center space-y-8">
        <nav class="reveal-item opacity-0 translate-y-8 transition-all duration-700 flex items-center justify-center gap-2 text-sm text-muted-foreground">
          <a href="/methode/smart-recruiting" class="hover:text-primary transition-colors">Smart Recruiting</a>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
          <span class="text-accent font-medium">Auswaehlen</span>
        </nav>
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500" style="transition-delay: 100ms;">
          <span class="inline-flex items-center rounded-md border px-2.5 py-0.5 text-xs font-semibold bg-accent/10 text-accent border-accent/20">Smart Recruiting</span>
        </div>
        <h1 class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-4xl md:text-6xl lg:text-7xl font-display font-bold tracking-tight" style="transition-delay: 200ms;">Phase 2: <span class="text-accent">Auswaehlen</span></h1>
        <p class="reveal-item opacity-0 translate-y-8 transition-all duration-500 text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto" style="transition-delay: 300ms;">KI-gestuetztes Matching, strukturiertes Screening und datenbasierte Entscheidungen.</p>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-background to-transparent"></div>
  </section>

  <!-- Features -->
  <section class="py-20 md:py-28">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-4 mb-16">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">Was zu dieser Phase gehoert</h2>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto">Intelligente Werkzeuge, um die besten Kandidaten zu identifizieren.</p>
      </div>
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature, i) => (
          <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border p-6 hover:border-accent/20 hover:shadow-lg hover:-translate-y-1 bg-card" style={`transition-delay: ${Math.min(i * 100, 400)}ms;`}>
            <h3 class="font-display font-bold text-lg">{feature.title}</h3>
            <p class="text-sm text-muted-foreground mt-1">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison -->
  <section class="py-20 md:py-28 bg-muted/30">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 text-center space-y-4 mb-12">
        <h2 class="text-3xl md:text-4xl font-display font-bold tracking-tight">Manuelles Screening vs. Smart Screening</h2>
        <p class="text-lg text-muted-foreground max-w-xl mx-auto">Der Unterschied zwischen Stunden und Sekunden.</p>
      </div>
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-8">
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 rounded-xl border-2 border-muted p-6 bg-card">
          <div class="text-center pb-4 border-b">
            <p class="text-sm text-muted-foreground font-medium uppercase tracking-wider">Manuelles Screening</p>
            <p class="text-2xl font-display font-bold text-muted-foreground mt-1">Zeitfresser</p>
          </div>
          <div class="space-y-3 mt-4">
            {manualScreening.map((item) => (
              <div class="flex items-center gap-3">
                <div class="w-6 h-6 rounded-full bg-destructive/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-destructive" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                </div>
                <p class="text-sm text-muted-foreground">{item}</p>
              </div>
            ))}
          </div>
        </div>
        <div class="reveal-item opacity-0 translate-y-8 transition-all duration-500 rounded-xl border-2 border-accent/30 shadow-lg p-6 bg-card" style="transition-delay: 200ms;">
          <div class="text-center pb-4 border-b">
            <p class="text-sm text-accent font-medium uppercase tracking-wider">Smart Screening</p>
            <p class="text-2xl font-display font-bold mt-1">Effizienzbooster</p>
          </div>
          <div class="space-y-3 mt-4">
            {smartScreening.map((item) => (
              <div class="flex items-center gap-3">
                <div class="w-6 h-6 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0">
                  <svg class="w-3 h-3 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                </div>
                <p class="text-sm">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Next Phase -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="reveal-item opacity-0 translate-y-8 transition-all duration-700 max-w-2xl mx-auto">
        <a href="/methode/einstellen" class="group flex items-center justify-between p-6 rounded-2xl border-2 border-emerald-500/20 hover:border-emerald-500/40 bg-emerald-500/5 hover:bg-emerald-500/10 transition-all duration-300">
          <div class="space-y-1">
            <p class="text-sm text-emerald-500 font-medium uppercase tracking-wider">Weiter zu Phase 3</p>
            <p class="text-xl font-display font-bold tracking-tight">Einstellen</p>
            <p class="text-sm text-muted-foreground">Vom Interview zum Vertrag -- schnell und professionell.</p>
          </div>
          <svg class="w-6 h-6 text-emerald-500 group-hover:translate-x-2 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <CTASection />

  <script is:inline>
  (function() {
    var items = document.querySelectorAll('.reveal-item');
    if (!items.length) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    items.forEach(function(item) { observer.observe(item); });
  })();
  </script>
</MarketingLayout>
