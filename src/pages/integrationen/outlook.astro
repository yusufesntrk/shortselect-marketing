---
import IntegrationLayout from '../../layouts/IntegrationLayout.astro';

const benefits = [
  { title: "E-Mail 2-Way-Sync", description: "Alle E-Mails automatisch im Kandidaten-Profil. Kein manuelles Kopieren.", iconPath: '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>' },
  { title: "Kalender-Integration", description: "Interview-Termine aus Outlook direkt synchronisieren.", iconPath: '<path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/>' },
  { title: "Kontakte synchronisieren", description: "Kandidaten-Kontakte zwischen Outlook und ShortSelect abgleichen.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { title: "E-Mail Vorlagen", description: "Outlook-Templates direkt aus ShortSelect verwenden.", iconPath: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>' },
  { title: "Teams-Meetings", description: "Microsoft Teams Meeting-Links automatisch generieren.", iconPath: '<path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V15"/><path d="M18 18H5a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1h9"/><path d="m12 12 4.5-4.5"/><path d="m16 8-4 0 0 4"/>' },
  { title: "DSGVO-konform", description: "Microsoft 365 Compliance — Daten bleiben in der EU.", iconPath: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>' },
];

const howItWorks = [
  { step: "1", title: "Microsoft 365 verbinden", description: "Ein Klick: Microsoft-Konto autorisieren." },
  { step: "2", title: "E-Mails synchronisieren", description: "Alle Kandidaten-E-Mails erscheinen automatisch im ATS." },
  { step: "3", title: "Termine planen", description: "Interviews aus ShortSelect heraus buchen — Kalender synchron." },
  { step: "4", title: "Produktiver arbeiten", description: "Kein Wechsel zwischen Outlook und ATS mehr noetig." },
];
---

<IntegrationLayout
  title="Outlook & Microsoft 365 Integration | ShortSelect ATS"
  description="Outlook E-Mails synchronisieren, Kalender-Integration und Teams-Meetings. Microsoft 365 nahtlos mit ShortSelect verbinden."
  badgeText="Microsoft 365"
  badgeIcon='<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>'
  headline="Outlook +"
  highlightedWord="ShortSelect"
  subline="E-Mails, Kalender und Teams-Meetings nahtlos synchronisieren. Nie wieder zwischen Outlook und ATS wechseln."
  benefitsTitle="Ihre Vorteile mit der"
  benefitsHighlight="Outlook-Integration"
  benefits={benefits}
  howItWorks={howItWorks}
  howItWorksSubline="In 4 Schritten zur nahtlosen Microsoft 365 Integration."
  trustItems={["E-Mail 2-Way-Sync", "Kalender-Sync", "DSGVO-konform"]}
/>
