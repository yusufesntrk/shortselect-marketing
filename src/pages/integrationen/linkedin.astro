---
import IntegrationLayout from '../../layouts/IntegrationLayout.astro';

const benefits = [
  { title: "Profil-Import", description: "LinkedIn-Profile mit einem Klick als Kandidaten importieren.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/>' },
  { title: "Sourcing", description: "Kandidaten direkt aus LinkedIn suchen und ansprechen.", iconPath: '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>' },
  { title: "Automatische Zuordnung", description: "Importierte Profile werden automatisch passenden Jobs zugeordnet.", iconPath: '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/>' },
  { title: "Nachrichtenversand", description: "LinkedIn-Nachrichten direkt aus ShortSelect senden.", iconPath: '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>' },
  { title: "Analytics", description: "Welche LinkedIn-Quelle bringt die besten Kandidaten?", iconPath: '<line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/>' },
  { title: "DSGVO-konform", description: "Alle LinkedIn-Daten DSGVO-konform verarbeitet und gespeichert.", iconPath: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>' },
];

const howItWorks = [
  { step: "1", title: "Verbinden", description: "LinkedIn-Account mit ShortSelect verknuepfen." },
  { step: "2", title: "Suchen & Importieren", description: "Profile finden und mit einem Klick importieren." },
  { step: "3", title: "KI-Matching", description: "ShortSelect matcht importierte Profile automatisch." },
  { step: "4", title: "Ansprechen", description: "Kandidaten direkt aus der Plattform kontaktieren." },
];
---

<IntegrationLayout
  title="LinkedIn Integration | ShortSelect ATS"
  description="LinkedIn-Profile importieren, Kandidaten sourcen und KI-Matching nutzen. Die ShortSelect LinkedIn-Integration."
  badgeText="LinkedIn"
  badgeIcon='<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/>'
  headline="LinkedIn +
"
  highlightedWord="ShortSelect"
  subline="Importieren Sie LinkedIn-Profile, sourcen Sie Kandidaten und nutzen Sie KI-Matching, alles in einer Plattform."
  benefitsTitle="Ihre Vorteile mit der"
  benefitsHighlight="LinkedIn-Integration"
  benefits={benefits}
  howItWorks={howItWorks}
  howItWorksSubline="In 4 Schritten von LinkedIn zum besten Kandidaten."
  trustItems={["DSGVO-konform", "Ein-Klick-Import", "KI-Matching"]}
/>
