---
import IntegrationLayout from '../../layouts/IntegrationLayout.astro';

const benefits = [
  { title: "Multi-Posting", description: "Stellen aus ShortSelect direkt auf StepStone schalten.", iconPath: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/>' },
  { title: "Bewerbungs-Sync", description: "StepStone-Bewerbungen automatisch in Ihre Pipeline importieren.", iconPath: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { title: "Premium & Standard", description: "Standard- und Premium-Anzeigen verwalten, direkt im ATS.", iconPath: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>' },
  { title: "DACH-Reichweite", description: "StepStone erreicht Millionen Jobsuchende in DACH.", iconPath: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>' },
  { title: "Cost-per-Apply Tracking", description: "Kosten pro Bewerbung in Echtzeit überwachen.", iconPath: '<path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/>' },
  { title: "Analytics Dashboard", description: "Views, Klicks und Bewerbungen pro Anzeige vergleichen.", iconPath: '<line x1="12" x2="12" y1="20" y2="10"/><line x1="18" x2="18" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="16"/>' },
];

const howItWorks = [
  { step: "1", title: "Konto verknuepfen", description: "StepStone-Account in ShortSelect verbinden." },
  { step: "2", title: "Anzeigen schalten", description: "Jobs als Standard oder Premium auf StepStone posten." },
  { step: "3", title: "Bewerbungen sammeln", description: "Alle Bewerbungen fliessen automatisch in Ihre Pipeline." },
  { step: "4", title: "ROI messen", description: "Cost-per-Apply und Conversion-Rates analysieren." },
];
---

<IntegrationLayout
  title="StepStone Integration | ShortSelect ATS"
  description="StepStone-Anzeigen direkt aus ShortSelect schalten, Bewerbungen synchronisieren und ROI messen."
  badgeText="StepStone"
  badgeIcon='<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>'
  headline="StepStone +"
  highlightedWord="ShortSelect"
  subline="Stellenanzeigen direkt auf StepStone schalten, Bewerbungen automatisch importieren und den ROI messen."
  benefitsTitle="Ihre Vorteile mit der"
  benefitsHighlight="StepStone-Integration"
  benefits={benefits}
  howItWorks={howItWorks}
  howItWorksSubline="In 4 Schritten von der Anzeige zum Kandidaten."
  trustItems={["DACH-Reichweite", "Premium & Standard", "ROI-Tracking"]}
/>
